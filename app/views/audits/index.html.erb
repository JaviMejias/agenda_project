<% content_for :title, "Historial de Actividad" %>

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in">
  <!-- Header Card -->
  <div class="relative mb-8 p-5 sm:p-6 rounded-[2rem] bg-gradient-to-br from-white to-indigo-50 dark:from-slate-900 dark:to-slate-950 border border-indigo-100 dark:border-slate-800 shadow-xl shadow-indigo-100/30 dark:shadow-none overflow-hidden group">
    <div class="absolute -top-24 -right-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl"></div>
    <div class="relative flex flex-col xl:flex-row xl:items-center justify-between gap-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 border border-indigo-100 dark:border-slate-700 shadow-sm flex items-center justify-center text-indigo-600 dark:text-indigo-400 text-xl">
          <i class="fa-solid fa-clock-rotate-left"></i>
        </div>
        <div>
          <h1 class="text-xl sm:text-2xl font-black text-gray-900 dark:text-white tracking-tight leading-tight">
            Historial de Actividad
          </h1>
          <p class="text-indigo-600 dark:text-indigo-400 text-[10px] font-bold uppercase tracking-widest flex items-center gap-2">
            Actividad y Auditoría General de Reservas y Pagos
          </p>
        </div>
      </div>
      <!-- Filters -->
      <%= form_with url: audits_path, method: :get, local: true, class: "w-full xl:w-auto" do |f| %>
        <div class="flex flex-wrap items-center gap-3">
          <div class="relative flex-grow sm:flex-grow-0 min-w-[220px]">
            <%= f.select :property_id, 
                options_from_collection_for_select(@properties, :id, :name, params[:property_id]), 
                { include_blank: "Todas las Propiedades" }, 
                { data: { controller: "select" }, class: "w-full" } %>
          </div>

          <div class="relative flex-grow sm:flex-grow-0 min-w-[220px]">
            <%= f.select :action_type, 
                [
                  ["Creación de Reserva", "creación"],
                  ["Actualización de Reserva", "actualización"],
                  ["Reserva Confirmada", "confirmed"],
                  ["Reserva Cancelada", "cancelled"],
                  ["Pago Agregado", "payment_added"],
                  ["Pago Aprobado", "payment_approved"],
                  ["Pago Rechazado", "payment_rejected"],
                  ["Pago Eliminado", "payment_deleted"]
                ], 
                { include_blank: "Todos los Eventos", selected: params[:action_type] }, 
                { data: { controller: "select" }, class: "w-full" } %>
          </div>

          <div class="flex items-center gap-2 w-full sm:w-auto">
            <%= f.submit "Filtrar", class: "flex-grow sm:flex-grow-0 h-[38px] px-6 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl text-[10px] font-black uppercase tracking-widest cursor-pointer shadow-md shadow-indigo-200 dark:shadow-none transition-all duration-200" %>
            
            <% if params[:property_id].present? || params[:action_type].present? %>
              <%= link_to audits_path, class: "h-[38px] w-[38px] flex items-center justify-center bg-white dark:bg-slate-800 text-gray-500 rounded-xl hover:bg-red-50 dark:hover:bg-red-950/20 hover:text-red-600 transition-all shadow-sm border border-indigo-100 dark:border-slate-700", title: "Limpiar filtros" do %>
                <i class="fa-solid fa-arrow-rotate-left text-xs"></i>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Activity Timeline/List -->
  <% if @audits.any? %>
    <div class="space-y-4">
      <% @audits.each do |audit| %>
        <% cfg = audit_icon_config(audit.action) %>
        <% reservation = audit.reservation %>
        
        <div class="group bg-white dark:bg-slate-900 rounded-3xl border border-gray-100 dark:border-slate-800/80 shadow-sm hover:shadow-md transition-all duration-300 flex items-stretch overflow-hidden">
          <!-- Property Color Accent -->
          <div class="w-2 shrink-0 self-stretch" style="background-color: <%= reservation.property.color || '#4f46e5' %>"></div>
          
          <div class="flex-grow p-5 sm:p-6 grid grid-cols-1 md:grid-cols-12 gap-6 items-center">
            <!-- Column 1: Primary Info (Col-span-5 on Desktop) -->
            <div class="md:col-span-5 flex items-start gap-4 min-w-0">
              <div class="w-10 h-10 rounded-xl bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700 shadow-sm flex items-center justify-center shrink-0 ring-4 <%= cfg[:ring] %> <%= cfg[:color] %>">
                <i class="fa-solid <%= cfg[:icon] %> text-sm"></i>
              </div>
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1.5">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-[9px] font-black uppercase tracking-widest border <%= cfg[:badge] %>">
                    <%= audit_action_label(audit.action) %>
                  </span>
                  
                  <span class="text-[10px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest flex items-center gap-1">
                    <i class="fa-regular fa-clock text-[9px]"></i>
                    <%= audit.created_at.strftime("%d %b %Y, %H:%M") %>
                  </span>
                </div>

                <h3 class="text-sm font-black text-gray-900 dark:text-white leading-snug">
                  Reserva #<%= reservation.id %>: <%= reservation.blocked? ? "Bloqueo de Calendario" : reservation.client_name %>
                </h3>
                
                <p class="text-gray-400 dark:text-slate-500 text-[10px] font-bold uppercase tracking-wider mt-1 flex items-center gap-1.5">
                  <i class="fa-solid fa-house-chimney text-[9px]"></i>
                  <%= reservation.property.name %>
                </p>

                <div class="mt-2.5 flex items-center gap-2">
                  <% if audit.user %>
                    <span class="text-[9px] font-black text-indigo-600 dark:text-indigo-400 flex items-center gap-1 bg-indigo-50/50 dark:bg-indigo-950/20 px-2 py-1 rounded-md border border-indigo-100/20">
                      <i class="fa-solid fa-user-shield text-[9px]"></i>
                      <%= audit.user.full_name %> <span class="font-normal text-gray-400 dark:text-slate-500">(Admin)</span>
                    </span>
                  <% else %>
                    <span class="text-[9px] font-black text-amber-600 dark:text-amber-500 flex items-center gap-1 bg-amber-50/50 dark:bg-amber-950/20 px-2 py-1 rounded-md border border-amber-100/20">
                      <i class="fa-solid fa-user text-[9px]"></i>
                      <%= audit.author_name %>
                    </span>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- Column 2: Audit Changes/Details (Col-span-5 on Desktop) -->
            <div class="md:col-span-5 md:border-l md:border-gray-100 dark:md:border-slate-800 md:pl-6 flex flex-col justify-center min-w-0">
              <span class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-2 block">Detalles del Cambio</span>
              <% visible_details = audit_visible_details(audit) %>
              <% if visible_details.any? %>
                <div class="space-y-2">
                  <% visible_details.each do |key, values| %>
                    <div class="bg-gray-50/50 dark:bg-slate-800/40 p-2.5 rounded-xl border border-gray-100/50 dark:border-slate-800/50 flex flex-wrap items-baseline gap-x-2 gap-y-0.5 text-xs">
                      <span class="font-black text-gray-400 dark:text-slate-500 uppercase tracking-wider shrink-0 text-[9px]">
                        <%= audit_translate_key(key) %>:
                      </span>

                      <% if values.is_a?(Array) && values.size == 2 %>
                        <span class="line-through text-rose-400 dark:text-rose-500 opacity-70">
                          <%= audit_format_value(key, values[0]) %>
                        </span>
                        <i class="fa-solid fa-arrow-right text-gray-300 dark:text-slate-600 text-[8px]"></i>
                        <span class="font-bold text-emerald-600 dark:text-emerald-400">
                          <%= audit_format_value(key, values[1]) %>
                        </span>
                      <% else %>
                        <span class="font-bold text-gray-700 dark:text-slate-300">
                          <%= audit_format_value(key, values) %>
                        </span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <div class="text-xs text-gray-400 dark:text-slate-500 italic py-2 flex items-center gap-2">
                  <i class="fa-solid fa-circle-info text-[10px] text-gray-300 dark:text-slate-700"></i>
                  Acción de auditoría sin modificaciones de campos
                </div>
              <% end %>
            </div>

            <!-- Column 3: Actions (Col-span-2 on Desktop) -->
            <div class="md:col-span-2 md:border-l md:border-gray-100 dark:md:border-slate-800 md:pl-6 flex items-center justify-start md:justify-end shrink-0 pl-14 md:pl-0">
              <%= link_to reservation_path(reservation), class: "w-full md:w-auto inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl bg-indigo-50 dark:bg-slate-800 hover:bg-indigo-600 dark:hover:bg-indigo-500 text-indigo-600 dark:text-indigo-400 hover:text-white dark:hover:text-white font-black text-[10px] uppercase tracking-widest border border-indigo-100/50 dark:border-slate-700/50 hover:border-transparent transition-all shadow-sm group/btn", title: "Ver Reserva" do %>
                <span>Ver Reserva</span>
                <i class="fa-solid fa-arrow-right text-[9px] group-hover/btn:translate-x-0.5 transition-transform"></i>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%= render "shared/pagination" %>
  <% else %>
    <%= render "shared/empty_state", 
        icon: "fa-solid fa-clock-rotate-left", 
        title: "Sin registros de actividad", 
        subtitle: "No se encontró ningún registro de auditoría con los filtros aplicados." %>
  <% end %>
</div>>
</div>
