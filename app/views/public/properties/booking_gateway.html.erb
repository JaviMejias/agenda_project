<% content_for :title, "Reserva - Continuar" %>

<div class="flex-1 flex items-center justify-center min-h-[calc(100vh-4rem)] p-4 sm:p-6 lg:p-8 relative overflow-hidden bg-slate-50 dark:bg-slate-950">
  
  <%# Decorative Background Spheres %>
  <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-gradient-to-tr from-indigo-500/10 to-purple-500/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-96 h-96 bg-gradient-to-tr from-purple-500/10 to-pink-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 w-full max-w-2xl bg-white/70 dark:bg-slate-900/60 backdrop-blur-2xl rounded-[3rem] border border-gray-100 dark:border-slate-800 shadow-[0_30px_70px_rgba(0,0,0,0.04)] overflow-hidden">
    
    <div class="p-8 sm:p-12">
      
      <!-- Back Link -->
      <%= link_to public_property_path(@property), class: "inline-flex items-center gap-2 text-xs font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest hover:underline mb-8" do %>
        <i class="fa-solid fa-arrow-left"></i> Volver al detalle del espacio
      <% end %>

      <!-- Header -->
      <div class="text-center max-w-md mx-auto mb-10">
        <div class="w-16 h-16 rounded-2xl bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mx-auto mb-4 border border-indigo-100/50 dark:border-indigo-900/20">
          <i class="fa-solid fa-circle-user text-2xl"></i>
        </div>
        <h2 class="text-2xl sm:text-3xl font-black text-gray-900 dark:text-white mb-2 tracking-tight">¿Cómo deseas continuar?</h2>
        <p class="text-xs sm:text-sm text-gray-500 dark:text-slate-400 font-bold uppercase tracking-wider">Elige una opción para agendar tu espacio</p>
      </div>

      <!-- Grid of Options -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        
        <!-- Option 1: Login -->
        <%= link_to new_user_session_path, class: "group flex flex-col p-6 rounded-[2rem] bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700/50 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden text-left" do %>
          <div class="w-10 h-10 rounded-xl bg-indigo-50 dark:bg-indigo-950/40 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mb-4 group-hover:bg-indigo-600 group-hover:text-white transition-all">
            <i class="fa-solid fa-right-to-bracket text-base"></i>
          </div>
          <h3 class="text-lg font-black text-gray-950 dark:text-white mb-1.5">Iniciar Sesión</h3>
          <p class="text-xs text-gray-500 dark:text-slate-400 font-medium leading-relaxed mb-4">Ingresa con tu cuenta registrada para reservar al instante y seguir tu historial.</p>
          <span class="mt-auto inline-flex items-center text-[10px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest group-hover:underline">
            Ingresar <i class="fa-solid fa-chevron-right ml-1.5 text-[8px] group-hover:translate-x-0.5 transition-transform"></i>
          </span>
        <% end %>

        <!-- Option 2: Register -->
        <%= link_to new_user_registration_path, class: "group flex flex-col p-6 rounded-[2rem] bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700/50 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 relative overflow-hidden text-left" do %>
          <div class="w-10 h-10 rounded-xl bg-purple-50 dark:bg-purple-950/40 text-purple-600 dark:text-purple-400 flex items-center justify-center mb-4 group-hover:bg-purple-600 group-hover:text-white transition-all">
            <i class="fa-solid fa-user-plus text-base"></i>
          </div>
          <h3 class="text-lg font-black text-gray-950 dark:text-white mb-1.5">Crear una Cuenta</h3>
          <p class="text-xs text-gray-500 dark:text-slate-400 font-medium leading-relaxed mb-4">Regístrate como cliente en segundos. Tu cuenta es 100% gratuita y segura.</p>
          <span class="mt-auto inline-flex items-center text-[10px] font-black text-purple-600 dark:text-purple-400 uppercase tracking-widest group-hover:underline">
            Registrarse <i class="fa-solid fa-chevron-right ml-1.5 text-[8px] group-hover:translate-x-0.5 transition-transform"></i>
          </span>
        <% end %>

      </div>

      <div class="border-t border-gray-100 dark:border-slate-800/80 pt-8 text-center">
        <p class="text-xs text-gray-400 dark:text-slate-500 font-bold uppercase tracking-wider mb-4">¿Tienes prisa?</p>
        
        <!-- Option 3: Continue as Guest -->
        <%= link_to booking_public_property_path(@property, guest: true), class: "group inline-flex items-center gap-2.5 justify-center rounded-2xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-800 hover:bg-slate-50 dark:hover:bg-slate-750 text-gray-700 dark:text-slate-200 px-8 py-3.5 text-xs font-black uppercase tracking-widest shadow-sm hover:shadow-md transition-all active:scale-95 duration-300" do %>
          <i class="fa-solid fa-circle-arrow-right text-gray-400 group-hover:text-indigo-500 transition-colors"></i>
          <span>Continuar como Invitado</span>
        <% end %>
        
        <p class="text-[9px] text-gray-400 dark:text-slate-500 mt-3 font-medium">Podrás reservar usando tu nombre y correo sin registrar contraseña.</p>
      </div>

    </div>
  </div>
</div>
