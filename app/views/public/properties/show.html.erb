<% content_for :title, "#{@property.name} - Detalle" %>
<div class="w-full max-w-[98%] xl:max-w-[95%] mx-auto px-4 sm:px-6 lg:px-8 py-12 animate-fade-in" data-controller="modal">
  <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-[0_20px_60px_rgba(0,0,0,0.03)] overflow-hidden border border-gray-100/80 dark:border-slate-800 relative">
    <div class="relative h-[22rem] sm:h-[26rem] overflow-hidden bg-slate-950">
      <% if @property.images.attached? %>
        <%= image_tag @property.images.first.variant(resize_to_fill: [1600, 600]), class: "absolute inset-0 w-full h-full object-cover opacity-60 filter blur-[2px] scale-105" %>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/40 to-transparent"></div>
      <% else %>
        <div class="absolute inset-0 bg-gradient-to-tr from-slate-900 to-indigo-950/40"></div>
      <% end %>
      
      <div class="absolute top-6 left-6 z-10">
        <%= link_to root_path, class: "inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-white/10 hover:bg-white/20 border border-white/10 backdrop-blur-md text-white transition-all shadow-lg hover:scale-105" do %>
          <i class="fa-solid fa-arrow-left"></i>
        <% end %>
      </div>
      <div class="absolute bottom-10 left-6 sm:left-12 right-6 sm:right-12 z-10 text-white">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="inline-flex items-center gap-1 px-3.5 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-wider bg-emerald-500/90 dark:bg-emerald-500/20 backdrop-blur text-white shadow-md">
            <i class="fa-solid fa-circle-check"></i> Espacio Verificado
          </span>
          <% if @property.pricing_model == 'per_hour' %>
            <span class="inline-flex items-center gap-1 px-3.5 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-wider bg-amber-500/90 dark:bg-amber-500/20 backdrop-blur text-white shadow-md">
              <i class="fa-regular fa-clock"></i> Por Hora
            </span>
          <% else %>
            <span class="inline-flex items-center gap-1 px-3.5 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-wider bg-blue-500/90 dark:bg-blue-500/20 backdrop-blur text-white shadow-md">
              <i class="fa-regular fa-calendar"></i> Por Día
            </span>
          <% end %>
        </div>
        <h1 class="text-3xl sm:text-5xl font-black mb-3 tracking-tight leading-none text-white drop-shadow-md"><%= @property.name %></h1>
        <p class="text-white/80 font-bold text-sm sm:text-base flex items-center gap-2 drop-shadow-sm">
          <i class="fa-solid fa-location-dot text-indigo-400"></i> <%= @property.address %>
        </p>
      </div>
    </div>
    
    <div class="p-8 sm:p-12 grid grid-cols-1 lg:grid-cols-3 gap-12 relative z-20">
      <div class="lg:col-span-2 space-y-10">
        <div>
          <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-4">Sobre el Espacio</h2>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed text-base whitespace-pre-line font-medium">
            <%= @property.description.present? ? @property.description : "Este espacio exclusivo cuenta con todos los estándares y comodidades necesarias para llevar a cabo tus eventos o reuniones de manera profesional y cómoda. Contacta para más información." %>
          </p>
        </div>
        <% if @property.images.attached? && @property.images.count > 1 %>
          <div>
            <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-6">Galería de Fotos</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4" data-controller="lightbox">
              <% @property.images.each_with_index do |image, index| %>
                <div class="group relative h-40 rounded-3xl overflow-hidden bg-gray-50 border border-gray-100 dark:border-slate-800 shadow-sm cursor-zoom-in">
                  <%= image_tag image.variant(resize_to_fill: [400, 300]), class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %>
                  <div class="absolute inset-0 bg-slate-950/0 group-hover:bg-slate-950/20 transition-all flex items-center justify-center">
                    <i class="fa-solid fa-magnifying-glass-plus text-white text-lg opacity-0 group-hover:opacity-100 transition-opacity transform scale-90 group-hover:scale-100 duration-300"></i>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <div>
        <div class="sticky top-24 bg-gradient-to-b from-indigo-50/50 to-white dark:from-slate-800/40 dark:to-slate-900 border border-indigo-100/50 dark:border-slate-800 rounded-[2rem] p-8 shadow-xl relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>
          <div class="mb-6">
            <span class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest block mb-1">Precio Base</span>
            <div class="text-4xl font-black text-indigo-600 dark:text-indigo-400 font-sans leading-none mb-1">
              $<%= number_with_delimiter(@property.base_price.to_i, delimiter: ".") %>
            </div>
            <span class="text-xs text-gray-400 font-bold">Cobro por <%= @property.pricing_model == 'per_hour' ? 'hora' : 'día' %> de arriendo</span>
          </div>
          <div class="space-y-4 mb-8">
            <div class="flex items-center gap-3.5 text-xs text-gray-500 dark:text-slate-400 font-bold">
              <i class="fa-solid fa-calendar-check text-emerald-500 text-sm"></i>
              <span>Confirmación sujeta a disponibilidad</span>
            </div>
            <div class="flex items-center gap-3.5 text-xs text-gray-500 dark:text-slate-400 font-bold">
              <i class="fa-solid fa-bolt text-amber-500 text-sm"></i>
              <span>Reserva directa en sencillos pasos</span>
            </div>
            <div class="flex items-center gap-3.5 text-xs text-gray-500 dark:text-slate-400 font-bold">
              <i class="fa-solid fa-shield-halved text-indigo-500 text-sm"></i>
              <span>Protección y políticas de cancelación claras</span>
            </div>
          </div>
          
          <% if user_signed_in? %>
            <%= link_to booking_public_property_path(@property), class: "group flex items-center justify-center gap-3 rounded-2xl bg-indigo-600 dark:bg-indigo-500 hover:bg-indigo-700 dark:hover:bg-indigo-600 text-white p-4 text-sm font-black shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/30 dark:shadow-none transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95 text-center w-full" do %>
              <span>Ver Reservas Disponibles</span>
              <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            <% end %>
          <% else %>
            <button data-action="click->modal#open" class="group flex items-center justify-center gap-3 rounded-2xl bg-indigo-600 dark:bg-indigo-500 hover:bg-indigo-700 dark:hover:bg-indigo-600 text-white p-4 text-sm font-black shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/30 dark:shadow-none transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95 text-center w-full cursor-pointer">
              <span>Ver Reservas Disponibles</span>
              <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </button>
          <% end %>
          
          <div class="text-center mt-4">
            <span class="text-[9px] text-gray-400 dark:text-slate-500 uppercase tracking-widest font-black text-center block">Consulta de calendario en tiempo real</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal de Pasarela de Acceso -->
  <div data-modal-target="dialog" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true">
    <!-- Backdrop Blur overlay -->
    <div data-modal-target="overlay" class="fixed inset-0 bg-slate-950/40 dark:bg-slate-950/65 backdrop-blur-sm transition-opacity duration-300 opacity-0"></div>
    
    <!-- Modal Wrapper -->
    <div data-action="click->modal#close" class="fixed inset-0 z-[51] flex items-center justify-center p-4 sm:p-6 md:p-8 overflow-y-auto cursor-pointer">
      <div data-modal-target="content" data-action="click->modal#stopPropagation" class="relative bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-slate-800 w-full max-w-2xl overflow-hidden transition-all duration-300 transform scale-95 opacity-0 translate-y-4 cursor-default">
        
        <!-- Background Orbs -->
        <div class="absolute -top-32 -left-32 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-32 -right-32 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl pointer-events-none"></div>
        
        <!-- Close Button -->
        <button data-action="click->modal#close" type="button" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-gray-100 hover:bg-gray-200 dark:bg-slate-800 dark:hover:bg-slate-700 flex items-center justify-center text-gray-500 dark:text-slate-400 hover:scale-105 active:scale-95 transition-all cursor-pointer z-25">
          <i class="fa-solid fa-xmark"></i>
        </button>

        <div class="p-8 sm:p-12 relative z-10 text-center">
          <div class="w-16 h-16 rounded-[1.5rem] bg-gradient-to-tr from-indigo-500 to-purple-600 flex items-center justify-center text-white mx-auto shadow-lg shadow-indigo-500/20 mb-6">
            <i class="fa-solid fa-calendar-days text-2xl animate-pulse"></i>
          </div>
          
          <h3 class="text-2xl sm:text-3xl font-black text-gray-900 dark:text-white mb-2 tracking-tight">Agendar Reserva</h3>
          <p class="text-sm font-semibold text-gray-500 dark:text-slate-400 max-w-md mx-auto mb-8">
            Elige cómo deseas continuar para revisar el calendario de reservas disponibles y completar tu agendamiento.
          </p>

          <!-- Choice Grid -->
          <div class="grid grid-cols-1 gap-4 text-left">
            <!-- Iniciar Sesión -->
            <%= link_to new_user_session_path, class: "group flex items-center justify-between p-5 rounded-3xl bg-slate-50 hover:bg-indigo-50/50 dark:bg-slate-800/40 dark:hover:bg-indigo-950/20 border border-gray-100 hover:border-indigo-100 dark:border-slate-800 dark:hover:border-indigo-900/40 transition-all duration-300" do %>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shadow-sm border border-gray-100/50 dark:border-slate-700 group-hover:scale-105 transition-transform">
                  <i class="fa-solid fa-right-to-bracket text-lg"></i>
                </div>
                <div>
                  <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest block mb-0.5">Ya tengo una cuenta</span>
                  <span class="text-sm font-black text-gray-900 dark:text-white">Iniciar Sesión</span>
                </div>
              </div>
              <div class="w-8 h-8 rounded-full bg-white dark:bg-slate-800 flex items-center justify-center text-gray-400 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 shadow-sm transition-all group-hover:translate-x-0.5">
                <i class="fa-solid fa-arrow-right text-xs"></i>
              </div>
            <% end %>

            <!-- Crear Cuenta -->
            <%= link_to new_user_registration_path, class: "group flex items-center justify-between p-5 rounded-3xl bg-slate-50 hover:bg-purple-50/50 dark:bg-slate-800/40 dark:hover:bg-purple-950/20 border border-gray-100 hover:border-purple-100 dark:border-slate-800 dark:hover:border-purple-900/40 transition-all duration-300" do %>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 flex items-center justify-center text-purple-600 dark:text-purple-400 shadow-sm border border-gray-100/50 dark:border-slate-700 group-hover:scale-105 transition-transform">
                  <i class="fa-solid fa-user-plus text-lg"></i>
                </div>
                <div>
                  <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest block mb-0.5">Soy nuevo en la plataforma</span>
                  <span class="text-sm font-black text-gray-900 dark:text-white">Crear Cuenta (Cliente)</span>
                </div>
              </div>
              <div class="w-8 h-8 rounded-full bg-white dark:bg-slate-800 flex items-center justify-center text-gray-400 group-hover:text-purple-600 dark:group-hover:text-purple-400 shadow-sm transition-all group-hover:translate-x-0.5">
                <i class="fa-solid fa-arrow-right text-xs"></i>
              </div>
            <% end %>

            <!-- Invitado -->
            <%= link_to booking_public_property_path(@property, guest: true), class: "group flex items-center justify-between p-5 rounded-3xl bg-slate-50 hover:bg-emerald-50/50 dark:bg-slate-800/40 dark:hover:bg-emerald-950/20 border border-gray-100 hover:border-emerald-100 dark:border-slate-800 dark:hover:border-emerald-900/40 transition-all duration-300" do %>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 flex items-center justify-center text-emerald-600 dark:text-emerald-400 shadow-sm border border-gray-100/50 dark:border-slate-700 group-hover:scale-105 transition-transform">
                  <i class="fa-solid fa-user-secret text-lg"></i>
                </div>
                <div>
                  <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest block mb-0.5">Agendar de forma inmediata</span>
                  <span class="text-sm font-black text-gray-900 dark:text-white">Continuar como Invitado</span>
                </div>
              </div>
              <div class="w-8 h-8 rounded-full bg-white dark:bg-slate-800 flex items-center justify-center text-gray-400 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 shadow-sm transition-all group-hover:translate-x-0.5">
                <i class="fa-solid fa-arrow-right text-xs"></i>
              </div>
            <% end %>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
