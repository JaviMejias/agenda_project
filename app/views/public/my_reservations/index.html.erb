<% content_for :title, "Mis Reservas - Agenda Pro" %>
<div class="w-full mx-auto px-4 sm:px-6 lg:px-8 py-12 animate-fade-in">
  <%= render "shared/index_header", title: "Mis Reservas", icon: "fa-solid fa-receipt", subtitle: "Historial completo de tus reservas activas y pasadas", count: @reservations.count do %>
    <%= link_to public_property_index_path, class: "inline-flex items-center gap-2.5 rounded-2xl bg-indigo-600 dark:bg-indigo-500 hover:bg-indigo-700 dark:hover:bg-indigo-600 text-white py-3.5 px-6 text-xs font-black uppercase tracking-widest shadow-xl shadow-indigo-500/25 dark:shadow-none hover:-translate-y-0.5 active:scale-95 transition-all duration-300" do %>
      <i class="fa-solid fa-house"></i> Buscar Más Espacios
    <% end %>
  <% end %>
  <% if @reservations.any? %>
    <div class="grid grid-cols-1 gap-6">
      <% @reservations.each do |reservation| %>
        <div class="bg-white dark:bg-slate-900 rounded-3xl p-6 sm:p-8 border border-gray-100 dark:border-slate-800 shadow-xl hover:shadow-2xl transition-all duration-300 flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6">
          <div class="flex gap-4 sm:gap-6 items-start">
            <div class="w-16 h-16 rounded-2xl bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-2xl shrink-0">
              <i class="fa-solid fa-house-chimney"></i>
            </div>
            <div>
              <h3 class="text-xl font-black text-gray-900 dark:text-white mb-2"><%= reservation.property.name %></h3>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-bold text-gray-500 dark:text-slate-400">
                <span class="flex items-center gap-1">
                  <i class="fa-solid fa-calendar-day"></i> <%= reservation.start_time.strftime("%d/%m/%Y") %>
                </span>
                <span class="text-gray-300 dark:text-slate-700">•</span>
                <span class="flex items-center gap-1">
                  <i class="fa-solid fa-clock"></i> <%= reservation.start_time.strftime("%H:%M") %> - <%= reservation.end_time.strftime("%H:%M") %>
                </span>
                <span class="text-gray-300 dark:text-slate-700">•</span>
                <span class="flex items-center gap-1 uppercase tracking-widest text-[9px] bg-gray-50 dark:bg-slate-800 px-2 py-0.5 rounded border border-gray-100 dark:border-slate-700">
                  <%= reservation.property.pricing_model == 'per_hour' ? 'Hora' : 'Día' %>
                </span>
              </div>
            </div>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <span class="px-4 py-2 rounded-xl border text-[10px] font-black uppercase tracking-widest <%= reservation_status_color_classes(reservation.status) %>">
              <%= reservation.status_text %>
            </span>
            <span class="px-4 py-2 rounded-xl border text-[10px] font-black uppercase tracking-widest <%= reservation_payment_state_color_classes(reservation.payment_state) %>">
              <%= reservation.payment_state %>
            </span>
          </div>
          <div class="w-full lg:w-auto flex flex-row sm:flex-col lg:items-end justify-between items-center gap-4 pt-6 lg:pt-0 border-t lg:border-t-0 border-gray-100 dark:border-slate-800">
            <div class="text-left lg:text-right">
              <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-0.5">Total</p>
              <p class="text-xl font-black text-indigo-600 dark:text-indigo-400">$<%= number_with_delimiter(reservation.total_price.to_i, delimiter: ".") %></p>
            </div>
            <div class="flex items-center gap-2">
              <%= link_to receipt_public_reservation_path(reservation.token, format: :pdf), target: "_blank", class: "w-10 h-10 rounded-xl bg-gray-50 hover:bg-gray-100 dark:bg-slate-800 dark:hover:bg-slate-700 text-gray-500 dark:text-slate-400 border border-gray-100 dark:border-slate-700 flex items-center justify-center transition-colors shadow-sm active:scale-95", title: "Descargar PDF" do %>
                <i class="fa-solid fa-file-pdf"></i>
              <% end %>
              <%= link_to public_reservation_path(reservation.token), class: "inline-flex items-center justify-center gap-2 rounded-xl bg-gray-900 hover:bg-black dark:bg-indigo-600 dark:hover:bg-indigo-500 text-white px-5 py-2.5 text-xs font-black uppercase tracking-widest shadow-sm active:scale-95 transition-all" do %>
                <span>Ver Detalles</span> <i class="fa-solid fa-arrow-right text-[10px]"></i>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center p-16 bg-white dark:bg-slate-900 rounded-[2.5rem] border border-gray-100 dark:border-slate-800 shadow-xl">
      <div class="w-20 h-20 rounded-full bg-gray-50 dark:bg-slate-800 flex items-center justify-center mx-auto text-gray-400 mb-6">
        <i class="fa-solid fa-receipt text-3xl"></i>
      </div>
      <h3 class="text-xl font-black text-gray-900 dark:text-white mb-2">No tienes reservas registradas</h3>
      <p class="text-gray-500 dark:text-slate-400 max-w-sm mx-auto mb-8 leading-relaxed">Una vez que solicites tu primera reserva o te registres con el mismo correo, las verás listadas aquí.</p>
      <%= link_to public_property_index_path, class: "inline-flex items-center gap-2 rounded-2xl bg-indigo-600 dark:bg-indigo-500 text-white py-3.5 px-6 text-sm font-black shadow-lg shadow-indigo-500/20 hover:bg-indigo-700 dark:hover:bg-indigo-600 transition-all" do %>
        <i class="fa-solid fa-calendar-plus"></i> Reservar Mi Primer Espacio
      <% end %>
    </div>
  <% end %>
</div>
