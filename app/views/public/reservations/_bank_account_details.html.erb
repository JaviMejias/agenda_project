<div class="space-y-2.5 text-xs">
  <div class="flex justify-between border-b border-gray-100 dark:border-slate-800/80 pb-2 items-center">
    <span class="text-gray-500 dark:text-slate-400 font-bold">Banco:</span>
    <span class="text-gray-900 dark:text-white font-extrabold"><%= account[:bank_name] %></span>
  </div>
  <div class="flex justify-between border-b border-gray-100 dark:border-slate-800/80 pb-2 items-center">
    <span class="text-gray-500 dark:text-slate-400 font-bold">Tipo de Cuenta:</span>
    <span class="text-gray-900 dark:text-white font-extrabold"><%= account[:account_type] %></span>
  </div>
  <div class="flex justify-between border-b border-gray-100 dark:border-slate-800/80 pb-2 items-center">
    <span class="text-gray-500 dark:text-slate-400 font-bold">Nº de Cuenta:</span>
    <button type="button" data-controller="clipboard" data-clipboard-text-value="<%= account[:account_number] %>" data-action="click->clipboard#copy" class="relative group flex items-center gap-1.5 px-2 py-1 -mr-2 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-950/40 active:scale-95 transition-all cursor-pointer select-none" title="Copiar Nº de Cuenta">
      <span data-clipboard-target="tooltip" class="copy-msg absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2.5 py-1 bg-slate-900 dark:bg-slate-800 text-white text-[9px] font-bold rounded-lg shadow-lg opacity-0 translate-y-1 pointer-events-none transition-all duration-300 whitespace-nowrap z-30">
        ¡Nº de cuenta copiado!
        <span class="absolute top-full left-1/2 -translate-x-1/2 -mt-0.5 w-1.5 h-1.5 bg-slate-900 dark:bg-slate-800 rotate-45"></span>
      </span>
      <span data-clipboard-target="value" class="copy-val inline-block text-gray-900 dark:text-white font-extrabold transition-all duration-300"><%= account[:account_number] %></span>
      <i data-clipboard-target="icon" class="copy-icon fa-solid fa-copy text-gray-400 text-[10px] transition-all duration-300"></i>
    </button>
  </div>
  <div class="flex justify-between border-b border-gray-100 dark:border-slate-800/80 pb-2 items-center">
    <span class="text-gray-500 dark:text-slate-400 font-bold">RUT:</span>
    <button type="button" data-controller="clipboard" data-clipboard-text-value="<%= account[:holder_rut] %>" data-action="click->clipboard#copy" class="relative group flex items-center gap-1.5 px-2 py-1 -mr-2 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-950/40 active:scale-95 transition-all cursor-pointer select-none" title="Copiar RUT">
      <span data-clipboard-target="tooltip" class="copy-msg absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2.5 py-1 bg-slate-900 dark:bg-slate-800 text-white text-[9px] font-bold rounded-lg shadow-lg opacity-0 translate-y-1 pointer-events-none transition-all duration-300 whitespace-nowrap z-30">
        ¡RUT copiado!
        <span class="absolute top-full left-1/2 -translate-x-1/2 -mt-0.5 w-1.5 h-1.5 bg-slate-900 dark:bg-slate-800 rotate-45"></span>
      </span>
      <span data-clipboard-target="value" class="copy-val inline-block text-gray-900 dark:text-white font-extrabold transition-all duration-300"><%= account[:formatted_holder_rut] %></span>
      <i data-clipboard-target="icon" class="copy-icon fa-solid fa-copy text-gray-400 text-[10px] transition-all duration-300"></i>
    </button>
  </div>
  <div class="flex justify-between pb-0.5 items-center">
    <span class="text-gray-500 dark:text-slate-400 font-bold">Correo de Aviso:</span>
    <button type="button" data-controller="clipboard" data-clipboard-text-value="<%= account[:holder_email] %>" data-action="click->clipboard#copy" class="relative group flex items-center gap-1.5 px-2 py-1 -mr-2 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-950/40 active:scale-95 transition-all cursor-pointer select-none" title="Copiar Correo de Aviso">
      <span data-clipboard-target="tooltip" class="copy-msg absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2.5 py-1 bg-slate-900 dark:bg-slate-800 text-white text-[9px] font-bold rounded-lg shadow-lg opacity-0 translate-y-1 pointer-events-none transition-all duration-300 whitespace-nowrap z-30">
        ¡Correo copiado!
        <span class="absolute top-full left-1/2 -translate-x-1/2 -mt-0.5 w-1.5 h-1.5 bg-slate-900 dark:bg-slate-800 rotate-45"></span>
      </span>
      <span data-clipboard-target="value" class="copy-val inline-block text-gray-955 dark:text-white font-extrabold transition-all duration-300"><%= account[:holder_email] %></span>
      <i data-clipboard-target="icon" class="copy-icon fa-solid fa-copy text-gray-400 text-[10px] transition-all duration-300"></i>
    </button>
  </div>
</div>
