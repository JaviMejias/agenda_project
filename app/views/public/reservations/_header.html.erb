<div class="p-8 sm:p-10 border-b border-gray-100 dark:border-slate-800 relative overflow-hidden bg-gradient-to-br from-indigo-50/30 to-purple-50/30 dark:from-slate-900/50 dark:to-slate-950/50">
  <div class="absolute -top-24 -right-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 relative z-10">
    <div>
      <div class="flex items-center gap-2 mb-3 text-xs">
        <span class="text-gray-500 dark:text-slate-400 font-bold">Código reserva:</span>
        <button type="button" data-controller="clipboard" data-clipboard-text-value="<%= reservation.token %>" data-action="click->clipboard#copy" class="relative group flex items-center gap-1.5 px-2 py-1 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-950/40 active:scale-95 transition-all cursor-pointer select-none font-mono" title="Copiar Código de Reserva">
          <span data-clipboard-target="tooltip" class="copy-msg absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 px-2.5 py-1 bg-slate-900 dark:bg-slate-800 text-white text-[9px] font-bold rounded-lg shadow-lg opacity-0 translate-y-1 pointer-events-none transition-all duration-300 whitespace-nowrap z-30">
            ¡Código copiado!
            <span class="absolute top-full left-1/2 -translate-x-1/2 -mt-0.5 w-1.5 h-1.5 bg-slate-900 dark:bg-slate-800 rotate-45"></span>
          </span>
          <span data-clipboard-target="value" class="copy-val inline-block text-indigo-600 dark:text-indigo-400 font-extrabold transition-all duration-300"><%= reservation.token %></span>
          <i data-clipboard-target="icon" class="copy-icon fa-solid fa-copy text-gray-400 text-[10px] transition-all duration-300"></i>
        </button>
      </div>
      <h1 class="text-3xl font-black text-gray-900 dark:text-white mb-2 tracking-tight">Estado de tu Reserva</h1>
      <p class="text-sm text-gray-500 dark:text-slate-400 font-medium">Propiedad: <span class="font-bold text-gray-700 dark:text-slate-300"><%= reservation.property.name %></span></p>
    </div>
    <div class="flex items-center gap-3">
      <span class="px-5 py-2.5 rounded-2xl border text-xs font-black uppercase tracking-widest <%= reservation_status_color_classes(reservation.status) %>">
        <i class="fa-solid fa-circle-info mr-1.5"></i> <%= reservation.status_text %>
      </span>
    </div>
  </div>
</div>
