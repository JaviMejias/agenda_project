<div class="space-y-6">
  <h3 class="text-xs font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-4">Información Financiera</h3>
  <div class="bg-gray-50 dark:bg-slate-800/40 rounded-3xl p-6 border border-gray-100 dark:border-slate-800/60">
    <div class="flex justify-between items-center mb-3">
      <span class="text-xs font-bold text-gray-500 dark:text-slate-400">Total Reserva</span>
      <span class="text-lg font-black text-gray-900 dark:text-white">$<%= number_with_delimiter(reservation.total_price.to_i, delimiter: ".") %></span>
    </div>
    <div class="flex justify-between items-center mb-3">
      <span class="text-xs font-bold text-gray-500 dark:text-slate-400">Total Abonado</span>
      <span class="text-sm font-black text-emerald-600 dark:text-emerald-400">-$<%= number_with_delimiter(reservation.total_paid.to_i, delimiter: ".") %></span>
    </div>
    <div class="pt-3 border-t border-gray-200 dark:border-slate-700 flex justify-between items-center">
      <span class="text-xs font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest">Saldo Pendiente</span>
      <span class="text-xl font-black text-indigo-600 dark:text-indigo-400">$<%= number_with_delimiter(reservation.pending_balance.to_i, delimiter: ".") %></span>
    </div>
  </div>
  <% unless reservation.cancelled? %>
    <div class="flex gap-2">
      <%= link_to receipt_public_reservation_path(reservation.token, format: :pdf), target: "_blank", class: "flex-1 inline-flex items-center justify-center gap-2 rounded-2xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 text-gray-700 dark:text-slate-300 py-3.5 px-4 text-xs font-black uppercase tracking-widest hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors shadow-sm" do %>
        <i class="fa-solid fa-file-pdf"></i> Descargar Comprobante PDF
      <% end %>
    </div>
  <% end %>
</div>
