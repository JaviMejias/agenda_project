<% content_for :title, "Seguimiento de tu Reserva ##{@reservation.id}" %>
<div class="w-full mx-auto px-4 sm:px-6 lg:px-8 py-12 animate-fade-in">
  <% if user_signed_in? %>
    <div class="mx-auto mb-6">
      <%= link_to public_property_index_path, class: "inline-flex items-center gap-2 text-xs font-black text-gray-500 dark:text-slate-400 uppercase tracking-widest hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" do %>
        <i class="fa-solid fa-arrow-left text-sm"></i> Volver a Propiedades
      <% end %>
    </div>
  <% end %>
  <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100 dark:border-slate-800">
    <%= render "public/reservations/header", reservation: @reservation %>
    <div class="p-8 sm:p-10 grid grid-cols-1 md:grid-cols-2 gap-8 border-b border-gray-100 dark:border-slate-800">
      <%= render "public/reservations/period_details", reservation: @reservation %>
      <%= render "public/reservations/financial_details", reservation: @reservation %>
    </div>
    <div class="p-8 sm:p-10 divide-y md:divide-y-0 md:divide-x divide-gray-100 dark:divide-slate-800 grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="md:pr-8">
        <%= render "public/reservations/transaction_history", payments: @payments, reservation: @reservation %>
      </div>
      <div class="md:pl-8">
        <h3 class="text-xs font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-6">Subir Comprobante de Pago</h3>
        <% unless @reservation.cancelled? || @reservation.pending_balance <= 0 %>
          <%= render "public/reservations/bank_accounts", reservation: @reservation %>
        <% end %>
        <%= render "public/reservations/payment_form", reservation: @reservation, new_payment: @new_payment %>
      </div>
    </div>
  </div>
  <% if user_signed_in? %>
    <div class="mt-8 text-center">
      <%= link_to public_property_index_path, class: "inline-flex items-center gap-2 text-xs font-black text-gray-500 dark:text-slate-400 uppercase tracking-widest hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" do %>
        <i class="fa-solid fa-arrow-left"></i> Volver a Propiedades
      <% end %>
    </div>
  <% end %>
</div>
