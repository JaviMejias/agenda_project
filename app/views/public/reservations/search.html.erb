<% content_for :title, "Buscar tu Reserva - Agenda Pro" %>
<div class="min-h-[80vh] flex flex-col items-center justify-center px-4 sm:px-6 lg:px-8 py-12 animate-fade-in">
  <div class="max-w-md w-full text-center bg-white dark:bg-slate-900 rounded-[2.5rem] p-10 shadow-2xl border border-gray-100 dark:border-slate-800 relative overflow-hidden transition-all duration-500">
    <div class="absolute -top-24 -right-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-purple-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative z-10 space-y-6">
      <div class="w-20 h-20 rounded-[2rem] bg-indigo-50 dark:bg-indigo-950/30 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mx-auto shadow-md border border-indigo-100/50 dark:border-indigo-900/50 hover:rotate-12 transition-transform duration-500">
        <i class="fa-solid fa-magnifying-glass-location text-3xl"></i>
      </div>
      <h1 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight">
        Sigue tu Reserva
      </h1>
      <p class="text-sm text-gray-500 dark:text-slate-400 font-medium leading-relaxed max-w-[320px] mx-auto">
        Ingresa el código único de 24 caracteres enviado a tu correo electrónico para verificar el estado de tu pedido, gestionar tus pagos o subir comprobantes.
      </p>
      <% if flash[:alert].present? %>
        <div class="p-4 rounded-2xl bg-rose-50 dark:bg-rose-950/20 text-rose-600 dark:text-rose-400 text-xs font-semibold border border-rose-100/50 dark:border-rose-900/30 text-left flex items-start gap-3 animate-shake">
          <i class="fa-solid fa-circle-exclamation mt-0.5 text-sm"></i>
          <span><%= flash[:alert] %></span>
        </div>
      <% end %>
      <%= form_with url: search_public_reservations_path, method: :get, local: true, class: "space-y-5 text-left" do |f| %>
        <div class="space-y-2">
          <%= f.label :token, "Código de Reserva", class: "text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest pl-1" %>
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-400 dark:text-slate-600 group-focus-within:text-indigo-500 transition-colors">
              <i class="fa-solid fa-key text-sm"></i>
            </div>
            <%= f.text_field :token, value: params[:token], placeholder: "Ej. 24sDk29dKmWq...", 
                required: true,
                class: "block w-full pl-11 pr-4 py-4 border border-gray-200/60 dark:border-slate-800 rounded-2xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm bg-gray-50/50 dark:bg-slate-850 focus:bg-white dark:focus:bg-slate-800 text-gray-900 dark:text-white transition-all shadow-sm font-mono tracking-wider" %>
          </div>
        </div>
        <%= f.submit "Buscar y Continuar", class: "w-full inline-flex items-center justify-center gap-2 rounded-2xl bg-indigo-600 hover:bg-indigo-700 text-white py-4 px-6 text-xs font-black uppercase tracking-widest transition-all shadow-xl shadow-indigo-500/10 hover:shadow-indigo-500/20 hover:-translate-y-0.5 active:translate-y-0 cursor-pointer" %>
      <% end %>
      <div class="pt-6 border-t border-gray-100 dark:border-slate-800/80">
        <p class="text-[11px] text-gray-400 dark:text-slate-500 font-bold uppercase tracking-widest mb-3">
          ¿No tienes un código de reserva?
        </p>
        <%= link_to root_path, class: "text-xs font-black text-indigo-500 hover:text-indigo-600 dark:text-indigo-400 dark:hover:text-indigo-300 transition-colors inline-flex items-center gap-1.5" do %>
          Explorar espacios disponibles <i class="fa-solid fa-arrow-right text-[10px]"></i>
        <% end %>
      </div>
    </div>
  </div>
  <div class="mt-10 text-center">
    <div class="text-[10px] font-black text-gray-300 dark:text-slate-700 uppercase tracking-[0.3em]">Powered by Agenda Pro</div>
  </div>
</div>
