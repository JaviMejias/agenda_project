<%
  company = reservation.property.company
  bank_accounts = company&.bank_accounts&.reject(&:new_record?) || []
  accounts_to_render = if bank_accounts.any?
    bank_accounts.map do |acc|
      {
        id: acc.id,
        bank_name: acc.localized_bank_name,
        account_type: acc.localized_account_type,
        account_number: acc.account_number,
        holder_rut: acc.holder_rut,
        formatted_holder_rut: acc.formatted_holder_rut,
        holder_email: acc.holder_email
      }
    end
  else
    default_rut = company&.rut || '76.543.210-K'
    default_email = company&.email || reservation.user&.email || 'pagos@agendapro.cl'
    [
      {
        id: 'default',
        bank_name: 'Banco Estado',
        account_type: 'Cuenta Vista (Chequera Electrónica)',
        account_number: '123456789',
        holder_rut: default_rut,
        formatted_holder_rut: default_rut,
        holder_email: default_email
      }
    ]
  end
%>
<div class="bg-indigo-50/50 dark:bg-indigo-950/15 border border-indigo-100/50 dark:border-indigo-900/50 rounded-3xl p-6 mb-6">
  <div class="flex items-center gap-3 mb-4">
    <div class="w-8 h-8 rounded-xl bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center text-indigo-600 dark:text-indigo-400">
      <i class="fa-solid fa-building-columns text-sm"></i>
    </div>
    <h4 class="text-xs font-black text-indigo-950 dark:text-indigo-300 uppercase tracking-widest">Datos para Transferencia</h4>
  </div>
  <% if accounts_to_render.size > 1 %>
    <div data-controller="tabs" class="space-y-4">
      <div data-controller="drag-scroll" class="relative flex items-center group">
        <button type="button" data-drag-scroll-target="leftArrow" data-action="click->drag-scroll#slideLeft" class="absolute left-1.5 z-10 w-8 h-8 rounded-full bg-white/95 dark:bg-slate-900/95 shadow-md border border-gray-100/80 dark:border-slate-800/80 flex items-center justify-center text-gray-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:scale-105 active:scale-95 transition-all opacity-0 pointer-events-none cursor-pointer" title="Deslizar Izquierda">
          <i class="fa-solid fa-chevron-left text-[10px]"></i>
        </button>
        <div data-drag-scroll-target="scrollable" class="w-full flex items-center gap-1.5 overflow-x-auto p-1 bg-gray-100/80 dark:bg-slate-800/40 rounded-2xl [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden scroll-smooth">
          <% accounts_to_render.each do |account| %>
            <button type="button" data-tabs-target="tab" data-tab="account_<%= account[:id] %>" data-action="click->tabs#switch" class="flex-1 px-3 py-2 text-[10px] font-black uppercase tracking-widest rounded-xl transition-all cursor-pointer whitespace-nowrap text-center text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-white/40 dark:hover:bg-slate-700/30">
              <%= account[:bank_name] %>
            </button>
          <% end %>
        </div>
        <button type="button" data-drag-scroll-target="rightArrow" data-action="click->drag-scroll#slideRight" class="absolute right-1.5 z-10 w-8 h-8 rounded-full bg-white/95 dark:bg-slate-900/95 shadow-md border border-gray-100/80 dark:border-slate-800/80 flex items-center justify-center text-gray-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:scale-105 active:scale-95 transition-all opacity-0 pointer-events-none cursor-pointer" title="Deslizar Derecha">
          <i class="fa-solid fa-chevron-right text-[10px]"></i>
        </button>
      </div>
      <% accounts_to_render.each do |account| %>
        <div data-tabs-target="panel" data-panel="account_<%= account[:id] %>" class="hidden animate-fade-in">
          <%= render "public/reservations/bank_account_details", account: account %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "public/reservations/bank_account_details", account: accounts_to_render.first %>
  <% end %>
</div>
