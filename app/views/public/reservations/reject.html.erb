<div class="min-h-screen flex items-center justify-center bg-slate-50 dark:bg-slate-950 px-4 transition-colors duration-500">
  <div class="max-w-lg w-full">
    <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.02)] dark:shadow-[0_20px_50px_rgba(0,0,0,0.25)] p-10 text-center border border-gray-100 dark:border-slate-800/80 relative overflow-hidden transition-colors duration-500">
      <div class="absolute top-0 right-0 w-32 h-32 <%= reject_bg_blur_class(@status) %> rounded-full -mr-16 -mt-16 blur-3xl"></div>
      <div class="relative mb-8 inline-flex items-center justify-center w-20 h-20 rounded-3xl <%= reject_icon_wrapper_classes(@status) %> transition-all duration-700 hover:scale-105">
        <% if @status == :success %>
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        <% else %>
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
          </svg>
        <% end %>
      </div>
      <h2 class="text-3xl font-black text-gray-900 dark:text-white mb-4 tracking-tight">
        <%= reject_header_title(@status) %>
      </h2>
      <p class="text-gray-500 dark:text-slate-400 font-medium text-lg leading-relaxed mb-10 max-w-[320px] mx-auto">
        <%= @message %>
      </p>
      <div class="bg-gray-50/50 dark:bg-slate-800/20 rounded-[2rem] p-8 mb-10 text-left border border-gray-100/50 dark:border-slate-800/40">
        <div class="flex items-center gap-4 mb-6 opacity-60">
          <div class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 shadow-sm flex items-center justify-center text-gray-400 border border-gray-100 dark:border-slate-700">
            <i class="fa-solid fa-house-chimney text-lg text-rose-450"></i>
          </div>
          <div>
            <div class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Propiedad</div>
            <div class="text-gray-900 dark:text-white font-black text-lg tracking-tight line-through"><%= @reservation.property.name %></div>
          </div>
        </div>
        <div class="flex items-center gap-4 opacity-60">
          <div class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 shadow-sm flex items-center justify-center text-gray-400 border border-gray-100 dark:border-slate-700">
            <i class="fa-solid fa-calendar-xmark text-lg text-rose-450"></i>
          </div>
          <div>
            <div class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Fecha Original</div>
            <div class="text-gray-900 dark:text-slate-200 font-bold text-sm">
              <%= l(@reservation.start_time, format: :long) %>
            </div>
          </div>
        </div>
      </div>
      <div class="pt-6 border-t border-gray-100 dark:border-slate-800/80">
        <p class="text-sm font-bold <%= reject_footer_banner_classes(@status) %> py-3 rounded-2xl">
          <i class="fa-solid <%= reject_footer_icon_class(@status) %> mr-2"></i> Ya puedes cerrar esta pestaña de forma segura.
        </p>
      </div>
    </div>
    <div class="mt-10 text-center">
      <div class="text-[10px] font-black text-gray-300 dark:text-slate-700 uppercase tracking-[0.3em]">Powered by Agenda Pro</div>
    </div>
  </div>
</div>
