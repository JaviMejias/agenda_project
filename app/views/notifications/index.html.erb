<% content_for :title, "Historial de Notificaciones" %>

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-6">
  
  <%= render "shared/index_header", 
      title: "Notificaciones", 
      icon: "fa-solid fa-bell", 
      subtitle: "Historial de Actividad" do %>
    
    <% if @notifications.any? %>
      <%= button_to mark_all_as_read_notifications_path, method: :post, 
          class: "w-full sm:w-auto group flex items-center justify-center gap-3 px-6 py-3.5 bg-white dark:bg-slate-800 text-indigo-600 dark:text-white rounded-2xl border border-indigo-100 dark:border-transparent hover:bg-indigo-50 dark:hover:bg-indigo-500 transition-all shadow-md shadow-indigo-100/50 dark:shadow-none hover:-translate-y-1 active:scale-95" do %>
        <i class="fa-solid fa-check-double text-indigo-500 dark:text-indigo-200"></i>
        <span class="text-[10px] font-black uppercase tracking-widest">Marcar todo como leído</span>
      <% end %>
    <% end %>
  <% end %>

  <div class="space-y-4">
    <div id="notifications_full_list" class="space-y-4">
      <%= render @notifications %>
      <% if @notifications.none? %>
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <div class="w-16 h-16 bg-gray-50 dark:bg-slate-800 rounded-full flex items-center justify-center mb-4 text-gray-200 dark:text-slate-700">
            <i class="fa-solid fa-bell-slash text-2xl"></i>
          </div>
          <h3 class="text-lg font-black text-gray-900 dark:text-white">Sin notificaciones</h3>
          <p class="text-xs text-gray-500 dark:text-slate-400 font-medium">No hay actividad reciente para mostrar.</p>
        </div>
      <% end %>
    </div>

    <%= render "shared/pagination" %>
  </div>
</div>
