<% content_for :title, "Historial de Notificaciones" %>

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-6">
  
  <div class="relative mb-6 p-5 sm:p-6 rounded-[2rem] bg-gradient-to-br from-white to-indigo-50 dark:from-slate-900 dark:to-slate-950 border border-indigo-100 dark:border-slate-800 shadow-xl shadow-indigo-100/30 dark:shadow-none overflow-hidden group">
    <div class="absolute -top-24 -right-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl"></div>
    
    <div class="relative flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 border border-indigo-100 dark:border-slate-700 shadow-sm flex items-center justify-center text-indigo-600 dark:text-indigo-400 text-xl">
          <i class="fa-solid fa-bell"></i>
        </div>
        <div>
          <h1 class="text-xl sm:text-2xl font-black text-gray-900 dark:text-white tracking-tight leading-tight">
            Notificaciones
          </h1>
          <p class="text-indigo-600 text-[10px] font-bold uppercase tracking-widest">
            Historial de Actividad
          </p>
        </div>
      </div>
      
      <div class="flex flex-col sm:flex-row items-center gap-3">
        <% if @notifications.any? %>
          <%= button_to mark_all_as_read_notifications_path, method: :post, class: "w-full sm:w-auto group flex items-center justify-center gap-3 px-6 py-3.5 bg-white dark:bg-slate-800 text-indigo-600 dark:text-white rounded-2xl border border-indigo-100 dark:border-transparent hover:bg-indigo-50 dark:hover:bg-indigo-500 transition-all shadow-md shadow-indigo-100/50 dark:shadow-none hover:-translate-y-1 active:scale-95" do %>
            <i class="fa-solid fa-check-double text-indigo-500 dark:text-indigo-200"></i>
            <span class="text-[10px] font-black uppercase tracking-widest">Marcar todo como leído</span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="space-y-4">
    <div id="notifications_full_list" class="space-y-4">
      <%= render @notifications %>
      <% if @notifications.none? %>
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <div class="w-16 h-16 bg-gray-50 dark:bg-slate-800 rounded-full flex items-center justify-center mb-4 text-gray-200 dark:text-slate-700">
            <i class="fa-solid fa-bell-slash text-2xl"></i>
          </div>
          <h3 class="text-lg font-black text-gray-900 dark:text-white">Sin notificaciones</h3>
          <p class="text-xs text-gray-500 dark:text-slate-400 font-medium">No hay actividad reciente para mostrar.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
