<%= turbo_stream.remove dom_id(@notification) %>
<%= turbo_stream.replace "notifications_count" do %>
  <span id="notifications_count" class="absolute top-1.5 right-1.5 flex items-center justify-center min-w-[16px] h-[16px] px-1 text-[9px] font-black text-white bg-red-500 rounded-full border-2 border-white dark:border-slate-900 <%= current_user.notifications.unread.count.zero? ? 'hidden' : '' %>">
    <%= current_user.notifications.unread.count %>
  </span>
<% end %>
