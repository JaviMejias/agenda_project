<% content_for :title, "Editar Empresa" %>

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-12 animate-fade-in">
  <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] border border-indigo-50 dark:border-slate-800 shadow-2xl shadow-indigo-100/20 dark:shadow-none overflow-hidden">
    <div class="relative p-8 sm:p-12">
      <div class="absolute top-0 right-0 p-8 flex gap-4">
        <div class="w-16 h-16 rounded-2xl bg-amber-50 dark:bg-amber-900/20 flex items-center justify-center text-amber-600 dark:text-amber-400 rotate-12 transition-transform duration-500">
          <i class="fa-solid fa-pen-nib text-2xl"></i>
        </div>
        <%= button_to @company, method: :delete, class: "w-16 h-16 rounded-2xl bg-rose-50 dark:bg-rose-900/20 flex items-center justify-center text-rose-600 dark:text-rose-400 hover:bg-rose-600 hover:text-white transition-all", data: { turbo_confirm: "¿Estás seguro de eliminar esta empresa? Las propiedades vinculadas quedarán sin empresa asignada." } do %>
          <i class="fa-solid fa-trash-can text-2xl"></i>
        <% end %>
      </div>

      <div class="mb-10">
        <h1 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight mb-2">Editar Empresa</h1>
        <p class="text-gray-500 dark:text-slate-400 font-medium tracking-tight">Modifica la información legal de <span class="font-bold text-indigo-600 dark:text-indigo-400"><%= @company.name %></span>.</p>
        <div class="w-20 h-1.5 bg-gradient-to-r from-amber-500 to-orange-600 rounded-full mt-4"></div>
      </div>

      <%= render "form", company: @company %>
    </div>
  </div>
</div>
