<% content_for :title, "Gestión de Empresas" %>

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in" data-controller="search">
  
  <%= render "shared/index_header", 
      title: "Empresas / Entidades", 
      icon: "fa-solid fa-building", 
      subtitle: "Perfiles de Facturación y Marca", 
      search_url: companies_path, 
      search_placeholder: "Buscar empresa...", 
      search_frame_id: "list_frame" do %>
    
    <%= link_to new_company_path, class: "w-full sm:w-auto group flex items-center justify-center gap-3 px-6 py-3.5 bg-white dark:bg-indigo-600 text-indigo-600 dark:text-white rounded-2xl border border-indigo-100 dark:border-transparent hover:bg-indigo-50 dark:hover:bg-indigo-500 transition-all shadow-md shadow-indigo-100/50 dark:shadow-none hover:-translate-y-1 active:scale-95" do %>
      <i class="fa-solid fa-plus-circle text-indigo-500 dark:text-indigo-200 group-hover:rotate-90 transition-transform duration-500"></i>
      <span class="text-[10px] font-black uppercase tracking-widest">Nueva Empresa</span>
    <% end %>
  <% end %>

  <turbo-frame id="list_frame" class="relative block w-full">
    <%= render "shared/loading_state" %>
    
    <% if @companies.any? %>
      <div class="space-y-3 mb-8">
        <% @companies.each do |company| %>
          <div class="group bg-white dark:bg-slate-900 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-sm hover:shadow-md transition-all duration-300 flex items-center overflow-hidden">
            <div class="w-2 h-20 self-stretch shrink-0 bg-indigo-600"></div>
            <div class="flex-grow grid grid-cols-1 md:grid-cols-12 items-center p-4 sm:p-5 gap-4 sm:gap-6">
              
              <div class="md:col-span-4 flex items-center gap-4 min-w-0">
                <% if company.logo.attached? %>
                  <div class="w-12 h-12 rounded-2xl shrink-0 shadow-sm overflow-hidden border border-gray-100 dark:border-slate-700">
                    <%= image_tag company.logo, loading: "lazy", class: "w-full h-full object-cover" %>
                  </div>
                <% else %>
                  <div class="w-12 h-12 rounded-2xl bg-indigo-50 dark:bg-slate-800 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shrink-0 shadow-sm border border-gray-100 dark:border-slate-700">
                    <i class="fa-solid fa-building text-base"></i>
                  </div>
                <% end %>
                <div class="truncate">
                  <h3 class="text-sm sm:text-base font-black text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors truncate">
                    <%= company.name %>
                  </h3>
                  <p class="text-[10px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest flex items-center gap-1.5 mt-0.5">
                    <i class="fa-solid fa-id-card text-[9px]"></i> <%= company.rut %>
                  </p>
                </div>
              </div>

              <div class="md:col-span-5 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-6 md:border-l md:border-gray-50 dark:md:border-slate-800 md:pl-6">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 flex items-center justify-center text-emerald-600 dark:text-emerald-400 shrink-0">
                    <i class="fa-solid fa-tag text-xs"></i>
                  </div>
                  <p class="text-[10px] font-black text-gray-900 dark:text-slate-200 leading-none">
                    <%= company.business_type %>
                  </p>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-rose-50 dark:bg-rose-900/20 flex items-center justify-center text-rose-600 dark:text-rose-400 shrink-0">
                    <i class="fa-solid fa-location-dot text-xs"></i>
                  </div>
                  <p class="text-[10px] font-black text-gray-900 dark:text-slate-200 leading-none truncate max-w-[200px]">
                    <%= company.address %>
                  </p>
                </div>
              </div>

              <div class="md:col-span-1 border-t md:border-t-0 pt-3 md:pt-0 border-gray-50 dark:border-slate-800 md:border-l md:pl-6">
                <p class="text-[9px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-tighter leading-none mb-1.5 md:text-right">Propiedades</p>
                <p class="text-sm font-black text-indigo-600 dark:text-indigo-400 md:text-right">
                  <%= company.properties.size %>
                </p>
              </div>

              <div class="md:col-span-2 flex items-center justify-between sm:justify-end gap-3 border-t md:border-t-0 pt-4 md:pt-0 border-gray-50 dark:border-slate-800 md:border-l md:pl-6">
                <span class="md:hidden text-[9px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest">Acciones</span>
                <div class="flex gap-2">
                  <%= link_to company_path(company), data: { turbo_frame: "_top" }, class: "w-10 h-10 rounded-xl bg-gray-50 dark:bg-slate-800 flex items-center justify-center text-gray-400 dark:text-slate-500 hover:bg-indigo-600 dark:hover:bg-indigo-500 hover:text-white transition-all shadow-sm active:scale-90" do %>
                    <i class="fa-solid fa-eye text-xs"></i>
                  <% end %>
                  <%= link_to edit_company_path(company), data: { turbo_frame: "_top" }, class: "w-10 h-10 rounded-xl bg-gray-50 dark:bg-slate-800 flex items-center justify-center text-gray-400 dark:text-slate-500 hover:bg-amber-500 dark:hover:bg-amber-600 hover:text-white transition-all shadow-sm active:scale-90" do %>
                    <i class="fa-solid fa-pen-to-square text-xs"></i>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

    <%= render "shared/pagination" %>
    <% else %>
      <%= render "shared/empty_state", 
          icon: "fa-solid fa-building-circle-exclamation", 
          title: "No hay empresas", 
          subtitle: "Crea tu primera empresa para organizar tus propiedades." %>
    <% end %>
  </turbo-frame>
</div>
