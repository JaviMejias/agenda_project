<%
  form_structure = [
    { name: :name, label: "Razón Social", placeholder: "Ej: Inversiones Logísticas SpA", type: :text_field, icon: "fa-solid fa-building", required: true },
    { name: :rut, label: "RUT Empresa", placeholder: "Ej: 76.123.456-K", type: :text_field, icon: "fa-solid fa-id-card", required: true, data: { action: "input->rut#format", rut_target: "input" } },
    { name: :business_type, label: "Giro / Actividad", placeholder: "Ej: Arriendo de bodegas y logística", type: :text_field, icon: "fa-solid fa-tag", required: true },
    { name: :address, label: "Dirección Comercial", placeholder: "Ej: Av. Providencia 1234, Santiago", type: :text_field, icon: "fa-solid fa-location-dot", required: true }
  ]

  input_class = "block w-full rounded-xl border-gray-300 dark:border-slate-700 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-3 border bg-gray-50 dark:bg-slate-800 focus:bg-white dark:focus:bg-slate-900 transition-colors dark:text-white"
  label_class = "block text-sm font-bold text-gray-700 dark:text-slate-300 mb-1"
%>

<%= form_with(model: company, class: "space-y-6", data: { controller: "rut" }) do |f| %>
  <% if company.errors.any? %>
    <div class="p-6 bg-rose-50 dark:bg-rose-950/20 border border-rose-100 dark:border-rose-900 rounded-2xl animate-shake">
      <h2 class="text-rose-800 dark:text-rose-400 text-sm font-black uppercase tracking-widest mb-3 flex items-center gap-2">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <%= company.errors.count == 1 ? "1 error impide" : "#{company.errors.count} errores impiden" %> guardar esta empresa:
      </h2>
      <ul class="space-y-1">
        <% company.errors.full_messages.each do |message| %>
          <li class="text-rose-600 dark:text-rose-500 text-xs font-bold"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% form_structure.each do |field| %>
      <div class="space-y-2">
        <%= f.label field[:name], class: label_class do %>
          <i class="<%= field[:icon] %> text-gray-400 dark:text-slate-500 mr-1"></i> <%= field[:label] %>
        <% end %>
        <%= f.send(field[:type], field[:name], 
            placeholder: field[:placeholder], 
            class: input_class, 
            required: field[:required],
            data: field[:data]) %>
      </div>
    <% end %>
  </div>

  <div class="pt-6 border-t border-gray-100 dark:border-slate-800 flex flex-col sm:flex-row items-center justify-start gap-8">
    <%= link_to companies_path, class: "group inline-flex items-center text-sm font-bold text-gray-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all" do %>
      <div class="w-9 h-9 rounded-full bg-white dark:bg-slate-800 shadow-sm border border-gray-200 dark:border-slate-700 flex items-center justify-center mr-3 group-hover:bg-indigo-50 dark:group-hover:bg-indigo-900/50 group-hover:border-indigo-200 transition-all group-hover:-translate-x-1">
        <i class="fa-solid fa-arrow-left text-xs"></i>
      </div>
      Volver al listado
    <% end %>

    <%= f.button type: "submit", class: "w-full sm:w-auto sm:min-w-[200px] flex justify-center items-center py-3.5 px-6 border border-transparent rounded-xl shadow-lg text-base font-bold text-white bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer transform hover:-translate-y-1 transition-all duration-300" do %>
      <i class="fa-solid fa-floppy-disk mr-2"></i> <%= company.new_record? ? "Crear Empresa" : "Actualizar Empresa" %>
    <% end %>
  </div>
<% end %>
