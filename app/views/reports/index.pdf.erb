<meta charset="utf-8">
<style>
  @page { margin: 0; }
  body { 
    font-family: 'Helvetica', 'Arial', sans-serif; 
    color: #374151; 
    margin: 0; 
    padding: 40px; 
    background-color: #ffffff;
    line-height: 1.5;
  }
  
  .pdf-header { 
    background-color: #4f46e5; 
    color: white; 
    padding: 40px; 
    border-radius: 24px; 
    margin-bottom: 35px;
    box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.2);
  }
  .pdf-header h1 { 
    margin: 0; 
    font-size: 32px; 
    font-weight: bold; 
    letter-spacing: -0.02em;
  }
  .pdf-header p { 
    margin: 10px 0 0; 
    opacity: 0.9; 
    font-size: 13px; 
    font-weight: bold; 
    text-transform: uppercase; 
    letter-spacing: 0.05em;
  }
  
  .stats-grid { 
    display: table; 
    width: 100%; 
    border-spacing: 15px; 
    margin: 0 -15px 40px; 
  }
  .stat-card { 
    display: table-cell; 
    background: #ffffff; 
    border: 1px solid #e5e7eb; 
    padding: 25px; 
    border-radius: 20px; 
    width: 25%;
    vertical-align: top;
  }
  .stat-label { 
    font-size: 10px; 
    font-weight: bold; 
    color: #6b7280; 
    text-transform: uppercase; 
    margin-bottom: 10px; 
    letter-spacing: 0.02em;
  }
  .stat-value { 
    font-size: 22px; 
    font-weight: bold; 
    color: #111827; 
  }
  
  .section-title { 
    font-size: 20px; 
    font-weight: bold; 
    color: #111827; 
    margin: 45px 0 25px; 
    padding-bottom: 12px;
    border-bottom: 3px solid #4f46e5;
    width: 100%;
  }
  
  .table-container {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 40px;
  }

  table { 
    width: 100%; 
    border-collapse: collapse; 
  }
  th { 
    background-color: #f8fafc;
    text-align: left; 
    padding: 18px 20px; 
    font-size: 11px; 
    text-transform: uppercase; 
    color: #475569; 
    font-weight: bold; 
    border-bottom: 2px solid #e2e8f0; 
  }
  td { 
    padding: 18px 20px; 
    border-bottom: 1px solid #f1f5f9; 
    font-size: 13px; 
    color: #334155; 
  }
  tr:nth-child(even) {
    background-color: #fbfcfe;
  }
  tr:last-child td {
    border-bottom: none;
  }
  
  .badge {
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 11px;
    font-weight: bold;
    display: inline-block;
  }
  .badge-indigo { background: #e0e7ff; color: #4338ca; }
  .badge-emerald { background: #d1fae5; color: #065f46; }
  
  .money-positive { font-weight: bold; color: #059669; font-size: 14px; }
  .money-negative { font-weight: bold; color: #dc2626; }
  .property-name { font-weight: bold; color: #1e293b; font-size: 14px; }

  .trend-table { width: 50%; }
</style>

<div class="pdf-header">
  <h1>Reporte de Gestión</h1>
  <p>Agenda Propietario • Periodo: <%= l(@start_date) %> al <%= l(@end_date) %></p>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-label">Ingresos Totales</div>
    <div class="stat-value" style="color: #059669;">$<%= number_to_currency(@total_income, unit: "", separator: ",", delimiter: ".") %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Reservas Realizadas</div>
    <div class="stat-value"><%= @reservations_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Pérdida por Bloqueo</div>
    <div class="stat-value" style="color: #dc2626;">$<%= number_to_currency(@total_loss, unit: "", separator: ",", delimiter: ".") %></div>
  </div>
  <div class="stat-card">
    <% avg_occ = @properties_data.map { |p| p[:occupancy_rate] }.sum / [@properties_data.size, 1].max %>
    <div class="stat-label">Ocupación Promedio</div>
    <div class="stat-value"><%= avg_occ.round(1) %>%</div>
  </div>
</div>

<div class="section-title">Desglose por Propiedad</div>
<div class="table-container">
  <table>
    <thead>
      <tr>
        <th>Propiedad</th>
        <th style="text-align: right;">Ingresos</th>
        <th style="text-align: right;">Pérdida por Bloqueo</th>
        <th style="text-align: center;">Tasa Ocupación</th>
      </tr>
    </thead>
    <tbody>
      <% @properties_data.each do |data| %>
        <tr>
          <td>
            <span class="property-name"><%= data[:name] %></span><br>
            <span style="font-size: 10px; color: #94a3b8; font-weight: bold; text-transform: uppercase;">Activo en Gestión</span>
          </td>
          <td style="text-align: right;" class="money-positive">$<%= number_to_currency(data[:income], unit: "", separator: ",", delimiter: ".") %></td>
          <td style="text-align: right;" class="money-negative">$<%= number_to_currency(data[:loss], unit: "", separator: ",", delimiter: ".") %></td>
          <td style="text-align: center;">
            <span class="badge badge-indigo"><%= data[:occupancy_rate] %>%</span>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="section-title">Análisis de Tendencia</div>
<div class="table-container trend-table">
  <table>
    <thead>
      <tr>
        <th>Mes</th>
        <th style="text-align: right;">Ingresos Mensuales</th>
      </tr>
    </thead>
    <tbody>
      <% @monthly_trend.each do |trend| %>
        <tr>
          <td style="font-weight: bold; color: #475569;"><%= trend[:month] %></td>
          <td style="text-align: right;" class="money-positive">$<%= number_to_currency(trend[:income], unit: "", separator: ",", delimiter: ".") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
