<div class="mx-auto px-4 sm:px-6 lg:px-8 py-6" data-controller="dashboard-filters">
  
  <% if params[:format] == 'pdf' %>
    <div class="header">
      <h1>Reporte de Gestión</h1>
      <% if @company_id.present? %>
        <p>Empresa: <%= current_user.companies.find_by(id: @company_id)&.name %></p>
      <% end %>
      <p>Periodo: <%= l(@start_date) %> al <%= l(@end_date) %></p>
    </div>
  <% else %>
    <%= render "shared/index_header", 
        title: "Reportes de Gestión", 
        icon: "fa-solid fa-file-invoice-dollar", 
        subtitle: (@company_id.present? ? current_user.companies.find_by(id: @company_id)&.name : "Análisis Global de Ingresos"),
        large_form: true do %>
      
      <%= form_with url: reports_path, method: :get, class: "grid grid-cols-1 md:grid-cols-12 items-end gap-3 w-full",
          data: { 
            dashboard_filters_target: "form",
            turbo_frame: "reports_content",
            turbo_action: "advance"
          } do |f| %>
        <div class="md:col-span-3 text-left">
          <%= f.label :company_id, "Empresa", class: "text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase ml-2 mb-1.5 block" %>
          <div class="relative h-[38px] flex items-center">
            <%= f.collection_select :company_id, current_user.companies.order(name: :asc), :id, :name, { include_blank: "Todas" }, 
                data: { 
                  controller: "select",
                  action: "change->dashboard-filters#submit" 
                }, 
                class: "w-full" %>
          </div>
        </div>

        <div class="md:col-span-2 text-left">
          <%= f.label :start_date, "Desde", class: "text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase ml-2 mb-1.5 block" %>
          <%= f.text_field :start_date, value: @start_date, 
              data: { 
                controller: "datepicker",
                dashboard_filters_target: "startDate",
                action: "change->dashboard-filters#submit"
              }, 
              class: "w-full h-[38px] px-4 bg-white/80 dark:bg-slate-800 border border-indigo-100 dark:border-slate-700 rounded-xl text-xs font-bold text-gray-900 dark:text-white focus:bg-white dark:focus:bg-slate-700 transition-all shadow-sm" %>
        </div>

        <div class="md:col-span-2 text-left">
          <%= f.label :end_date, "Hasta", class: "text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase ml-2 mb-1.5 block" %>
          <%= f.text_field :end_date, value: @end_date, 
              data: { 
                controller: "datepicker",
                dashboard_filters_target: "endDate",
                action: "change->dashboard-filters#submit"
              }, 
              class: "w-full h-[38px] px-4 bg-white/80 dark:bg-slate-800 border border-indigo-100 dark:border-slate-700 rounded-xl text-xs font-bold text-gray-900 dark:text-white focus:bg-white dark:focus:bg-slate-700 transition-all shadow-sm" %>
        </div>

        <div class="md:col-span-5 flex gap-2">
          <button type="button" data-action="click->dashboard-filters#reset" class="flex-grow flex items-center justify-center h-[38px] px-4 bg-white/80 dark:bg-slate-800 text-gray-500 dark:text-slate-400 rounded-xl hover:bg-white dark:hover:bg-slate-700 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all text-xs font-bold shadow-sm border border-indigo-50 dark:border-slate-700" title="Restablecer">
            <i class="fa-solid fa-arrow-rotate-left"></i>
          </button>

          <%= link_to reports_path(format: :xlsx, start_date: @start_date, end_date: @end_date, company_id: @company_id), 
              class: "flex-grow flex items-center justify-center h-[38px] px-4 bg-emerald-50 dark:bg-emerald-950/20 text-emerald-600 dark:text-emerald-400 rounded-xl hover:bg-emerald-600 hover:text-white transition-all gap-2 text-xs font-black uppercase tracking-widest border border-emerald-100 dark:border-emerald-900/30 shadow-sm",
              title: "Exportar Excel" do %>
            <i class="fa-solid fa-file-excel"></i>
            <span class="hidden lg:inline">Excel</span>
          <% end %>

          <%= link_to reports_path(format: :pdf, start_date: @start_date, end_date: @end_date, company_id: @company_id), 
              class: "flex-grow flex items-center justify-center h-[38px] px-4 bg-rose-50 dark:bg-rose-950/20 text-rose-600 dark:text-rose-400 rounded-xl hover:bg-rose-600 hover:text-white transition-all gap-2 text-xs font-black uppercase tracking-widest border border-rose-100 dark:border-rose-900/30 shadow-sm",
              title: "Exportar PDF", target: "_blank" do %>
            <i class="fa-solid fa-file-pdf"></i>
            <span class="hidden lg:inline">PDF</span>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
  <% end %>

  <div data-dashboard-filters-target="loading" class="hidden absolute inset-0 z-50 bg-white/60 dark:bg-slate-950/60 backdrop-blur-[2px] items-center justify-center rounded-[2.5rem] transition-all duration-300">
    <div class="flex flex-col items-center">
      <div class="w-16 h-16 border-4 border-indigo-100 dark:border-slate-800 border-t-indigo-600 dark:border-t-indigo-500 rounded-full animate-spin mb-4"></div>
      <p class="text-sm font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest animate-pulse">Actualizando Reportes...</p>
    </div>
  </div>

  <turbo-frame id="reports_content" class="relative block" data-action="turbo:frame-load->dashboard-filters#hideLoading">

    <div data-controller="reports-charts"
         data-reports-charts-properties-value="<%= @properties_data.to_json %>"
         data-reports-charts-trend-value="<%= @monthly_trend.to_json %>"
         class="animate-fade-in">

    <!-- Resumen Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <!-- Total Ingresos -->
      <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-xl shadow-emerald-100/10 dark:shadow-none relative overflow-hidden group">
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-emerald-500/5 rounded-full blur-2xl group-hover:bg-emerald-500/10 transition-colors"></div>
        <div class="relative flex items-center gap-4">
          <div class="w-10 h-10 rounded-xl bg-emerald-600 flex items-center justify-center text-white shadow-lg shrink-0">
            <i class="fa-solid fa-money-bill-trend-up text-sm"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Ingresos Totales</p>
            <h3 class="text-lg font-black text-gray-900 dark:text-white truncate">$<%= number_to_currency(@total_income, unit: "", separator: ",", delimiter: ".") %></h3>
          </div>
        </div>
      </div>

      <!-- Reservas Realizadas -->
      <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-xl shadow-indigo-100/10 dark:shadow-none relative overflow-hidden group">
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-indigo-500/5 rounded-full blur-2xl group-hover:bg-indigo-500/10 transition-colors"></div>
        <div class="relative flex items-center gap-4">
          <div class="w-10 h-10 rounded-xl bg-indigo-600 flex items-center justify-center text-white shadow-lg shrink-0">
            <i class="fa-solid fa-calendar-check text-sm"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Reservas en Rango</p>
            <h3 class="text-lg font-black text-gray-900 dark:text-white truncate"><%= @reservations_count %></h3>
          </div>
        </div>
      </div>

      <!-- Pérdida por Bloqueo -->
      <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-xl shadow-slate-100/10 dark:shadow-none relative overflow-hidden group">
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-slate-500/5 rounded-full blur-2xl group-hover:bg-slate-500/10 transition-colors"></div>
        <div class="relative flex items-center gap-4">
          <div class="w-10 h-10 rounded-xl bg-slate-600 flex items-center justify-center text-white shadow-lg shrink-0">
            <i class="fa-solid fa-lock text-sm"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Pérdida por Bloqueo</p>
            <h3 class="text-lg font-black text-gray-900 dark:text-white truncate">$<%= number_to_currency(@total_loss, unit: "", separator: ",", delimiter: ".") %></h3>
          </div>
        </div>
      </div>

      <!-- Ocupación Promedio -->
      <% avg_occ = @properties_data.map { |p| p[:occupancy_rate] }.sum / [@properties_data.size, 1].max %>
      <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-xl shadow-amber-100/10 dark:shadow-none relative overflow-hidden group">
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-amber-500/5 rounded-full blur-2xl group-hover:bg-amber-500/10 transition-colors"></div>
        <div class="relative flex items-center gap-4">
          <div class="w-10 h-10 rounded-xl bg-amber-500 flex items-center justify-center text-white shadow-lg shrink-0">
            <i class="fa-solid fa-percent text-sm"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Ocupación Promedio</p>
            <h3 class="text-lg font-black text-gray-900 dark:text-white truncate"><%= avg_occ.round(1) %>%</h3>
          </div>
        </div>
      </div>
    </div>

    <% unless params[:format] == 'pdf' %>
      <% if @reservations_count > 0 %>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
          <!-- Gráfico de Ingresos por Propiedad -->
          <div class="bg-white dark:bg-slate-900 p-8 rounded-3xl border border-gray-100 dark:border-slate-800 shadow-sm">
            <h3 class="text-lg font-black text-gray-900 dark:text-white mb-6 flex items-center gap-2">
              <i class="fa-solid fa-chart-simple text-indigo-500"></i> Ingresos por Propiedad
            </h3>
            <div class="h-64">
              <canvas data-reports-charts-target="incomeChart"></canvas>
            </div>
          </div>

          <!-- Gráfico de Ocupación % -->
          <div class="bg-white dark:bg-slate-900 p-8 rounded-3xl border border-gray-100 dark:border-slate-800 shadow-sm">
            <h3 class="text-lg font-black text-gray-900 dark:text-white mb-6 flex items-center gap-2">
              <i class="fa-solid fa-chart-pie text-emerald-500"></i> Tasa de Ocupación (%)
            </h3>
            <div class="h-64">
              <canvas data-reports-charts-target="occupancyChart"></canvas>
            </div>
          </div>
        </div>
<% else %>
      <div class="bg-white dark:bg-slate-900 p-12 rounded-3xl border border-dashed border-gray-200 dark:border-slate-800 mb-8 flex flex-col items-center justify-center text-center">
          <div class="w-16 h-16 rounded-full bg-gray-50 dark:bg-slate-800 flex items-center justify-center text-gray-400 dark:text-slate-500 mb-4">
            <i class="fa-solid fa-chart-area text-2xl"></i>
          </div>
          <h4 class="text-lg font-black text-gray-900 dark:text-white">Sin datos para este periodo</h4>
          <p class="text-gray-500 dark:text-slate-400 text-sm max-w-xs mx-auto mt-2">No se encontraron reservas confirmadas o bloqueos en las fechas seleccionadas para generar los gráficos.</p>
        </div>
      <% end %>
    <% end %>

    <!-- Tabla de Detalle -->
    <div class="<%= params[:format] == 'pdf' ? '' : 'bg-white dark:bg-slate-900 rounded-3xl border border-gray-100 dark:border-slate-800 shadow-sm overflow-hidden' %>">
      <div class="px-8 py-6 border-b border-gray-100 dark:border-slate-800 flex items-center justify-between">
        <h3 class="text-lg font-black text-gray-900 dark:text-white">Desglose por Propiedad</h3>
        <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest"><%= l(@start_date) %> - <%= l(@end_date) %></span>
      </div>
      <div class="overflow-x-auto">
        <table class="<%= params[:format] == 'pdf' ? '' : 'w-full text-left' %>">
          <thead>
            <tr class="bg-gray-50/50 dark:bg-slate-800/50">
              <th class="px-8 py-4 text-[10px] font-black text-gray-400 uppercase tracking-widest">Propiedad</th>
              <th class="px-8 py-4 text-[10px] font-black text-gray-400 uppercase tracking-widest">Ingresos</th>
              <th class="px-8 py-4 text-[10px] font-black text-gray-400 uppercase tracking-widest">Pérdida Bloqueo</th>
              <th class="px-8 py-4 text-[10px] font-black text-gray-400 uppercase tracking-widest text-center">Ocupación</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-slate-800">
            <% @properties_data.each do |data| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-slate-800/30 transition-colors group">
                <td class="px-8 py-5">
                  <div class="flex items-center gap-3">
                    <% unless params[:format] == 'pdf' %>
                      <div class="w-3 h-3 rounded-full" style="background-color: <%= data[:color] %>"></div>
                    <% end %>
                    <span class="font-bold text-gray-900 dark:text-white"><%= data[:name] %></span>
                  </div>
                </td>
                <td class="px-8 py-5 font-black text-emerald-600 dark:text-emerald-400">$<%= number_to_currency(data[:income], unit: "", separator: ",", delimiter: ".") %></td>
                <td class="px-8 py-5 font-bold text-gray-400">$<%= number_to_currency(data[:loss], unit: "", separator: ",", delimiter: ".") %></td>
                <td class="px-8 py-5">
                  <div class="flex items-center gap-3 justify-center">
                    <% unless params[:format] == 'pdf' %>
                      <div class="w-24 h-2 bg-gray-100 dark:bg-slate-800 rounded-full overflow-hidden">
                        <div class="h-full bg-indigo-500 rounded-full" style="width: <%= data[:occupancy_rate] %>%"></div>
                      </div>
                    <% end %>
                    <span class="text-xs font-black text-gray-700 dark:text-slate-300"><%= data[:occupancy_rate] %>%</span>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    </div>
  </turbo-frame>
</div>
