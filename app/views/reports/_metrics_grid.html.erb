<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
  <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-sm relative overflow-hidden group">
    <div class="relative flex items-center gap-4">
      <div class="w-10 h-10 rounded-xl bg-indigo-600 flex items-center justify-center text-white shadow-lg shrink-0">
        <i class="fa-solid fa-calculator text-sm"></i>
      </div>
      <div class="min-w-0">
        <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Ingresos Teóricos</p>
        <h3 class="text-lg font-black text-gray-900 dark:text-white truncate">$<%= number_to_currency(@total_income, unit: "", separator: ",", delimiter: ".") %></h3>
      </div>
    </div>
  </div>
  <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-sm relative overflow-hidden group">
    <div class="relative flex items-center gap-4">
      <div class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 flex items-center justify-center shadow-sm shrink-0">
        <i class="fa-solid fa-calendar-check text-sm"></i>
      </div>
      <div class="min-w-0">
        <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Reservas en Rango</p>
        <h3 class="text-lg font-black text-gray-900 dark:text-white truncate"><%= @reservations_count %></h3>
      </div>
    </div>
  </div>
  <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-sm relative overflow-hidden group">
    <div class="relative flex items-center gap-4">
      <div class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 shadow-sm shrink-0">
        <i class="fa-solid fa-lock text-sm"></i>
      </div>
      <div class="min-w-0">
        <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Pérdida por Bloqueo</p>
        <h3 class="text-lg font-black text-gray-900 dark:text-white truncate">$<%= number_to_currency(@total_loss, unit: "", separator: ",", delimiter: ".") %></h3>
      </div>
    </div>
  </div>
  <% avg_occ = @properties_data.map { |p| p[:occupancy_rate] }.sum / [@properties_data.size, 1].max %>
  <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-sm relative overflow-hidden group">
    <div class="relative flex items-center gap-4">
      <div class="w-10 h-10 rounded-xl bg-amber-500 flex items-center justify-center text-white shadow-lg shrink-0">
        <i class="fa-solid fa-percent text-sm"></i>
      </div>
      <div class="min-w-0">
        <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Ocupación Promedio</p>
        <h3 class="text-lg font-black text-gray-900 dark:text-white truncate"><%= avg_occ.round(1) %>%</h3>
      </div>
    </div>
  </div>
</div>
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
  <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-xl shadow-emerald-100/10 dark:shadow-none relative overflow-hidden group">
    <div class="absolute -top-10 -right-10 w-32 h-32 bg-emerald-500/5 rounded-full blur-2xl"></div>
    <div class="relative flex items-center gap-4">
      <div class="w-10 h-10 rounded-xl bg-emerald-600 flex items-center justify-center text-white shadow-lg shrink-0">
        <i class="fa-solid fa-money-bill-trend-up text-sm"></i>
      </div>
      <div class="min-w-0">
        <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Caja Real (Abonos)</p>
        <h3 class="text-lg font-black text-emerald-600 dark:text-emerald-400 truncate">$<%= number_to_currency(@actual_cash_in, unit: "", separator: ",", delimiter: ".") %></h3>
      </div>
    </div>
  </div>
  <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-xl shadow-rose-100/10 dark:shadow-none relative overflow-hidden group">
    <div class="absolute -top-10 -right-10 w-32 h-32 bg-rose-500/5 rounded-full blur-2xl"></div>
    <div class="relative flex items-center gap-4">
      <div class="w-10 h-10 rounded-xl bg-rose-600 flex items-center justify-center text-white shadow-lg shrink-0">
        <i class="fa-solid fa-file-invoice-dollar text-sm"></i>
      </div>
      <div class="min-w-0">
        <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Gastos Operativos</p>
        <h3 class="text-lg font-black text-rose-600 dark:text-rose-400 truncate">-$<%= number_to_currency(@total_expenses, unit: "", separator: ",", delimiter: ".") %></h3>
      </div>
    </div>
  </div>
  <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-xl shadow-indigo-100/20 dark:shadow-none relative overflow-hidden group border-b-4 border-b-indigo-500">
    <div class="absolute -top-10 -right-10 w-32 h-32 bg-indigo-500/5 rounded-full blur-2xl"></div>
    <div class="relative flex items-center gap-4">
      <div class="w-10 h-10 rounded-xl bg-indigo-900 flex items-center justify-center text-white shadow-lg shrink-0">
        <i class="fa-solid fa-scale-balanced text-sm"></i>
      </div>
      <div class="min-w-0">
        <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Utilidad Neta</p>
        <h3 class="text-lg font-black text-gray-900 dark:text-white truncate">$<%= number_to_currency(@net_profit, unit: "", separator: ",", delimiter: ".") %></h3>
      </div>
    </div>
  </div>
</div>
