<%
  form_structure = [
    { name: :name, label: "Nombre Completo", placeholder: "Ej: Juan Pérez", type: :text_field, icon: "fa-solid fa-user", required: true },
    { name: :rut, label: "RUT", placeholder: "Ej: 12.345.678-9", type: :text_field, icon: "fa-solid fa-id-card", required: true, data: { action: "input->rut#format", rut_target: "input" } },
    { name: :phone, label: "Teléfono / WhatsApp", placeholder: "+56 9 1234 5678", type: :text_field, icon: "fa-solid fa-phone" },
    { name: :email, label: "Correo Electrónico", placeholder: "ejemplo@correo.com", type: :email_field, icon: "fa-solid fa-envelope" }
  ]

  input_class = "block w-full rounded-xl border-gray-300 dark:border-slate-700 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-3 border bg-gray-50 dark:bg-slate-800 focus:bg-white dark:focus:bg-slate-900 transition-colors dark:text-white"
  label_class = "block text-sm font-bold text-gray-700 dark:text-slate-300 mb-1"
%>

<%= form_with(model: client, class: "space-y-6", data: { controller: "rut" }) do |f| %>
  <% if client.errors.any? %>
    <div class="p-6 bg-rose-50 dark:bg-rose-950/20 border border-rose-100 dark:border-rose-900 rounded-2xl animate-shake">
      <h2 class="text-rose-800 dark:text-rose-400 text-sm font-black uppercase tracking-widest mb-3 flex items-center gap-2">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <%= client.errors.count == 1 ? "1 error impide" : "#{client.errors.count} errores impiden" %> guardar este cliente:
      </h2>
      <ul class="space-y-1">
        <% client.errors.full_messages.each do |message| %>
          <li class="text-rose-600 dark:text-rose-500 text-xs font-bold"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% form_structure.each do |field| %>
      <div class="space-y-2">
        <%= f.label field[:name], class: label_class do %>
          <i class="<%= field[:icon] %> text-gray-400 dark:text-slate-500 mr-1"></i> <%= field[:label] %>
        <% end %>
        <%= f.send(field[:type], field[:name], 
            placeholder: field[:placeholder], 
            class: input_class, 
            required: field[:required],
            data: field[:data]) %>
      </div>
    <% end %>
  </div>

  <div class="pt-6 border-t border-gray-100 dark:border-slate-800 flex flex-col sm:flex-row items-center justify-start gap-8">
    <%= render "shared/back_button", path: clients_path, form: true %>

    <%= f.button type: "submit", class: "w-full sm:w-auto sm:min-w-[200px] flex justify-center items-center py-3.5 px-6 border border-transparent rounded-xl shadow-lg text-base font-bold text-white bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer transform hover:-translate-y-1 transition-all duration-300" do %>
      <i class="fa-solid fa-floppy-disk mr-2"></i> <%= client.new_record? ? "Guardar Cliente" : "Actualizar Cliente" %>
    <% end %>
  </div>
<% end %>
