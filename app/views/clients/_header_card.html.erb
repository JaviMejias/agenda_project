<div class="relative p-6 sm:p-10 bg-gradient-to-br from-white to-indigo-50 dark:from-slate-900 dark:to-slate-950 border-b border-indigo-100 dark:border-slate-800 overflow-hidden">
  <div class="absolute -top-24 -right-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div class="flex items-center gap-4">
      <div class="w-16 h-16 rounded-2xl bg-white dark:bg-slate-800 border border-indigo-100 dark:border-slate-700 shadow-sm flex items-center justify-center text-indigo-600 dark:text-indigo-400 text-3xl">
        <i class="fa-solid fa-user"></i>
      </div>
      <div class="flex-1">
        <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 mb-2 sm:mb-1">
          <h3 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight leading-tight"><%= client.name %></h3>
          <% if client.tag.present? && client.tag != "unassigned" %>
            <div class="inline-flex">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 text-[10px] font-black uppercase tracking-widest rounded-full border <%= client_tag_classes(client.tag) %>">
                <i class="fa-solid <%= client_tag_icon(client.tag) %>"></i> <%= I18n.t("enums.client.tag.#{client.tag}") %>
              </span>
            </div>
          <% end %>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-2 text-indigo-600 dark:text-indigo-400 text-[10px] font-bold uppercase tracking-widest opacity-80">
          <span>RUT: <%= client.formatted_rut %></span>
          <span class="hidden sm:inline">•</span>
          <span>Cliente desde <%= client.created_at.strftime("%B %Y") %></span>
        </div>
      </div>
    </div>
    <div class="flex items-center gap-4 bg-white/50 dark:bg-slate-800/50 backdrop-blur-md p-4 rounded-2xl border border-indigo-100 dark:border-slate-700 shadow-sm">
      <div class="text-left sm:text-right">
        <dt class="text-[9px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest mb-1">Reservas</dt>
        <dd class="text-xl font-black text-gray-900 dark:text-white"><%= client.reservations_count %></dd>
      </div>
      <div class="w-px h-10 bg-indigo-100 dark:bg-slate-700"></div>
      <div class="text-left sm:text-right">
        <dt class="text-[9px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest mb-1">Inversión</dt>
        <dd class="text-xl font-black text-gray-900 dark:text-white">$<%= number_with_delimiter(client.total_spent, delimiter: ".") %></dd>
      </div>
    </div>
  </div>
</div>
