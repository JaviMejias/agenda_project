<% content_for :title, @client.name %>

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in">
  
  <%= render "shared/back_button", path: clients_path %>

  <div class="bg-white dark:bg-slate-900 shadow-2xl overflow-hidden rounded-[2.5rem] border border-gray-100 dark:border-slate-800 animate-fade-in-up">
    <!-- Light Header Style -->
    <div class="relative p-6 sm:p-10 bg-gradient-to-br from-white to-indigo-50 dark:from-slate-900 dark:to-slate-950 border-b border-indigo-100 dark:border-slate-800 overflow-hidden">
      <div class="absolute -top-24 -right-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 rounded-2xl bg-white dark:bg-slate-800 border border-indigo-100 dark:border-slate-700 shadow-sm flex items-center justify-center text-indigo-600 dark:text-indigo-400 text-3xl">
            <i class="fa-solid fa-user"></i>
          </div>
          <div>
            <h3 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight leading-tight"><%= @client.name %></h3>
            <p class="text-indigo-600 dark:text-indigo-400 text-[10px] font-bold uppercase tracking-widest opacity-80">
              RUT: <%= @client.rut %> • Cliente desde <%= @client.created_at.strftime("%B %Y") %>
            </p>
          </div>
        </div>

        <div class="flex items-center gap-4 bg-white/50 dark:bg-slate-800/50 backdrop-blur-md p-4 rounded-2xl border border-indigo-100 dark:border-slate-700 shadow-sm">
          <div class="text-left sm:text-right">
            <dt class="text-[9px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest mb-1">Reservas</dt>
            <dd class="text-xl font-black text-gray-900 dark:text-white"><%= @client.reservations.count %></dd>
          </div>
          <div class="w-px h-10 bg-indigo-100 dark:bg-slate-700"></div>
          <div class="text-left sm:text-right">
            <dt class="text-[9px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest mb-1">Inversión</dt>
            <dd class="text-xl font-black text-gray-900 dark:text-white">$<%= number_with_delimiter(@client.reservations.sum(:total_price).to_i, delimiter: ".") %></dd>
          </div>
        </div>
      </div>
    </div>
    
    <div class="px-6 py-10 sm:px-10 grid grid-cols-1 lg:grid-cols-3 gap-10">
      <!-- Columna de Contacto -->
      <div class="lg:col-span-1">
        <h4 class="text-sm font-black text-gray-900 dark:text-white uppercase tracking-widest mb-6 flex items-center gap-2">
          <i class="fa-solid fa-address-book text-indigo-600 dark:text-indigo-400"></i> Información de Contacto
        </h4>
        <div class="space-y-4">
          <div class="bg-gray-50/50 dark:bg-slate-800/50 p-5 rounded-2xl border border-gray-100 dark:border-slate-800 group hover:bg-white dark:hover:bg-slate-800 hover:border-indigo-100 dark:hover:border-indigo-900 hover:shadow-lg transition-all duration-300">
            <p class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-1">Teléfono</p>
            <p class="text-sm font-bold text-gray-900 dark:text-slate-100 flex items-center gap-2">
              <i class="fa-solid fa-phone text-emerald-500"></i>
              <%= @client.phone.present? ? @client.phone : "No registrado" %>
            </p>
          </div>
          <div class="bg-gray-50/50 dark:bg-slate-800/50 p-5 rounded-2xl border border-gray-100 dark:border-slate-800 group hover:bg-white dark:hover:bg-slate-800 hover:border-indigo-100 dark:hover:border-indigo-900 hover:shadow-lg transition-all duration-300">
            <p class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-1">Email</p>
            <p class="text-sm font-bold text-gray-900 dark:text-slate-100 flex items-center gap-2">
              <i class="fa-solid fa-envelope text-rose-500"></i>
              <%= @client.email.present? ? @client.email : "Sin correo" %>
            </p>
          </div>
        </div>
      </div>

      <!-- Historial de Reservas -->
      <div class="lg:col-span-2">
        <h4 class="text-sm font-black text-gray-900 dark:text-white uppercase tracking-widest mb-6 flex items-center gap-2">
          <i class="fa-solid fa-history text-indigo-600 dark:text-indigo-400"></i> Historial de Reservas
        </h4>

        <%= turbo_frame_tag "client_reservations_history" do %>
          <% if @reservations.any? %>
            <div class="space-y-3">
              <% @reservations.each do |res| %>
                <div class="flex items-center justify-between p-4 rounded-xl bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700 group hover:border-indigo-200 dark:hover:border-indigo-900 hover:shadow-md transition-all duration-300">
                  <div class="flex items-center gap-4">
                    <div class="w-1.5 h-8 rounded-full" style="background-color: <%= res.property.color %>"></div>
                    <div>
                      <p class="text-sm font-black text-gray-900 dark:text-slate-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors"><%= res.property.name %></p>
                      <p class="text-[10px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest">
                        <%= res.start_time.strftime("%d %b, %Y") %>
                      </p>
                    </div>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-black text-gray-900 dark:text-white">$<%= number_with_delimiter(res.total_price.to_i, delimiter: ".") %></p>
                    <span class="text-[9px] font-black uppercase tracking-widest <%= res.status_color_classes.split(' ')[1] %>">
                      <%= res.status_text %>
                    </span>
                  </div>
                </div>
              <% end %>
            </div>
            <%= render "shared/pagination" %>
          <% else %>
            <div class="py-12 bg-gray-50/50 dark:bg-slate-800/50 rounded-2xl border border-dashed border-gray-200 dark:border-slate-800 text-center">
              <p class="text-sm text-gray-500 dark:text-slate-400 font-medium">No registra reservas.</p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
