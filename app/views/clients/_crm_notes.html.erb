<% if client.private_notes.present? %>
  <div class="lg:col-span-3 mb-2">
    <h4 class="text-sm font-black text-gray-900 dark:text-white uppercase tracking-widest mb-6 flex items-center gap-2">
      <i class="fa-solid fa-lock text-indigo-600 dark:text-indigo-400"></i> Notas Privadas de CRM
    </h4>
    <div class="p-6 sm:p-8 bg-amber-50/50 dark:bg-amber-950/20 border border-amber-100 dark:border-amber-900/50 rounded-[2rem] shadow-sm relative overflow-hidden">
      <div class="absolute -top-12 -right-12 text-9xl text-amber-500/5 dark:text-amber-500/5 pointer-events-none">
        <i class="fa-solid fa-clipboard-list"></i>
      </div>
      <div class="relative z-10 prose prose-sm dark:prose-invert max-w-none prose-amber prose-p:leading-relaxed prose-p:font-medium text-gray-700 dark:text-slate-300">
        <%= simple_format(client.private_notes) %>
      </div>
    </div>
  </div>
<% end %>
