<% content_for :title, "Gastos - #{@property.name}" %>

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in">
  <%= render "shared/back_button", path: properties_path %>
  
  
  <%= render "shared/index_header", 
      title: "Gastos Operativos", 
      icon: "fa-solid fa-file-invoice-dollar", 
      subtitle: @property.name do %>
    
    <div class="flex flex-col sm:flex-row items-center gap-4">
      <!-- Toggle de Vistas -->
      <div class="bg-white/50 dark:bg-slate-800/50 backdrop-blur-md p-1 rounded-xl border border-indigo-100 dark:border-slate-700 inline-flex shadow-sm">
        <%= link_to property_path(@property), class: "px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all duration-300 text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400" do %>Agenda<% end %>
        <span class="px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all duration-300 tab-active">Gastos</span>
      </div>

      <!-- Botón de Acción -->
      <%= link_to new_property_expense_path(@property), class: "w-full sm:w-auto group flex items-center justify-center gap-3 px-6 py-3.5 bg-white dark:bg-indigo-600 text-indigo-600 dark:text-white rounded-2xl border border-indigo-100 dark:border-transparent hover:bg-indigo-50 dark:hover:bg-indigo-500 transition-all shadow-md shadow-indigo-100/50 dark:shadow-none hover:-translate-y-1 active:scale-95" do %>
        <i class="fa-solid fa-plus-circle text-indigo-500 dark:text-indigo-200 group-hover:rotate-90 transition-transform duration-500"></i>
        <span class="text-[10px] font-black uppercase tracking-widest">Registrar Gasto</span>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white dark:bg-slate-900 shadow-2xl overflow-hidden rounded-[2.5rem] border border-gray-100 dark:border-slate-800 mt-8">
    <div class="px-6 py-8 sm:px-10 border-b border-gray-100 dark:border-slate-800 flex justify-between items-center">
      <div>
        <h4 class="text-xl font-black text-gray-900 dark:text-white">Libro de Gastos</h4>
        <p class="text-gray-500 text-sm mt-1">Control detallado de costos operativos.</p>
      </div>
      <div class="text-right">
        <p class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-1">Inversión Total</p>
        <p class="text-3xl font-black text-rose-500">
          $<%= number_with_delimiter(@property.expenses.sum(:amount).to_i, delimiter: ".") %>
        </p>
      </div>
    </div>

    <div class="px-6 py-10 sm:px-10">
      <% if @expenses.any? %>
        <div class="hidden md:block overflow-x-auto rounded-2xl border border-gray-100 dark:border-slate-800 shadow-sm mb-6">
          <table class="min-w-full divide-y divide-gray-100 dark:divide-slate-800">
            <thead class="bg-gray-50/50 dark:bg-slate-800/50">
              <tr>
                <th scope="col" class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">Fecha</th>
                <th scope="col" class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">Categoría</th>
                <th scope="col" class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">Descripción</th>
                <th scope="col" class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">Monto</th>
                <th scope="col" class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">Adjuntos</th>
                <th scope="col" class="px-6 py-4 text-right text-[10px] font-black text-gray-400 uppercase tracking-widest">Acciones</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-slate-900 divide-y divide-gray-100 dark:divide-slate-800">
              <% @expenses.each do |expense| %>
                <tr class="hover:bg-gray-50/50 dark:hover:bg-slate-800/30 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900 dark:text-slate-300">
                    <%= expense.expense_date.strftime("%d/%m/%Y") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <span class="px-2 py-1 bg-gray-100 dark:bg-slate-800 text-gray-600 dark:text-slate-400 rounded-md text-[9px] font-black uppercase tracking-widest">
                      <%= Expense.translated_categories[expense.category] %>
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-500 dark:text-slate-400 max-w-xs truncate">
                    <%= expense.description %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-black text-rose-600 dark:text-rose-400">
                    $<%= number_with_delimiter(expense.amount.to_i, delimiter: ".") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% if expense.vouchers.attached? %>
                      <div class="flex -space-x-2">
                        <% expense.vouchers.to_a.take(3).each do |voucher| %>
                          <%= link_to rails_blob_path(voucher, disposition: "inline"), target: "_blank", class: "w-8 h-8 rounded-full border-2 border-white dark:border-slate-900 bg-gray-100 dark:bg-slate-800 overflow-hidden shadow-sm hover:scale-110 hover:z-10 transition-transform", title: "Ver #{voucher.filename}" do %>
                            <% if voucher.image? %>
                              <%= image_tag voucher.variant(resize_to_limit: [50, 50]), class: "w-full h-full object-cover" %>
                            <% else %>
                              <div class="w-full h-full flex items-center justify-center text-[8px] text-rose-500">
                                <i class="fa-solid fa-file-pdf"></i>
                              </div>
                            <% end %>
                          <% end %>
                        <% end %>
                        <% if expense.vouchers.to_a.size > 3 %>
                          <div class="w-8 h-8 rounded-full border-2 border-white dark:border-slate-900 bg-gray-200 dark:bg-slate-700 flex items-center justify-center text-[9px] font-black text-gray-600 dark:text-slate-400 shadow-sm">
                            +<%= expense.vouchers.to_a.size - 3 %>
                          </div>
                        <% end %>
                      </div>
                    <% else %>
                      <span class="text-[9px] font-bold text-gray-300 dark:text-slate-600 uppercase tracking-tighter">Sin archivos</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <div class="flex justify-end gap-2">
                      <%= link_to edit_property_expense_path(@property, expense), class: "w-8 h-8 rounded-lg bg-gray-50 dark:bg-slate-800 flex items-center justify-center text-gray-400 hover:text-indigo-600 transition-all shadow-sm" do %>
                        <i class="fa-solid fa-pen text-[10px]"></i>
                      <% end %>
                      <%= button_to property_expense_path(@property, expense), method: :delete, data: { turbo_confirm: "¿Eliminar gasto?" }, class: "w-8 h-8 rounded-lg bg-gray-50 dark:bg-slate-800 flex items-center justify-center text-gray-400 hover:text-rose-600 transition-all shadow-sm" do %>
                        <i class="fa-solid fa-trash-can text-[10px]"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- Vista de Móvil (Tarjetas) -->
        <div class="space-y-4 md:hidden mb-6">
          <% @expenses.each do |expense| %>
            <div class="flex flex-col sm:flex-row sm:items-center justify-between p-4 sm:p-5 rounded-2xl bg-gray-50 dark:bg-slate-800 border border-gray-100 dark:border-slate-700 gap-4 transition-all hover:shadow-md">
              <div class="flex flex-row items-start sm:items-center gap-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 bg-rose-50 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400 shadow-sm border border-rose-100 dark:border-rose-900/50">
                  <i class="fa-solid fa-file-invoice-dollar text-lg"></i>
                </div>
                <div>
                  <div class="flex flex-wrap items-center gap-2 mb-1">
                    <span class="px-2 py-0.5 text-[9px] font-bold uppercase tracking-widest rounded-full bg-white dark:bg-slate-700 text-gray-500 dark:text-slate-300 border border-gray-200 dark:border-slate-600 shadow-sm">
                      <%= Expense.translated_categories[expense.category] %>
                    </span>
                  </div>
                  <p class="text-[10px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest">
                    <%= expense.expense_date.strftime("%d %b, %Y") %>
                  </p>
                  <% if expense.description.present? %>
                    <p class="text-xs text-gray-500 dark:text-slate-400 mt-2 italic line-clamp-2">
                      <i class="fa-solid fa-comment-dots mr-1 opacity-50"></i> <%= expense.description %>
                    </p>
                  <% end %>
                  
                  <% if expense.vouchers.attached? %>
                    <div class="flex -space-x-2 mt-3">
                      <% expense.vouchers.to_a.take(3).each do |voucher| %>
                        <%= link_to rails_blob_path(voucher, disposition: "inline"), target: "_blank", class: "w-6 h-6 rounded-full border border-white dark:border-slate-900 bg-gray-100 dark:bg-slate-800 overflow-hidden shadow-sm hover:scale-110 hover:z-10 transition-transform", title: "Ver #{voucher.filename}" do %>
                          <% if voucher.image? %>
                            <%= image_tag voucher.variant(resize_to_limit: [50, 50]), class: "w-full h-full object-cover" %>
                          <% else %>
                            <div class="w-full h-full flex items-center justify-center text-[6px] text-rose-500">
                              <i class="fa-solid fa-file-pdf"></i>
                            </div>
                          <% end %>
                        <% end %>
                      <% end %>
                      <% if expense.vouchers.to_a.size > 3 %>
                        <div class="w-6 h-6 rounded-full border border-white dark:border-slate-900 bg-gray-200 dark:bg-slate-700 flex items-center justify-center text-[7px] font-black text-gray-600 dark:text-slate-400 shadow-sm">
                          +<%= expense.vouchers.to_a.size - 3 %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>

              <div class="flex flex-row sm:flex-col items-center sm:items-end justify-between sm:justify-center gap-3 sm:gap-2 pt-4 sm:pt-0 border-t border-gray-200 dark:border-slate-700 sm:border-t-0 mt-2 sm:mt-0">
                <div class="text-xl font-black text-rose-600 dark:text-rose-400">
                  $<%= number_with_delimiter(expense.amount.to_i, delimiter: ".") %>
                </div>
                <div class="flex justify-end gap-2">
                  <%= link_to edit_property_expense_path(@property, expense), class: "flex items-center justify-center w-8 h-8 rounded-lg bg-white dark:bg-slate-700 text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 border border-gray-200 dark:border-slate-600 hover:border-indigo-200 transition-colors shadow-sm", title: "Editar" do %>
                    <i class="fa-solid fa-pen text-xs"></i>
                  <% end %>
                  <%= button_to property_expense_path(@property, expense), method: :delete, data: { turbo_confirm: "¿Eliminar gasto?" }, class: "flex items-center justify-center w-8 h-8 rounded-lg bg-white dark:bg-slate-700 text-gray-400 hover:text-rose-600 dark:hover:text-rose-400 border border-gray-200 dark:border-slate-600 hover:border-rose-200 transition-colors shadow-sm", title: "Eliminar" do %>
                    <i class="fa-solid fa-trash-can text-xs"></i>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <%= render "shared/pagination" %>
      <% else %>
        <div class="py-12">
          <%= render "shared/empty_state", 
              icon: "fa-solid fa-receipt", 
              title: "Sin Gastos Registrados", 
              subtitle: "No hay gastos operativos registrados para esta propiedad aún." %>
        </div>
      <% end %>
    </div>
  </div>
</div>
