<% content_for :title, @property.name %>

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in"
     data-controller="fullcalendar"
     data-fullcalendar-mode-value="booking"
     data-fullcalendar-per-hour-value="<%= @property.per_hour? %>"
     data-fullcalendar-base-price-value="<%= @property.base_price %>"
     data-fullcalendar-events-url-value="<%= reservations_path(property_id: @property.id, format: :json) %>">
  
  <div class="mb-6">
    <%= link_to properties_path, class: "group inline-flex items-center text-sm font-bold text-gray-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" do %>
      <div class="w-8 h-8 rounded-full bg-white dark:bg-slate-800 shadow-sm border border-gray-200 dark:border-slate-700 flex items-center justify-center mr-3 group-hover:bg-indigo-50 dark:group-hover:bg-indigo-900/50 group-hover:border-indigo-200 transition-all group-hover:-translate-x-1">
        <i class="fa-solid fa-arrow-left text-[10px]"></i>
      </div>
      Volver al listado
    <% end %>
  </div>

  <div class="bg-white dark:bg-slate-900 shadow-xl overflow-hidden rounded-[2.5rem] border border-gray-100 dark:border-slate-800 mb-8 animate-fade-in-up">
    <!-- Light Header Style -->
    <div class="relative p-6 sm:p-10 bg-gradient-to-br from-white to-indigo-50 dark:from-slate-900 dark:to-slate-950 border-b border-indigo-100 dark:border-slate-800 overflow-hidden">
      <div class="absolute -top-24 -right-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-4">
          <div class="w-16 h-16 rounded-2xl bg-white dark:bg-slate-800 border border-indigo-100 dark:border-slate-700 shadow-sm flex items-center justify-center text-indigo-600 dark:text-indigo-400 text-3xl">
            <i class="fa-solid fa-house-chimney"></i>
          </div>
          <div>
            <div class="flex items-center gap-3 mb-1">
              <div class="w-4 h-4 rounded-full shadow-inner border border-indigo-100 dark:border-indigo-900" style="background-color: <%= @property.color || '#4f46e5' %>;"></div>
              <h3 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight leading-tight"><%= @property.name %></h3>
            </div>
            <div class="flex flex-wrap items-center gap-4 mt-2">
              <p class="text-indigo-600 dark:text-indigo-400 text-[10px] font-bold uppercase tracking-widest opacity-80 flex items-center gap-1.5">
                <i class="fa-solid fa-align-left text-[8px]"></i> <%= @property.description %>
              </p>
              <% if @property.address.present? %>
                <p class="text-gray-500 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest flex items-center gap-1.5">
                  <i class="fa-solid fa-location-dot text-[8px]"></i> <%= @property.address %>
                </p>
              <% end %>
              <% if @property.company.present? %>
                <p class="text-indigo-500 dark:text-indigo-300 text-[10px] font-bold uppercase tracking-widest flex items-center gap-1.5">
                  <i class="fa-solid fa-building text-[8px]"></i> <%= @property.company.name %>
                </p>
              <% end %>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row items-center gap-3 relative z-10">
          <% if current_user.admin? %>
            <%= link_to edit_property_path(@property), class: "w-full sm:w-auto group flex items-center justify-center gap-2 px-5 py-3 bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-300 rounded-xl border border-gray-200 dark:border-slate-700 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all shadow-sm" do %>
              <i class="fa-solid fa-pen-to-square text-sm"></i>
              <span class="text-[10px] font-black uppercase tracking-widest">Editar</span>
            <% end %>

            <%= button_to property_path(@property), method: :delete, data: { turbo_confirm: "¿Estás seguro de eliminar esta propiedad?" }, class: "w-full sm:w-auto group flex items-center justify-center gap-2 px-5 py-3 bg-white dark:bg-slate-800 text-red-600 dark:text-red-400 rounded-xl border border-red-100 dark:border-red-900/30 hover:bg-red-50 dark:hover:bg-red-950/30 transition-all shadow-sm" do %>
              <i class="fa-solid fa-trash-can text-sm"></i>
              <span class="text-[10px] font-black uppercase tracking-widest">Eliminar Propiedad</span>
            <% end %>
          <% end %>

          <div class="flex items-center gap-6 bg-white/50 dark:bg-slate-800/50 backdrop-blur-md p-4 rounded-2xl border border-indigo-100 dark:border-slate-700 shadow-sm">
          <div class="text-left sm:text-right">
            <dt class="text-[9px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest mb-1"><i class="fa-solid fa-file-invoice-dollar mr-1"></i> Modelo</dt>
            <dd class="text-sm font-black text-gray-900 dark:text-white"><%= @property.per_day? ? "Por Día" : "Por Hora" %></dd>
          </div>
          <div class="hidden sm:block w-px h-10 bg-indigo-100 dark:bg-slate-700"></div>
          <div class="text-left sm:text-right">
            <dt class="text-[9px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest mb-1"><i class="fa-solid fa-tag mr-1"></i> Precio</dt>
            <dd class="text-sm font-black text-gray-900 dark:text-white">$<%= number_with_delimiter(@property.base_price.to_i, delimiter: ".") %></dd>
          </div>
        </div>
      </div>
    </div>
    
    <div class="p-6 sm:p-10">
      <div class="flex flex-col lg:flex-row gap-8">
        <div class="lg:w-7/12">
           <%= render "shared/calendar_container", property: @property, omit_controller: true, omit_inputs: true %>
        </div>
        <div class="lg:w-5/12">
           <div class="sticky top-6">
                <%= render "reservations/booking_form", property: @property, reservation: @reservation || @property.reservations.build %>
           </div>
        </div>
      </div>
    </div>
  </div>
</div>
