<turbo-frame id="<%= dom_id property %>">
  <p>
    <strong>Name:</strong>
    <%= property.name %>
  </p>
  <p>
    <strong>Description:</strong>
    <%= property.description %>
  </p>
  <p>
    <strong>Price per day:</strong>
    <%= property.base_price %>
  </p>
  <p>
    <strong>User:</strong>
    <%= property.user_id %>
  </p>
</turbo-frame>
