<div class="p-5 bg-white dark:bg-slate-900 border border-gray-100 dark:border-slate-800 rounded-2xl shadow-sm relative group overflow-hidden">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-grow">
      <div class="flex items-center gap-2 mb-2">
        <span class="inline-flex items-center px-2 py-0.5 text-[8px] font-black uppercase tracking-widest rounded-md border <%= incident_severity_classes(incident.severity) %>">
          <%= incident_severity_label(incident.severity) %>
        </span>
        <span class="inline-flex items-center px-2 py-0.5 text-[8px] font-black uppercase tracking-widest rounded-md border <%= incident_status_classes(incident.status) %>">
          <%= incident_status_label(incident.status) %>
        </span>
      </div>
      <h4 class="text-base font-black text-gray-900 dark:text-white leading-tight mb-1"><%= incident.title %></h4>
      <p class="text-xs text-gray-500 dark:text-slate-400 leading-relaxed mb-3"><%= incident.description %></p>
      <div class="flex items-center justify-between mt-4">
        <div class="text-[9px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest">
          Reportado el <%= incident.created_at.strftime("%d %b, %Y") %>
        </div>
        <div class="flex items-center gap-2">
          <% if incident.photo.attached? %>
            <%= link_to rails_blob_path(incident.photo, disposition: "attachment"), target: "_blank", class: "w-8 h-8 rounded-lg bg-gray-50 dark:bg-slate-800 flex items-center justify-center text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 dark:hover:bg-indigo-900/50 transition-all", title: "Ver foto adjunta" do %>
              <i class="fa-solid fa-image"></i>
            <% end %>
          <% end %>
          <% unless incident.resolved? %>
            <%= form_with(model: [incident.property, incident], class: "inline-block") do |f| %>
              <%= f.hidden_field :status, value: incident_next_status_value(incident) %>
              <button type="submit" class="<%= incident_next_status_classes(incident) %>">
                <%= incident_next_status_label(incident) %>
              </button>
            <% end %>
          <% end %>
          <%= button_to property_incident_path(incident.property, incident), method: :delete, data: { turbo_confirm: "¿Eliminar esta incidencia?" }, class: "w-8 h-8 rounded-lg bg-gray-50 dark:bg-slate-800 flex items-center justify-center text-rose-400 hover:text-white hover:bg-rose-500 transition-all" do %>
            <i class="fa-solid fa-trash-can text-[10px]"></i>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
