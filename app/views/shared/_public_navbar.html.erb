<nav data-controller="mobile-menu" class="fixed top-0 inset-x-0 z-50 transition-colors duration-300">
  <div class="absolute inset-0 bg-white/80 dark:bg-slate-950/80 backdrop-blur-md border-b border-gray-100/80 dark:border-slate-800 shadow-sm -z-10"></div>
  <div class="mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 justify-between items-center">
      <div class="flex items-center gap-8">
        <%= link_to (user_signed_in? && current_user.client? ? public_property_index_path : root_path), class: "flex items-center gap-3 group" do %>
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white shadow-md shadow-indigo-500/20 group-hover:scale-105 transition-transform">
            <i class="fa-solid fa-calendar-check text-xl animate-pulse"></i>
          </div>
          <span class="text-xl font-black bg-clip-text text-transparent bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-slate-300">Agenda Pro</span>
        <% end %>
        <div class="hidden lg:flex lg:items-center lg:space-x-2">
          <%= link_to public_property_index_path, class: "group relative inline-flex items-center rounded-xl px-4 py-2 text-sm font-bold transition-all duration-300 #{current_page?(public_property_index_path) || current_page?(root_path) ? 'text-indigo-600 bg-indigo-50/50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
            <i class="fa-solid fa-house-chimney mr-2.5 transition-colors <%= current_page?(public_property_index_path) || current_page?(root_path) ? 'text-indigo-500' : 'text-gray-400 group-hover:text-indigo-500' %>"></i>
            <span>Explorar Espacios</span>
          <% end %>
          <%= link_to search_public_reservations_path, class: "group relative inline-flex items-center rounded-xl px-4 py-2 text-sm font-bold transition-all duration-300 #{current_page?(search_public_reservations_path) ? 'text-indigo-600 bg-indigo-50/50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
            <i class="fa-solid fa-magnifying-glass mr-2.5 transition-colors <%= current_page?(search_public_reservations_path) ? 'text-indigo-500' : 'text-gray-400 group-hover:text-indigo-500' %>"></i>
            <span>Buscar Reserva</span>
          <% end %>
          <% if user_signed_in? %>
            <% if current_user.client? %>
              <%= link_to my_reservations_path, class: "group relative inline-flex items-center rounded-xl px-4 py-2 text-sm font-bold transition-all duration-300 #{current_page?(my_reservations_path) ? 'text-indigo-600 bg-indigo-50/50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
                <i class="fa-solid fa-calendar-days mr-2.5 transition-colors <%= current_page?(my_reservations_path) ? 'text-indigo-500' : 'text-gray-400 group-hover:text-indigo-500' %>"></i>
                <span>Mis Reservas</span>
              <% end %>
            <% else %>
              <%= link_to dashboard_path, class: "group relative inline-flex items-center rounded-xl px-4 py-2 text-sm font-bold transition-all duration-300 #{current_page?(dashboard_path) ? 'text-indigo-600 bg-indigo-50/50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
                <i class="fa-solid fa-gauge-high mr-2.5 transition-colors <%= current_page?(dashboard_path) ? 'text-indigo-500' : 'text-gray-400 group-hover:text-indigo-500' %>"></i>
                <span>Mi Panel</span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <% if user_signed_in? %>
          <div class="hidden lg:block relative" data-controller="dropdown" data-action="click@window->dropdown#hide">
            <button data-action="click->dropdown#toggle" data-dropdown-target="button" class="flex items-center gap-3 group hover:opacity-80 transition-opacity focus:outline-none">
              <div class="flex flex-col items-end">
                <span class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none">Usuario</span>
                <span class="text-xs font-bold text-gray-700 dark:text-slate-200 truncate max-w-[150px]"><%= current_user.email.split('@').first %></span>
              </div>
              <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-600 text-white font-black text-sm shadow-lg shadow-indigo-100/30 dark:shadow-none ring-2 ring-white dark:ring-slate-800">
                <%= current_user.email[0].upcase %>
              </div>
            </button>
            
            <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-64 origin-top-right rounded-2xl bg-white dark:bg-slate-800 shadow-2xl shadow-indigo-100/50 dark:shadow-none ring-1 ring-black ring-opacity-5 focus:outline-none overflow-hidden z-50 border border-gray-100 dark:border-slate-700 transition-all duration-200 ease-out opacity-0 scale-95">
              <div class="px-5 py-4 border-b border-gray-50 dark:border-slate-700/50 bg-gray-50/30 dark:bg-slate-800/30">
                <p class="text-xs font-black text-gray-900 dark:text-white truncate"><%= current_user.email %></p>
                <p class="text-[10px] font-bold text-gray-400 dark:text-slate-500 mt-0.5"><%= current_user.admin? ? 'Administrador' : (current_user.normal? ? 'Empleado' : 'Cliente') %></p>
              </div>
              <div class="p-3">
                <div class="px-2 mb-2">
                  <span class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest">Tema Visual</span>
                </div>
                <div data-controller="theme" class="flex items-center gap-1 bg-gray-100/80 dark:bg-slate-900/60 p-1.5 rounded-xl border border-gray-200/50 dark:border-slate-700/50 shadow-inner">
                  <button data-action="click->theme#setTheme click->dropdown#stop" data-theme-value="light" title="Modo Claro" class="flex-1 flex flex-col items-center gap-1.5 py-2.5 rounded-lg transition-all hover:bg-white dark:hover:bg-slate-800 text-gray-500 dark:text-slate-400 group">
                    <i class="fa-solid fa-sun text-sm group-hover:scale-110 transition-transform"></i>
                    <span class="text-[9px] font-bold">Claro</span>
                  </button>
                  <button data-action="click->theme#setTheme click->dropdown#stop" data-theme-value="system" title="Seguir Sistema" class="flex-1 flex flex-col items-center gap-1.5 py-2.5 rounded-lg transition-all hover:bg-white dark:hover:bg-slate-800 text-gray-500 dark:text-slate-400 group">
                    <i class="fa-solid fa-desktop text-sm group-hover:scale-110 transition-transform"></i>
                    <span class="text-[9px] font-bold">Auto</span>
                  </button>
                  <button data-action="click->theme#setTheme click->dropdown#stop" data-theme-value="dark" title="Modo Oscuro" class="flex-1 flex flex-col items-center gap-1.5 py-2.5 rounded-lg transition-all hover:bg-white dark:hover:bg-slate-800 text-gray-500 dark:text-slate-400 group">
                    <i class="fa-solid fa-moon text-sm group-hover:scale-110 transition-transform"></i>
                    <span class="text-[9px] font-bold">Oscuro</span>
                  </button>
                </div>
              </div>
              <div class="border-t border-gray-50 dark:border-slate-700/50">
                <%= link_to destroy_user_session_path, data: { turbo: false }, class: "group flex items-center px-5 py-4 text-sm font-bold text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-all" do %>
                  <div class="w-8 h-8 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center mr-3 group-hover:bg-red-200 dark:group-hover:bg-red-900/50 transition-colors">
                    <i class="fa-solid fa-power-off text-red-500 dark:text-red-400 group-hover:rotate-90 transition-transform"></i>
                  </div>
                  Cerrar Sesión
                <% end %>
              </div>
            </div>
          </div>
        <% else %>
          <div data-controller="theme" class="hidden lg:flex items-center bg-gray-100 dark:bg-slate-800/50 p-1 rounded-xl border border-gray-200/50 dark:border-slate-700/50 mr-4">
            <button data-action="click->theme#setTheme" data-theme-value="light" title="Modo Claro" class="w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-200 hover:text-indigo-600 dark:hover:text-indigo-400 text-gray-500 dark:text-slate-400">
              <i class="fa-solid fa-sun text-xs"></i>
            </button>
            <button data-action="click->theme#setTheme" data-theme-value="system" title="Seguir Sistema" class="w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-200 hover:text-indigo-600 dark:hover:text-indigo-400 text-gray-500 dark:text-slate-400">
              <i class="fa-solid fa-desktop text-xs"></i>
            </button>
            <button data-action="click->theme#setTheme" data-theme-value="dark" title="Modo Oscuro" class="w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-200 hover:text-indigo-600 dark:hover:text-indigo-400 text-gray-500 dark:text-slate-400">
              <i class="fa-solid fa-moon text-xs"></i>
            </button>
          </div>
          <%= link_to new_user_session_path, class: "hidden lg:inline-flex items-center justify-center rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-700 dark:text-slate-300 px-5 py-2.5 text-sm font-bold shadow-sm hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors" do %>
            <i class="fa-solid fa-right-to-bracket mr-2"></i> Iniciar Sesión
          <% end %>
          <%= link_to new_user_registration_path, class: "hidden lg:inline-flex items-center justify-center rounded-xl bg-indigo-600 dark:bg-indigo-500 text-white px-5 py-2.5 text-sm font-bold shadow-sm hover:bg-indigo-700 dark:hover:bg-indigo-600 transition-colors" do %>
            <i class="fa-solid fa-user-plus mr-2"></i> Crear Cuenta
          <% end %>
        <% end %>
        <button data-action="click->mobile-menu#toggle" class="lg:hidden inline-flex items-center justify-center rounded-xl p-2.5 text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-indigo-400 focus:outline-none transition-all border border-gray-100 dark:border-slate-800 cursor-pointer">
          <span data-mobile-menu-target="iconOpen">
            <i class="fa-solid fa-bars-staggered text-xl"></i>
          </span>
          <span data-mobile-menu-target="iconClose" class="hidden">
            <i class="fa-solid fa-xmark text-xl"></i>
          </span>
        </button>
      </div>
    </div>
  </div>
  <%= render "shared/public_navbar_mobile" %>
</nav>
