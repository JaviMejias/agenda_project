<div aria-live="assertive" class="pointer-events-none fixed inset-0 flex px-4 py-6 items-start sm:p-6 z-50 mt-16">
  <div id="flash-container" class="flex w-full flex-col items-center space-y-4 sm:items-end">
    <% flash.each do |type, message| %>
      <%= render "shared/flash_message", type: type, message: message %>
    <% end %>
  </div>
</div>
