<% 
  property = local_assigns.fetch(:property, nil)
  show_views = local_assigns.fetch(:show_views, true)
  mode = local_assigns.fetch(:mode, 'booking')
%>

<div id="calendar-header-container" class="flex flex-col md:flex-row justify-between items-center mb-8 gap-6 px-2">
  
  <div class="flex items-center gap-1 bg-gray-50 dark:bg-slate-800/50 p-1.5 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm order-2 md:order-1">
    <button type="button" data-action="click->fullcalendar#prev" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:shadow-md transition-all border border-transparent dark:border-slate-700">
      <i class="fa-solid fa-chevron-left text-xs"></i>
    </button>
    <button type="button" data-action="click->fullcalendar#today" class="px-4 py-2 text-[10px] font-black uppercase tracking-widest bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:shadow-md transition-all rounded-xl border border-transparent dark:border-slate-700">
      Hoy
    </button>
    <button type="button" data-action="click->fullcalendar#next" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:shadow-md transition-all border border-transparent dark:border-slate-700">
      <i class="fa-solid fa-chevron-right text-xs"></i>
    </button>
  </div>

  
  <div class="order-1 md:order-2 flex flex-col items-center">
    <button type="button" data-action="click->fullcalendar#openDatePicker" class="group flex flex-col items-center focus:outline-none">
      <span class="text-[10px] font-black uppercase tracking-[0.2em] text-indigo-400 opacity-0 group-hover:opacity-100 transition-all mb-1">Saltar a fecha</span>
      <div class="flex items-center gap-3">
        <h3 data-fullcalendar-target="title" class="text-2xl font-black text-gray-900 dark:text-white capitalize tracking-tight group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors"></h3>
        <div class="w-8 h-8 rounded-full bg-indigo-50 dark:bg-indigo-950/30 flex items-center justify-center text-indigo-500 dark:text-indigo-400 group-hover:bg-indigo-600 group-hover:text-white transition-all shadow-sm border border-indigo-100 dark:border-indigo-900">
          <i class="fa-solid fa-calendar-plus text-xs"></i>
        </div>
      </div>
    </button>
    <input type="text" data-fullcalendar-target="jumpInput" class="hidden">
  </div>
  
  
  <div class="order-3">
    <% if show_views %>
      <div class="flex items-center gap-1 bg-gray-50 dark:bg-slate-800/50 p-1.5 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm">
        <% if mode == 'dashboard' %>
          <button type="button" id="btn-month" data-action="click->fullcalendar#changeView" data-view="dayGridMonth" class="px-4 py-2 text-[10px] font-black uppercase tracking-widest bg-white dark:bg-slate-800 text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 rounded-xl transition-all tab-active">Mes</button>
          <button type="button" id="btn-week" data-action="click->fullcalendar#changeView" data-view="timeGridWeek" class="px-4 py-2 text-[10px] font-black uppercase tracking-widest bg-white dark:bg-slate-800 text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 rounded-xl transition-all">Semana</button>
          <button type="button" id="btn-day" data-action="click->fullcalendar#changeView" data-view="timeGridDay" class="px-4 py-2 text-[10px] font-black uppercase tracking-widest bg-white dark:bg-slate-800 text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 rounded-xl transition-all">Día</button>
        <% elsif property&.per_hour? %>
          <button type="button" id="btn-week-cal" data-action="click->fullcalendar#changeView" data-view="timeGridWeek" class="px-4 py-2 text-[10px] font-black uppercase tracking-widest bg-white dark:bg-slate-800 text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 rounded-xl transition-all tab-active">Semana</button>
          <button type="button" id="btn-day-cal" data-action="click->fullcalendar#changeView" data-view="timeGridDay" class="px-4 py-2 text-[10px] font-black uppercase tracking-widest bg-white dark:bg-slate-800 text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 rounded-xl transition-all">Día</button>
        <% else %>
          <button type="button" id="btn-month-cal" data-action="click->fullcalendar#changeView" data-view="dayGridMonth" class="px-4 py-2 text-[10px] font-black uppercase tracking-widest bg-white dark:bg-slate-800 text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 rounded-xl transition-all tab-active">Mes</button>
        <% end %>
      </div>
    <% else %>
      <div class="w-10 md:w-32"></div>
    <% end %>
  </div>
</div>
