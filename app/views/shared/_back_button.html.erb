<% if local_assigns[:form] %>
  <%= link_to local_assigns[:path] || :back, class: "group inline-flex items-center text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-[0.2em] hover:text-indigo-600 dark:hover:text-indigo-400 transition-all" do %>
    <i class="fa-solid fa-arrow-left mr-2 group-hover:-translate-x-1 transition-transform"></i>
    <%= local_assigns[:text] || "Cancelar y Volver" %>
  <% end %>
<% else %>
  <div class="<%= local_assigns[:class] || 'mb-6' %>">
    <%= link_to local_assigns[:path] || :back, class: "group inline-flex items-center text-sm font-bold text-gray-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" do %>
      <div class="w-8 h-8 rounded-full bg-white dark:bg-slate-800 shadow-sm border border-gray-200 dark:border-slate-700 flex items-center justify-center mr-3 group-hover:bg-indigo-50 dark:group-hover:bg-indigo-900/50 group-hover:border-indigo-200 transition-all group-hover:-translate-x-1">
        <i class="fa-solid fa-arrow-left text-[10px]"></i>
      </div>
      <%= local_assigns[:text] || "Volver al listado" %>
    <% end %>
  </div>
<% end %>
