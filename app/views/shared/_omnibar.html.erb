<div id="omnibar-modal" 
     class="hidden fixed inset-0 z-[100] overflow-y-auto p-4 sm:p-6 md:p-20" 
     role="dialog" 
     aria-modal="true"
     data-omnibar-target="modal">
  <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity" 
       data-action="click->omnibar#close"></div>
  <div class="mx-auto max-w-2xl transform divide-y divide-gray-100 dark:divide-slate-800 overflow-hidden rounded-2xl bg-white/90 dark:bg-slate-900/90 shadow-2xl ring-1 ring-black/5 backdrop-blur-2xl transition-all opacity-0 scale-95 duration-200"
       data-omnibar-target="container">
    <div class="relative">
      <i class="fa-solid fa-magnifying-glass absolute left-4 sm:left-6 top-5 text-indigo-500 dark:text-indigo-400 text-lg"></i>
      <input type="text" 
             class="h-16 w-full border-0 bg-transparent pl-12 sm:pl-14 pr-4 text-gray-900 dark:text-white placeholder:text-gray-400 focus:ring-0 text-sm sm:text-base font-bold" 
             placeholder="Buscar clientes, reservas, propiedades..."
             data-omnibar-target="input"
             data-action="input->omnibar#search">
      <div class="absolute right-4 top-4 hidden sm:flex items-center gap-2">
        <kbd class="flex h-7 items-center rounded border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-2 font-sans text-[10px] font-black text-gray-400 uppercase tracking-widest shadow-sm">
          Esc
        </kbd>
      </div>
    </div>
    <div class="max-h-[60vh] sm:max-h-[50vh] scroll-py-2 overflow-y-auto pb-2" data-omnibar-target="results"></div>
    <div class="hidden sm:flex items-center justify-between bg-gray-50/50 dark:bg-slate-800/30 px-6 py-3">
      <div class="flex gap-4">
        <div class="flex items-center gap-1">
          <kbd class="flex h-5 w-5 items-center justify-center rounded border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 font-sans text-[10px] font-black text-gray-400 shadow-sm">
            <i class="fa-solid fa-arrow-up text-[8px]"></i>
          </kbd>
          <kbd class="flex h-5 w-5 items-center justify-center rounded border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 font-sans text-[10px] font-black text-gray-400 shadow-sm">
            <i class="fa-solid fa-arrow-down text-[8px]"></i>
          </kbd>
          <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Navegar</span>
        </div>
        <div class="flex items-center gap-1">
          <kbd class="flex h-5 px-1 items-center justify-center rounded border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 font-sans text-[10px] font-black text-gray-400 shadow-sm">
            Enter
          </kbd>
          <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Seleccionar</span>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest">Omnibar v1.0</span>
      </div>
    </div>
  </div>
</div>
