<%
  admin_items = [
    { name: 'Dashboard', path: dashboard_path, icon: 'fa-chart-pie', controller: 'dashboard' },
    { name: 'Empresas', path: companies_path, icon: 'fa-building', controller: 'companies' },
    { name: 'Usuarios', path: users_path, icon: 'fa-users-gear', controller: 'users' },
    { name: 'Reportes', path: reports_path, icon: 'fa-chart-line', controller: 'reports' }
  ]
  operational_items = [
    { name: 'Propiedades', path: properties_path, icon: 'fa-house-chimney', controller: 'properties' },
    { name: 'Agenda Global', path: reservations_path, icon: 'fa-book-open', controller: 'reservations' },
    { name: 'Clientes', path: clients_path, icon: 'fa-users', controller: 'clients' },
    { name: 'Historial', path: audits_path, icon: 'fa-clock-rotate-left', controller: 'audits' }
  ]
%>
<nav data-controller="mobile-menu" class="sticky top-0 z-40">
  <div class="absolute inset-0 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border-b border-gray-200/50 dark:border-slate-800 shadow-sm -z-10"></div>
  <div class="mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 justify-between items-center">
      <div class="flex items-center gap-8">
        <%= link_to root_path, class: "flex flex-shrink-0 items-center text-indigo-600 dark:text-indigo-400 font-black text-2xl tracking-tighter drop-shadow-sm hover:opacity-80 transition-opacity" do %>
          <i class="fa-solid fa-calendar-days mr-2 text-indigo-500 animate-pulse"></i> Agenda
        <% end %>
        <div class="hidden sm:flex sm:items-center sm:space-x-1">
          <% if current_user.admin? %>
            <div class="relative mr-2" data-controller="dropdown" data-action="click@window->dropdown#hide">
              <button data-action="click->dropdown#toggle" data-dropdown-target="button" class="group inline-flex items-center rounded-xl px-4 py-2 text-sm font-bold text-gray-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800 transition-all duration-300">
                <i class="fa-solid fa-screwdriver-wrench mr-2.5 text-gray-400 group-hover:text-indigo-500 transition-colors"></i>
                <span>Administración</span>
                <i class="fa-solid fa-chevron-down ml-2 text-[10px] opacity-50 group-hover:rotate-180 transition-transform"></i>
              </button>

              <div data-dropdown-target="menu" class="hidden absolute left-0 mt-2 w-56 origin-top-left rounded-2xl bg-white dark:bg-slate-800 shadow-2xl shadow-indigo-100/50 dark:shadow-none ring-1 ring-black ring-opacity-5 focus:outline-none overflow-hidden z-50 border border-gray-100 dark:border-slate-700 transition-all duration-200 ease-out opacity-0 scale-95">
                <div class="py-2">
                  <div class="px-4 py-2 border-b border-gray-50 dark:border-slate-700/50 mb-1">
                    <span class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest">Panel de Control</span>
                  </div>
                  <% admin_items.each do |item| %>
                    <% is_active = controller_name == item[:controller] %>
                    <%= link_to item[:path], class: "flex items-center px-4 py-2.5 text-sm font-bold #{is_active ? 'text-indigo-600 bg-indigo-50/50 dark:text-indigo-400 dark:bg-indigo-900/20' : 'text-gray-600 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-slate-700/50 hover:text-indigo-600 dark:hover:text-indigo-400'} transition-all" do %>
                      <i class="fa-solid <%= item[:icon] %> w-5 mr-3 text-center <%= is_active ? 'text-indigo-500' : 'text-gray-400' %>"></i>
                      <%= item[:name] %>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
          <% operational_items.each do |item| %>
            <% is_active = controller_name == item[:controller] %>
            <%= link_to item[:path], class: "group relative inline-flex items-center rounded-xl px-4 py-2 text-sm font-bold transition-all duration-300 #{is_active ? 'text-indigo-600 bg-indigo-50/50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
              <i class="fa-solid <%= item[:icon] %> mr-2.5 transition-colors <%= is_active ? 'text-indigo-500' : 'text-gray-400 group-hover:text-indigo-500' %>"></i> 
              <span><%= item[:name] %></span>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="flex items-center space-x-4">
        <button data-action="click->omnibar#open" 
                class="hidden md:flex items-center gap-3 px-3 py-1.5 rounded-xl bg-gray-50 dark:bg-slate-800 border border-gray-100 dark:border-slate-700 text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:border-indigo-100 dark:hover:border-indigo-900 transition-all group shadow-sm">
          <i class="fa-solid fa-magnifying-glass text-xs group-hover:scale-110 transition-transform"></i>
          <span class="text-[10px] font-black uppercase tracking-widest">Buscar...</span>
          <kbd class="flex h-5 items-center gap-1 rounded bg-white dark:bg-slate-900 px-1.5 font-sans text-[10px] font-black text-gray-300 dark:text-slate-600 border border-gray-100 dark:border-slate-800">
            <span class="text-[8px]">⌘</span>K
          </kbd>
        </button>
        <div class="relative" data-controller="dropdown" data-action="click@window->dropdown#hide">
          <%= turbo_stream_from "notifications_#{current_user.id}" %>
          <div id="notifications_signal"></div>
          <button data-action="click->dropdown#toggle" data-dropdown-target="button" class="relative p-2.5 rounded-xl text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50/50 dark:hover:bg-slate-800 transition-all focus:outline-none group">
            <i id="notification-bell" class="fa-solid fa-bell text-lg group-hover:scale-110 transition-transform"></i>
            <span id="notifications_count" class="absolute top-2 right-2 flex items-center justify-center min-w-[16px] h-[16px] px-1 text-[9px] font-black text-white bg-red-500 rounded-full border-2 border-white dark:border-slate-900 <%= current_user.notifications.unread.count.zero? ? 'hidden' : '' %>">
              <%= current_user.notifications.unread.count %>
            </span>
          </button>
          <div data-dropdown-target="menu" class="hidden flex flex-col overflow-hidden fixed inset-0 z-[60] sm:z-50 sm:absolute sm:inset-auto sm:right-0 sm:mt-2 w-full h-full sm:h-auto sm:max-h-[36rem] sm:w-[450px] bg-white dark:bg-slate-900 shadow-2xl origin-top-right sm:rounded-3xl border-0 sm:border border-gray-100 dark:border-slate-700 animate-in fade-in slide-in-from-bottom-4 sm:slide-in-from-top-2 sm:zoom-in duration-300">
            <div class="px-4 py-4 sm:py-3 border-b border-gray-50 dark:border-slate-700/50 flex justify-between items-center bg-gray-50/50 dark:bg-slate-800/50 flex-shrink-0">
              <div class="flex items-center gap-3">
                <button data-action="click->dropdown#hide" class="sm:hidden text-gray-400 hover:text-gray-600">
                  <i class="fa-solid fa-arrow-left"></i>
                </button>
                <span class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest">Notificaciones</span>
              </div>
              <div class="flex items-center gap-4">
                <% if current_user.notifications.any? %>
                  <%= button_to mark_all_as_read_notifications_path, method: :post, 
                      data: { action: "click->dropdown#stop" },
                      class: "text-[10px] font-bold text-indigo-600 dark:text-indigo-400 hover:underline" do %>
                    Marcar leídas
                  <% end %>
                <% end %>
                <button data-action="click->dropdown#hide" class="sm:hidden w-8 h-8 rounded-full bg-gray-200/50 flex items-center justify-center text-gray-500">
                  <i class="fa-solid fa-xmark text-xs"></i>
                </button>
              </div>
            </div>
            <div id="notifications_list" class="flex-1 sm:h-auto sm:max-h-[28rem] overflow-y-auto p-4 space-y-3 bg-white dark:bg-slate-900 sm:bg-gray-50/20 sm:dark:bg-slate-900/50">
              <% if current_user.notifications.any? %>
                <%= render current_user.notifications.ordered.limit(10) %>
              <% else %>
                <div id="no-notifications" class="flex flex-col items-center justify-center py-20 text-center">
                  <div class="w-20 h-20 rounded-full bg-gray-50 dark:bg-slate-800/50 flex items-center justify-center mb-4 border border-gray-100 dark:border-slate-700">
                    <i class="fa-solid fa-bell-slash text-gray-200 dark:text-slate-700 text-3xl"></i>
                  </div>
                  <h4 class="text-sm font-bold text-gray-900 dark:text-white mb-1">Bandeja Vacía</h4>
                  <p class="text-xs text-gray-400 dark:text-slate-500 font-medium">No tienes notificaciones pendientes</p>
                </div>
              <% end %>
            </div>
            <div class="mt-auto border-t border-gray-50 dark:border-slate-700/50 bg-gray-50/50 dark:bg-slate-800/50 flex-shrink-0">
              <%= link_to notifications_path, class: "group flex items-center justify-center p-4 sm:p-3 pb-8 sm:pb-3 text-center transition-all hover:bg-indigo-50 dark:hover:bg-indigo-900/20" do %>
                <span class="text-[10px] font-black uppercase tracking-widest text-indigo-600 dark:text-indigo-400 group-hover:scale-105 transition-transform">
                  Ver historial completo
                  <i class="fa-solid fa-arrow-right ml-2 text-[8px]"></i>
                </span>
              <% end %>
            </div>
          </div>
        </div>
        <div data-controller="theme" class="hidden sm:flex items-center bg-gray-100 dark:bg-slate-800/50 p-1 rounded-xl border border-gray-200/50 dark:border-slate-700/50">
          <button data-action="click->theme#setTheme" data-theme-value="light" title="Modo Claro"
                  class="w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-200 hover:text-indigo-600">
            <i class="fa-solid fa-sun text-xs"></i>
          </button>
          <button data-action="click->theme#setTheme" data-theme-value="system" title="Seguir Sistema"
                  class="w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-200 hover:text-indigo-600">
            <i class="fa-solid fa-desktop text-xs"></i>
          </button>
          <button data-action="click->theme#setTheme" data-theme-value="dark" title="Modo Oscuro"
                  class="w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-200 hover:text-indigo-600">
            <i class="fa-solid fa-moon text-xs"></i>
          </button>
        </div>
        <div class="hidden md:flex items-center gap-3 pr-4 border-r border-gray-100 dark:border-slate-800">
          <div class="flex flex-col items-end">
            <span class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none">Usuario</span>
            <span class="text-xs font-bold text-gray-700 dark:text-slate-200 truncate max-w-[150px]"><%= current_user.email.split('@').first %></span>
          </div>
          <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-600 text-white font-black text-sm shadow-lg shadow-indigo-100/30 dark:shadow-none ring-2 ring-white dark:ring-slate-800">
            <%= current_user.email[0].upcase %>
          </div>
        </div>
        <div class="hidden sm:block">
          <%= link_to destroy_user_session_path, data: { turbo: false }, class: "group inline-flex items-center justify-center rounded-xl text-xs font-black uppercase tracking-widest text-gray-400 hover:text-red-600 hover:bg-red-50 px-4 py-2.5 transition-all duration-300 border border-transparent hover:border-red-100" do %>
            <i class="fa-solid fa-power-off mr-2 group-hover:rotate-90 transition-transform"></i> Salir
          <% end %>
        </div>
        <button data-action="click->mobile-menu#toggle" class="sm:hidden inline-flex items-center justify-center rounded-xl p-2.5 text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 focus:outline-none transition-all border border-gray-100">
          <span data-mobile-menu-target="iconOpen">
            <i class="fa-solid fa-bars-staggered text-xl"></i>
          </span>
          <span data-mobile-menu-target="iconClose" class="hidden">
            <i class="fa-solid fa-xmark text-xl"></i>
          </span>
        </button>
      </div>
    </div>
  </div>
  <%= render "shared/navbar_mobile", admin_items: admin_items, operational_items: operational_items %>
</nav>
