<% content_for :title, "Listado de Reservas" %>

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in" data-controller="search">
  
  <!-- Premium Header & Filters Container -->
  <div class="relative mb-8 p-5 sm:p-6 rounded-[2rem] bg-gradient-to-br from-white to-indigo-50 dark:from-slate-900 dark:to-slate-950 border border-indigo-100 dark:border-slate-800 shadow-xl shadow-indigo-100/30 dark:shadow-none overflow-hidden group">
    <div class="absolute -top-24 -right-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl"></div>
    
    <div class="relative flex flex-col xl:flex-row xl:items-center justify-between gap-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-2xl bg-white dark:bg-slate-800 border border-indigo-100 dark:border-slate-700 shadow-sm flex items-center justify-center text-indigo-600 dark:text-indigo-400 text-xl">
          <i class="fa-solid fa-list-check"></i>
        </div>
        <div>
          <h1 class="text-xl sm:text-2xl font-black text-gray-900 dark:text-white tracking-tight leading-tight">
            Listado de Reservas
          </h1>
          <p class="text-indigo-600 dark:text-indigo-400 text-[10px] font-bold uppercase tracking-widest flex items-center gap-2">
            <%= @reservations_count %> registros encontrados
          </p>
        </div>
      </div>

      <!-- Filters Row -->
      <div class="flex flex-col md:flex-row items-center gap-4">
        <%= form_with url: list_reservations_path, method: :get, data: { turbo_frame: "list_frame", search_target: "form", action: "input->search#submit" }, class: "flex-grow w-full md:w-auto" do |f| %>
          <div class="flex items-center gap-2">
            <div class="relative flex-grow min-w-[200px]">
              <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-indigo-300 dark:text-slate-500 text-xs"></i>
              <%= f.text_field :q, value: params[:q], placeholder: "Buscar por cliente...", class: "w-full pl-10 pr-4 py-3 bg-white dark:bg-slate-800 border border-indigo-50 dark:border-slate-700 rounded-xl text-xs font-bold text-gray-900 dark:text-white placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all shadow-sm", data: { action: "search#submit" } %>
            </div>
            
            <%= f.select :status, 
                Reservation.selectable_statuses.map { |s| [I18n.t("enums.reservation.status.#{s}"), s] }, 
                { include_blank: "Todos los estados", selected: params[:status] }, 
                { class: "h-[42px] px-4 bg-white dark:bg-slate-800 border border-indigo-50 dark:border-slate-700 rounded-xl text-[10px] font-black uppercase tracking-widest text-gray-600 dark:text-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-transparent cursor-pointer shadow-sm" } %>
            
            <% if params[:q].present? || params[:status].present? %>
              <button type="button" data-action="click->search#reset" class="h-[42px] px-4 bg-white dark:bg-slate-800 text-gray-500 rounded-xl hover:bg-red-50 dark:hover:bg-red-950/20 hover:text-red-600 transition-all text-[10px] font-black uppercase tracking-widest shadow-sm border border-indigo-50 dark:border-slate-700" title="Limpiar filtros">
                <i class="fa-solid fa-arrow-rotate-left"></i>
              </button>
            <% end %>
          </div>
        <% end %>

        <div class="bg-white/50 dark:bg-slate-800/50 backdrop-blur-md p-1 rounded-xl border border-indigo-100 dark:border-slate-700 flex items-center gap-1 shadow-sm">
          <%= link_to list_reservations_path(request.query_parameters.merge(format: :xlsx)), 
              class: "w-9 h-9 rounded-lg flex items-center justify-center text-emerald-600 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-950/30 transition-all", 
              title: "Exportar a Excel", 
              data: { turbo: false } do %>
            <i class="fa-solid fa-file-excel"></i>
          <% end %>
          <%= link_to list_reservations_path(request.query_parameters.merge(format: :pdf)), 
              class: "w-9 h-9 rounded-lg flex items-center justify-center text-rose-600 dark:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-950/30 transition-all", 
              title: "Exportar a PDF", 
              data: { turbo: false } do %>
            <i class="fa-solid fa-file-pdf"></i>
          <% end %>
        </div>

        <div class="bg-white/50 dark:bg-slate-800/50 backdrop-blur-md p-1 rounded-xl border border-indigo-100 dark:border-slate-700 inline-flex shadow-sm">
           <%= link_to reservations_path, class: "px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all duration-300 text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400" do %>Agenda<% end %>
           <span class="px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all duration-300 tab-active">Listado</span>
        </div>
      </div>
    </div>
  </div>

  
  <turbo-frame id="list_frame" class="relative block w-full">
    <div data-search-target="loading" class="hidden absolute inset-0 z-50 bg-white/60 dark:bg-slate-950/60 backdrop-blur-[2px] items-center justify-center rounded-[2rem] transition-all duration-300">
      <div class="flex flex-col items-center">
        <div class="w-16 h-16 border-4 border-indigo-100 dark:border-slate-800 border-t-indigo-600 dark:border-t-indigo-500 rounded-full animate-spin mb-4"></div>
        <p class="text-[10px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest animate-pulse">Actualizando listado...</p>
      </div>
    </div>
    <% if @reservations.any? %>
      <div class="space-y-3 mb-8">
        <% @reservations.each do |reservation| %>
          <div class="group bg-white dark:bg-slate-900 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-sm hover:shadow-md transition-all duration-300 flex items-center overflow-hidden">
            <div class="w-2 h-20 self-stretch shrink-0" style="background-color: <%= reservation.property.color || '#4f46e5' %>"></div>
            
            <div class="flex-grow grid grid-cols-1 md:grid-cols-12 items-center p-4 gap-4">
              
              <!-- Columna 1: Cliente/Propiedad -->
              <div class="md:col-span-4 flex items-center gap-4 min-w-0">
                <div class="w-10 h-10 rounded-full bg-indigo-50 dark:bg-slate-800 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shrink-0">
                  <i class="fa-solid fa-user text-sm"></i>
                </div>
                <div class="truncate">
                  <h3 class="text-sm font-black text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors truncate">
                    <%= reservation.client_name %>
                  </h3>
                  <p class="text-[10px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest flex items-center gap-1">
                    <i class="fa-solid fa-house-chimney text-[8px]"></i> <%= reservation.property.name %>
                  </p>
                </div>
              </div>

              <!-- Columna 2: Fecha -->
              <div class="md:col-span-3 flex items-center gap-3 md:border-l md:border-gray-50 dark:md:border-slate-800 md:pl-6">
                <div class="w-8 h-8 rounded-lg bg-purple-50 dark:bg-purple-900/20 flex items-center justify-center text-purple-600 dark:text-purple-400 shrink-0">
                  <i class="fa-solid fa-calendar-day text-xs"></i>
                </div>
                <div class="truncate">
                  <p class="text-[10px] font-black text-gray-900 dark:text-slate-200 leading-none mb-1 truncate">
                    <% if reservation.property.per_day? %>
                      <%= reservation.start_time.strftime("%d %b") %> - <%= (reservation.end_time - 1.day).strftime("%d %b, %Y") %>
                    <% else %>
                      <%= reservation.start_time.strftime("%d %b, %H:%M") %>
                    <% end %>
                  </p>
                  <p class="text-[9px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-tighter">
                    <%= reservation.property.per_day? ? "Día" : "Hora" %>
                  </p>
                </div>
              </div>

              <!-- Columna 3: Precio -->
              <div class="md:col-span-2 md:border-l md:border-gray-50 dark:md:border-slate-800 md:pl-6">
                <p class="text-[10px] font-bold text-gray-400 dark:text-slate-500 uppercase tracking-tighter leading-none mb-1 md:text-right">Total</p>
                <p class="text-sm font-black text-indigo-600 dark:text-indigo-400 md:text-right">
                  $<%= number_to_currency(reservation.total_price, unit: "", separator: ",", delimiter: ".") %>
                </p>
              </div>

              <!-- Columna 4: Estado y Acciones -->
              <div class="md:col-span-3 flex items-center justify-between md:justify-end gap-4 md:border-l md:border-gray-50 dark:md:border-slate-800 md:pl-6">
                <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-widest border <%= reservation.status_color_classes %>">
                  <%= reservation.status_text %>
                </span>

                <div class="flex items-center gap-2">
                  <%= link_to reservation_path(reservation, from: 'list'), data: { turbo_frame: "_top" }, class: "w-9 h-9 rounded-xl bg-gray-50 dark:bg-slate-800 flex items-center justify-center text-gray-400 hover:bg-indigo-600 dark:hover:bg-indigo-500 hover:text-white transition-all shadow-sm" do %>
                    <i class="fa-solid fa-eye text-xs"></i>
                  <% end %>
                  <%= link_to edit_reservation_path(reservation, from: 'list'), data: { turbo_frame: "_top" }, class: "w-9 h-9 rounded-xl bg-gray-50 dark:bg-slate-800 flex items-center justify-center text-gray-400 hover:bg-amber-500 dark:hover:bg-amber-600 hover:text-white transition-all shadow-sm" do %>
                    <i class="fa-solid fa-pen-to-square text-xs"></i>
                  <% end %>
                </div>
              </div>

            </div>
          </div>
        <% end %>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="flex justify-center pb-8 pt-4">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center justify-center py-20 text-center bg-white dark:bg-slate-900 rounded-[2rem] border border-gray-100 dark:border-slate-800 shadow-sm">
        <div class="w-16 h-16 bg-gray-50 dark:bg-slate-800 rounded-full flex items-center justify-center mb-4 text-gray-200 dark:text-slate-700">
          <i class="fa-solid fa-calendar-xmark text-2xl"></i>
        </div>
        <h3 class="text-lg font-black text-gray-900 dark:text-white">No hay resultados</h3>
        <p class="text-xs text-gray-500 dark:text-slate-400 font-medium">Prueba con otros términos o limpia la búsqueda.</p>
      </div>
    <% end %>
  </turbo-frame>
</div>

<style>
  .tab-active {
    background-color: white !important;
    color: #4f46e5 !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05) !important;
    transform: scale(1.02);
  }
  html.dark .tab-active {
    background-color: #1e293b !important;
    color: #818cf8 !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2) !important;
  }
</style>
