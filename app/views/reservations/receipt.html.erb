<div style="font-family: 'Helvetica', 'Arial', sans-serif; max-width: 800px; margin: 0 auto; color: #1e293b;">
  
  <!-- Header Section -->
  <div style="display: table; width: 100%; border-bottom: 3px solid #4f46e5; padding-bottom: 20px; margin-bottom: 30px;">
    <!-- Company Info (Left) -->
    <div style="display: table-cell; width: 50%; vertical-align: top;">
      <% if @reservation.property.company.present? %>
        <% company = @reservation.property.company %>
        <% if company.logo.attached? %>
          <div style="margin-bottom: 15px;">
            <% image_base64 = Base64.strict_encode64(company.logo.download) %>
            <img src="data:<%= company.logo.content_type %>;base64,<%= image_base64 %>" style="max-height: 60px; max-width: 150px; object-fit: contain;" />
          </div>
        <% end %>
        <h2 style="margin: 0; color: #111827; font-size: 24px; font-weight: 900; text-transform: uppercase; letter-spacing: -0.5px;">
          <%= company.name %>
        </h2>
        <p style="margin: 4px 0 0 0; font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; font-weight: bold;">
          <%= company.business_type %>
        </p>
        <div style="margin-top: 10px; font-size: 12px; color: #475569; line-height: 1.5;">
          <% if company.rut.present? %><div><strong>RUT:</strong> <%= company.rut %></div><% end %>
          <% if company.address.present? %><div><strong>Dirección:</strong> <%= company.address %></div><% end %>
          <% if company.phone.present? %><div><strong>Tel:</strong> <%= company.phone %></div><% end %>
          <% if company.email.present? %><div><strong>Email:</strong> <%= company.email %></div><% end %>
        </div>
      <% else %>
        <h2 style="margin: 0; color: #111827; font-size: 24px; font-weight: 900; letter-spacing: -0.5px;">AGENDA PRO</h2>
        <p style="margin: 4px 0 0 0; font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; font-weight: bold;">Plataforma de Reservas</p>
      <% end %>
    </div>
    
    <!-- Receipt Info (Right) -->
    <div style="display: table-cell; width: 50%; text-align: right; vertical-align: top;">
      <h1 style="margin: 0; color: #4f46e5; font-size: 32px; font-weight: 900; letter-spacing: -1px;">RECIBO</h1>
      <p style="margin: 5px 0 0 0; font-size: 14px; color: #0f172a; font-weight: bold;">
        Reserva N° <%= @reservation.id %>
      </p>
      <p style="margin: 4px 0 0 0; font-size: 12px; color: #64748b;">
        Fecha de Emisión: <%= Time.current.strftime("%d/%m/%Y") %>
      </p>
      
      <div style="margin-top: 15px;">
        <% 
          status_colors = {
            'pending' => 'background-color: #fef3c7; color: #d97706; border: 1px solid #fde68a;',
            'confirmed' => 'background-color: #d1fae5; color: #059669; border: 1px solid #a7f3d0;',
            'cancelled' => 'background-color: #fee2e2; color: #e11d48; border: 1px solid #fecaca;',
            'completed' => 'background-color: #e0e7ff; color: #4338ca; border: 1px solid #c7d2fe;'
          }
          status_labels = {
            'pending' => 'Pendiente',
            'confirmed' => 'Confirmada',
            'cancelled' => 'Cancelada',
            'completed' => 'Completada'
          }
        %>
        <span style="display: inline-block; padding: 6px 12px; border-radius: 6px; font-size: 11px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; <%= status_colors[@reservation.status] || status_colors['pending'] %>">
          Estado: <%= status_labels[@reservation.status] || @reservation.status.titleize %>
        </span>
      </div>
    </div>
  </div>

  <!-- Reservation & Client Details -->
  <div style="display: table; width: 100%; margin-bottom: 30px;">
    <div style="display: table-cell; width: 50%; padding-right: 15px; vertical-align: top;">
      <div style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; height: 100%;">
        <h3 style="margin: 0 0 15px 0; font-size: 11px; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;">Cobrar A:</h3>
        <p style="margin: 0 0 8px 0; font-size: 16px; font-weight: bold; color: #0f172a;"><%= @reservation.client_name %></p>
        <% if @reservation.client.present? %>
          <% if @reservation.client.rut.present? %><p style="margin: 0 0 4px 0; font-size: 12px; color: #475569;"><strong style="color:#1e293b;">RUT:</strong> <%= @reservation.client.rut %></p><% end %>
          <% if @reservation.client.email.present? %><p style="margin: 0 0 4px 0; font-size: 12px; color: #475569;"><strong style="color:#1e293b;">Email:</strong> <%= @reservation.client.email %></p><% end %>
          <% if @reservation.client.phone.present? %><p style="margin: 0; font-size: 12px; color: #475569;"><strong style="color:#1e293b;">Tel:</strong> <%= @reservation.client.phone %></p><% end %>
        <% end %>
      </div>
    </div>
    
    <div style="display: table-cell; width: 50%; padding-left: 15px; vertical-align: top;">
      <div style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; height: 100%;">
        <h3 style="margin: 0 0 15px 0; font-size: 11px; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;">Detalles del Servicio:</h3>
        <p style="margin: 0 0 12px 0; font-size: 14px; font-weight: bold; color: #0f172a;"><%= @reservation.property.name %></p>
        <% 
          display_end = @reservation.property.per_day? ? @reservation.end_time - 1.day : @reservation.end_time
          date_format = @reservation.property.per_hour? ? "%d/%m/%Y %H:%M" : "%d/%m/%Y" 
        %>
        <table style="width: 100%; margin: 0; padding: 0; border: none; font-size: 12px;">
          <tr>
            <td style="padding: 4px 0; color: #64748b; border: none;">Entrada:</td>
            <td style="padding: 4px 0; font-weight: bold; text-align: right; border: none; color: #1e293b;"><%= @reservation.start_time.strftime(date_format) %></td>
          </tr>
          <tr>
            <td style="padding: 4px 0; color: #64748b; border: none;">Salida:</td>
            <td style="padding: 4px 0; font-weight: bold; text-align: right; border: none; color: #1e293b;"><%= display_end.strftime(date_format) %></td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <!-- Financial Summary -->
  <div style="margin-bottom: 40px;">
    <h3 style="font-size: 14px; margin: 0 0 15px 0; color: #0f172a; border-bottom: 2px solid #e2e8f0; padding-bottom: 8px; font-weight: 900; text-transform: uppercase;">
      Resumen Financiero
    </h3>
    <table style="width: 100%; border-collapse: collapse; margin-bottom: 10px;">
      <tr>
        <td style="padding: 12px 10px; border-bottom: 1px solid #f1f5f9; color: #475569; font-size: 14px;">Total Acordado</td>
        <td style="padding: 12px 10px; border-bottom: 1px solid #f1f5f9; text-align: right; font-weight: bold; font-size: 14px; color: #0f172a;">
          $<%= number_with_delimiter(@reservation.total_price.to_i, delimiter: ".") %>
        </td>
      </tr>
      <tr>
        <td style="padding: 12px 10px; border-bottom: 1px solid #f1f5f9; color: #475569; font-size: 14px;">Total Pagado / Abonado</td>
        <td style="padding: 12px 10px; border-bottom: 1px solid #f1f5f9; text-align: right; font-weight: bold; font-size: 14px; color: #059669;">
          $<%= number_with_delimiter(@reservation.total_paid.to_i, delimiter: ".") %>
        </td>
      </tr>
      <tr>
        <td style="padding: 15px 10px; font-weight: 900; font-size: 18px; color: #0f172a; border-top: 2px solid #e2e8f0; background-color: #f8fafc; border-bottom-left-radius: 8px;">Saldo Pendiente</td>
        <td style="padding: 15px 10px; font-weight: 900; font-size: 18px; text-align: right; border-top: 2px solid #e2e8f0; background-color: #f8fafc; border-bottom-right-radius: 8px; color: <%= @reservation.pending_balance <= 0 ? '#059669' : '#dc2626' %>;">
          $<%= number_with_delimiter(@reservation.pending_balance.to_i, delimiter: ".") %>
        </td>
      </tr>
    </table>
  </div>

  <!-- Transactions Table -->
  <% if @reservation.payments.any? %>
    <h3 style="font-size: 14px; margin: 0 0 15px 0; color: #0f172a; border-bottom: 2px solid #e2e8f0; padding-bottom: 8px; font-weight: 900; text-transform: uppercase;">
      Historial de Transacciones
    </h3>
    <table style="width: 100%; border-collapse: separate; border-spacing: 0; border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden;">
      <thead style="background-color: #f8fafc;">
        <tr>
          <th style="padding: 12px 15px; text-align: left; font-size: 10px; text-transform: uppercase; color: #64748b; border-bottom: 1px solid #e2e8f0;">Fecha</th>
          <th style="padding: 12px 15px; text-align: left; font-size: 10px; text-transform: uppercase; color: #64748b; border-bottom: 1px solid #e2e8f0;">Tipo</th>
          <th style="padding: 12px 15px; text-align: left; font-size: 10px; text-transform: uppercase; color: #64748b; border-bottom: 1px solid #e2e8f0;">Método</th>
          <th style="padding: 12px 15px; text-align: left; font-size: 10px; text-transform: uppercase; color: #64748b; border-bottom: 1px solid #e2e8f0;">Notas</th>
          <th style="padding: 12px 15px; text-align: right; font-size: 10px; text-transform: uppercase; color: #64748b; border-bottom: 1px solid #e2e8f0;">Monto</th>
        </tr>
      </thead>
      <tbody>
        <% @reservation.payments.order(payment_date: :asc).each_with_index do |payment, index| %>
          <tr style="background-color: <%= index.even? ? '#ffffff' : '#f8fafc' %>;">
            <td style="padding: 12px 15px; font-size: 12px; color: #334155; border-bottom: 1px solid #f1f5f9;"><%= payment.payment_date.strftime("%d/%m/%Y") %></td>
            <td style="padding: 12px 15px; border-bottom: 1px solid #f1f5f9;">
              <span style="display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: bold; text-transform: uppercase; background-color: <%= payment.abono? ? '#d1fae5' : '#fee2e2' %>; color: <%= payment.abono? ? '#065f46' : '#9f1239' %>;">
                <%= payment.abono? ? 'Abono' : 'Reembolso' %>
              </span>
            </td>
            <td style="padding: 12px 15px; font-size: 12px; color: #475569; border-bottom: 1px solid #f1f5f9;">
              <% 
                method_label = case payment.payment_method
                  when 'transfer' then 'Transferencia'
                  when 'cash' then 'Efectivo'
                  when 'card' then 'Tarjeta'
                  else 'Depósito / Otro'
                end
              %>
              <%= method_label %>
              <% if payment.operation_number.present? %>
                <br>
                <span style="font-size: 10px; color: #64748b; font-weight: bold;">N° <%= payment.operation_number %></span>
              <% end %>
            </td>
            <td style="padding: 12px 15px; font-size: 12px; color: #64748b; border-bottom: 1px solid #f1f5f9; font-style: italic;"><%= payment.notes.presence || "-" %></td>
            <td style="padding: 12px 15px; text-align: right; font-weight: 900; font-size: 13px; border-bottom: 1px solid #f1f5f9; color: <%= payment.abono? ? '#059669' : '#e11d48' %>;">
              <%= payment.abono? ? '+' : '-' %> $<%= number_with_delimiter(payment.amount.to_i, delimiter: ".") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <div style="margin-top: 40px; text-align: center; color: #64748b; font-size: 11px;">
    <i>Este documento es un comprobante de transacciones de carácter informativo y no constituye una boleta o factura fiscal.</i>
  </div>
</div>
