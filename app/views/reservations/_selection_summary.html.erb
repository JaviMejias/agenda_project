<div data-fullcalendar-target="preview" class="hidden animate-fade-in space-y-6">
  <% if local_assigns[:previous_reservation] %>
    <div class="p-5 bg-amber-50/50 dark:bg-amber-900/10 rounded-[2rem] border-2 border-dashed border-amber-200 dark:border-amber-900/50 transition-all">
      <div class="flex items-center gap-2 mb-4">
        <div class="w-6 h-6 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center text-amber-600 dark:text-amber-400">
           <i class="fa-solid fa-clock-rotate-left text-[10px]"></i>
        </div>
        <span class="text-[10px] font-black text-amber-700 dark:text-amber-500 uppercase tracking-widest">Reserva Original</span>
      </div>
      
      <div class="grid grid-cols-2 gap-4">
        <div class="space-y-1">
          <p class="text-[8px] font-black text-amber-600/50 dark:text-amber-400/50 uppercase tracking-tighter">Desde</p>
          <div class="flex items-center gap-2">
            <i class="fa-solid fa-calendar text-[10px] text-amber-400"></i>
            <p class="text-xs font-bold text-amber-900 dark:text-amber-200">
              <%= local_assigns[:previous_reservation].start_time.strftime(local_assigns[:previous_reservation].property.per_hour? ? "%d/%m/%Y %H:%M" : "%d/%m/%Y") %>
            </p>
          </div>
        </div>
        <div class="space-y-1">
          <p class="text-[8px] font-black text-amber-600/50 dark:text-amber-400/50 uppercase tracking-tighter">Hasta</p>
          <div class="flex items-center gap-2">
            <i class="fa-solid fa-calendar-check text-[10px] text-amber-400"></i>
            <p class="text-xs font-bold text-amber-900 dark:text-amber-200">
              <%= local_assigns[:previous_reservation].end_time.strftime(local_assigns[:previous_reservation].property.per_hour? ? "%d/%m/%Y %H:%M" : "%d/%m/%Y") %>
            </p>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="p-6 bg-white dark:bg-slate-900 rounded-[2rem] border-2 border-indigo-100 dark:border-indigo-500/30 shadow-xl shadow-indigo-100/50 dark:shadow-none">
    <div class="flex items-center gap-2 mb-6">
      <div class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></div>
      <span class="text-[10px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest">Nueva Propuesta</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
      <!-- Start Date Card -->
      <div class="flex items-center gap-3 p-3 bg-gray-50 dark:bg-slate-800/50 rounded-2xl border border-gray-100 dark:border-slate-700">
        <div class="w-10 h-10 rounded-xl bg-white dark:bg-slate-800 flex items-center justify-center border border-indigo-100 dark:border-slate-700 shadow-sm text-indigo-500">
          <i class="fa-solid fa-calendar-plus"></i>
        </div>
        <div class="text-left">
          <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Desde el</p>
          <p data-fullcalendar-target="inicio" class="text-sm font-black text-gray-900 dark:text-white leading-tight">---</p>
        </div>
      </div>

      <!-- End Date Card -->
      <div class="flex items-center gap-3 p-3 bg-gray-50 dark:bg-slate-800/50 rounded-2xl border border-gray-100 dark:border-slate-700">
        <div class="w-10 h-10 rounded-xl bg-white dark:bg-slate-800 flex items-center justify-center border border-rose-100 dark:border-slate-700 shadow-sm text-rose-500">
          <i class="fa-solid fa-calendar-minus"></i>
        </div>
        <div class="text-left">
          <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">Hasta el</p>
          <p data-fullcalendar-target="fin" class="text-sm font-black text-gray-900 dark:text-white leading-tight">---</p>
        </div>
      </div>
    </div>

    <!-- Total Card -->
    <div class="flex items-center justify-between p-4 bg-indigo-600 dark:bg-indigo-700 rounded-2xl shadow-lg shadow-indigo-100 dark:shadow-none">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center text-white">
          <i class="fa-solid fa-money-bill-wave"></i>
        </div>
        <p class="text-[10px] font-black text-indigo-100 uppercase tracking-widest">Total Estimado</p>
      </div>
      <p data-fullcalendar-target="precioTotal" class="text-xl font-black text-white">$ 0</p>
    </div>
  </div>
</div>
