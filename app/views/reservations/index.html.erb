<% content_for :title, "Agenda de Reservas" %>
<div class="mx-auto px-2 sm:px-6 lg:px-8 py-6"
     data-controller="fullcalendar" 
     data-fullcalendar-mode-value="dashboard" 
     data-fullcalendar-events-url-value="<%= reservations_path(format: :json) %>">
  <%= render "shared/index_header", 
      title: "Agenda de Reservas", 
      icon: "fa-solid fa-calendar-check", 
      subtitle: "Vista Global" do %>
    <div class="bg-white/50 dark:bg-slate-800/50 backdrop-blur-md p-1 rounded-xl border border-indigo-100 dark:border-slate-700 inline-flex shadow-sm">
       <span class="px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all duration-300 tab-active">Agenda</span>
       <%= link_to list_reservations_path, class: "px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all duration-300 text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400" do %>Listado<% end %>
    </div>
  <% end %>
  <div class="flex flex-col lg:flex-row gap-6">
    <div class="lg:w-8/12 xl:w-9/12">
      <div id="calendar-view" data-fullcalendar-target="calendarView" class="bg-white dark:bg-slate-900 rounded-[2rem] shadow-2xl shadow-indigo-100 dark:shadow-none border border-gray-100 dark:border-slate-800 p-2 sm:p-4 overflow-hidden">
        <%= render "shared/calendar_header", mode: 'dashboard' %>
        <div data-fullcalendar-target="calendar" class="min-h-[400px] sm:min-h-[480px]"></div>
      </div>
    </div>
    <div class="lg:w-4/12 xl:w-3/12">
      <div class="sticky top-6 space-y-4">
        <div class="bg-white dark:bg-slate-900 rounded-[2rem] border border-gray-100 dark:border-slate-800 shadow-xl p-5 overflow-hidden relative">
          <div class="absolute -top-12 -right-12 w-32 h-32 bg-indigo-500/5 rounded-full blur-2xl"></div>
          <h2 class="relative z-10 text-[10px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest mb-4 flex items-center gap-2">
            <i class="fa-solid fa-list-ul text-[8px]"></i> Reservas del Periodo
          </h2>
          <div class="relative z-10">
            <%= turbo_frame_tag "reservations_list_frame" do %>
              <div class="py-10 text-center">
                <div class="animate-pulse flex flex-col items-center">
                  <div class="w-8 h-8 bg-gray-100 dark:bg-slate-800 rounded-full mb-3"></div>
                  <div class="h-2 w-20 bg-gray-100 dark:bg-slate-800 rounded"></div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
        <div class="bg-gradient-to-br from-indigo-600 to-purple-700 rounded-[2rem] p-5 text-white shadow-lg shadow-indigo-200/50 dark:shadow-none">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-[9px] font-black uppercase tracking-widest opacity-80">Mes Actual</h3>
            <i class="fa-solid fa-chart-pie text-xs opacity-50"></i>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-xl font-black"><%= @current_month_count %></p>
              <p class="text-[8px] font-bold uppercase opacity-70">Reservas</p>
            </div>
            <div>
              <p class="text-lg font-black">$<%= number_to_currency(@current_month_earnings, unit: "", separator: ",", delimiter: ".") %></p>
              <p class="text-[8px] font-bold uppercase opacity-70">Ingresos</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>