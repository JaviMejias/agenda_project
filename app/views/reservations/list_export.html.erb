<div class="header">
  <h1>Reporte de Reservas</h1>
  <p style="text-transform: uppercase; font-weight: bold; font-size: 8px; color: #6b7280; letter-spacing: 2px;">
    <%= @reservations.count %> Reservas encontradas
  </p>
</div>

<table>
  <thead>
    <tr>
      <th>Vendedor</th>
      <th>Propiedad</th>
      <th>Inicio</th>
      <th>Fin</th>
      <th style="text-align: center;">Estado</th>
      <th style="text-align: right;">Precio</th>
    </tr>
  </thead>
  <tbody>
    <% @reservations.each do |reservation| %>
      <tr>
        <td><%= reservation.user&.full_name %></td>
        <td style="font-weight: bold; color: <%= reservation.property.color %>">
          <%= reservation.property.name %>
        </td>
        <td>
          <%= reservation.property.per_day? ? reservation.start_time.strftime("%d/%m/%Y") : reservation.start_time.strftime("%d/%m/%Y %H:%M") %>
        </td>
        <td>
          <%= reservation.property.per_day? ? (reservation.end_time - 1.day).strftime("%d/%m/%Y") : reservation.end_time.strftime("%d/%m/%Y %H:%M") %>
        </td>
        <td style="text-align: center;">
          <%
            status_color = case reservation.status
                           when 'pending' then '#d97706'
                           when 'confirmed' then '#059669'
                           when 'cancelled' then '#e11d48'
                           else '#6b7280'
                           end
            status_bg = case reservation.status
                           when 'pending' then '#fffbeb'
                           when 'confirmed' then '#f0fdf4'
                           when 'cancelled' then '#fff1f2'
                           else '#f9fafb'
                           end
          %>
          <span class="status-badge" style="color: <%= status_color %>; background-color: <%= status_bg %>; border: 1px solid <%= status_color %>33;">
            <%= reservation.status_text %>
          </span>
        </td>
        <td class="total-price" style="text-align: right;">
          $<%= number_with_delimiter(reservation.total_price.to_i, delimiter: ".") %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div style="margin-top: 30px; text-align: right;">
  <p style="font-size: 12px; font-weight: bold;">
    Total General: <span style="color: #4f46e5; font-size: 14px;">$<%= number_with_delimiter(@reservations.sum(:total_price).to_i, delimiter: ".") %></span>
  </p>
</div>
