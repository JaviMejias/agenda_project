<%= form_with(model: reservation, class: "space-y-4") do |form| %>
  <% if reservation.errors.any? %>
    <div class="p-4 mb-4 text-sm text-red-800 dark:text-red-400 rounded-lg bg-red-50 dark:bg-red-950/20 border border-red-100 dark:border-red-900">
      <h2 class="font-bold">No se pudo guardar la reserva:</h2>
      <ul class="list-disc pl-5 mt-2">
        <% reservation.errors.full_messages.each do |message| %>
          <li><%= sanitize(message, tags: %w(a), attributes: %w(href target class)) %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div class="sm:col-span-1" data-controller="client-select" data-client-select-url-value="<%= list_clients_path %>">
      <div class="flex items-center justify-between mb-1">
        <%= form.label :client_id, "Cliente", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
        <%= link_to new_client_path, class: "text-[10px] font-black text-indigo-600 dark:text-indigo-400 uppercase tracking-widest hover:text-indigo-800 transition-colors flex items-center gap-1", target: "_blank" do %>
          <i class="fa-solid fa-plus-circle"></i> Nuevo Cliente
        <% end %>
      </div>
      <%= form.select :client_id, 
          (reservation.client ? [[reservation.client.name, reservation.client.id]] : []), 
          { include_blank: true }, 
          { data: { client_select_target: "select" }, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-slate-700 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-slate-800 dark:text-white" } %>
      <p class="mt-1 text-[10px] text-gray-400 dark:text-slate-500">Busca por nombre o RUT</p>
    </div>

    <div>
      <%= form.label :status, "Estado de la Reserva", class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
      <%= form.select :status, Reservation.selectable_statuses.map { |s| [I18n.t("enums.reservation.status.#{s}"), s] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-slate-700 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-4 py-2 border bg-white dark:bg-slate-800 dark:text-white" %>
    </div>

    <div class="sm:col-span-2" data-controller="fullcalendar" data-fullcalendar-mode-value="booking" data-fullcalendar-per-hour-value="<%= reservation.property.per_hour? %>" data-fullcalendar-events-url-value="<%= reservations_path(property_id: reservation.property.id, exclude_id: reservation.id, format: :json) %>" data-fullcalendar-initial-start-value="<%= reservation.start_time&.iso8601 %>" data-fullcalendar-initial-end-value="<%= reservation.end_time&.iso8601 %>">
      <p class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Modifica tus fechas en el calendario</p>
      
      <div data-fullcalendar-target="calendar" class="bg-white dark:bg-slate-900 border dark:border-slate-800 rounded-lg shadow-sm w-full py-2"></div>
      
      <%= form.hidden_field :start_time, data: { fullcalendar_target: "startInput" }, required: true %>
      <%= form.hidden_field :end_time, data: { fullcalendar_target: "endInput" }, required: true %>
      
      <%= render "reservations/selection_summary" %>
    </div>
  </div>

  <div class="pt-4">
    <%= form.submit (reservation.new_record? ? "Crear Reserva" : "Actualizar Reserva"), class: "w-full inline-flex justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" %>
  </div>
<% end %>
