<% content_for :title, "Editar Reserva" %>

<div class="mx-auto px-4 sm:px-6 lg:px-8 py-10">
  
  <div class="mb-8">
    <% back_path = params[:from] == 'list' ? list_reservations_path : reservations_path %>
    <%= link_to back_path, class: "group inline-flex items-center text-sm font-bold text-gray-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" do %>
      <div class="w-10 h-10 rounded-full bg-white dark:bg-slate-800 shadow-md border border-gray-100 dark:border-slate-700 flex items-center justify-center mr-3 group-hover:bg-indigo-50 dark:group-hover:bg-indigo-900/50 group-hover:border-indigo-200 transition-all group-hover:-translate-x-1">
        <i class="fa-solid fa-arrow-left text-[10px]"></i>
      </div>
      Volver <%= params[:from] == 'list' ? 'al listado' : 'a la agenda' %>
    <% end %>
  </div>

  <div class="bg-white dark:bg-slate-900 shadow-2xl overflow-hidden rounded-[2.5rem] border border-gray-100 dark:border-slate-800 animate-fade-in-up">
    
    <!-- Light Header Style -->
    <div class="relative p-6 sm:p-10 bg-gradient-to-br from-white to-indigo-50 dark:from-slate-900 dark:to-slate-950 border-b border-indigo-100 dark:border-slate-800 overflow-hidden">
      <div class="absolute -top-24 -right-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="relative z-10 flex items-center gap-4">
        <div class="w-16 h-16 rounded-2xl bg-white dark:bg-slate-800 border border-indigo-100 dark:border-slate-700 shadow-sm flex items-center justify-center text-indigo-600 dark:text-indigo-400 text-3xl">
          <i class="fa-solid fa-pen-to-square"></i>
        </div>
        <div>
          <h3 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight leading-tight">Modificar Reserva</h3>
          <p class="text-indigo-600 dark:text-indigo-400 text-[10px] font-bold uppercase tracking-widest opacity-80">Reserva #<%= @reservation.id %> • <%= @reservation.property.name %></p>
        </div>
      </div>
    </div>

    <div class="p-6 py-10 sm:p-12">
      <%= form_with(model: @reservation, class: "space-y-10") do |form| %>
        <%= hidden_field_tag :from, params[:from] %>
        
        <% if @reservation.errors.any? %>
          <div class="p-6 text-sm text-red-800 dark:text-red-400 rounded-2xl bg-red-50 dark:bg-red-950/20 border border-red-100 dark:border-red-900 flex items-start shadow-sm mb-8">
            <i class="fa-solid fa-circle-exclamation mt-1 mr-4 text-red-500 text-xl"></i>
            <div>
              <h2 class="font-black text-lg mb-1">¡Ups! Hay errores:</h2>
              <ul class="list-disc pl-5 mt-1 space-y-1 font-medium">
                <% @reservation.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          <div>
            <%= form.label :client_name, class: "block text-sm font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-4 ml-2" do %>
              <i class="fa-regular fa-user mr-2"></i> Nombre del Cliente
            <% end %>
            <%= form.text_field :client_name, required: true, class: "block w-full rounded-2xl border-gray-100 dark:border-slate-700 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-lg px-6 py-4 border bg-gray-50 dark:bg-slate-800 focus:bg-white dark:focus:bg-slate-900 dark:text-white transition-all font-bold placeholder-gray-300 dark:placeholder:text-slate-600", placeholder: "Ej. Javier Mejías" %>
          </div>

          <div>
            <%= form.label :status, class: "block text-sm font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-4 ml-2" do %>
              <i class="fa-solid fa-circle-info mr-2"></i> Estado de la Reserva
            <% end %>
            <%= form.select :status, Reservation.selectable_statuses.map { |s| [I18n.t("enums.reservation.status.#{s}"), s] }, {}, class: "block w-full rounded-2xl border-gray-100 dark:border-slate-700 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-lg px-6 py-4 border bg-gray-50 dark:bg-slate-800 focus:bg-white dark:focus:bg-slate-900 dark:text-white transition-all font-bold cursor-pointer" %>
          </div>
        </div>

        <div class="mb-12">
          <%= render "shared/calendar_container", 
                     property: @reservation.property, 
                     mode: 'booking', 
                     events_url: reservations_path(property_id: @reservation.property.id, format: :json, exclude_id: @reservation.id),
                     initial_start: @reservation.start_time.iso8601,
                     initial_end: @reservation.end_time.iso8601 do %>
            <%= render "reservations/selection_summary" %>
          <% end %>
        </div>

        <div class="pt-8 border-t border-gray-100 dark:border-slate-800 flex flex-col sm:flex-row items-center justify-start gap-8">
          <%= link_to reservation_path(@reservation), class: "group inline-flex items-center text-sm font-bold text-gray-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all" do %>
            <div class="w-9 h-9 rounded-full bg-white dark:bg-slate-800 shadow-sm border border-gray-200 dark:border-slate-700 flex items-center justify-center mr-3 group-hover:bg-indigo-50 dark:group-hover:bg-indigo-900/50 group-hover:border-indigo-200 transition-all group-hover:-translate-x-1">
              <i class="fa-solid fa-arrow-left text-xs"></i>
            </div>
            Volver sin guardar
          <% end %>

          <%= form.button type: "submit", class: "w-full sm:w-auto sm:min-w-[200px] flex justify-center items-center py-3.5 px-6 border border-transparent rounded-xl shadow-lg text-base font-bold text-white bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer transform hover:-translate-y-1 transition-all duration-300" do %>
            <i class="fa-solid fa-floppy-disk mr-2"></i>
            <span>Guardar Cambios</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
