<div style="font-family: sans-serif; padding: 40px; max-width: 800px; margin: 0 auto; color: #333;">
  <div style="text-align: right; margin-bottom: 40px;">
    <h1 style="color: #4f46e5; margin: 0; font-size: 32px;">COMPROBANTE DE RESERVA</h1>
    <p style="margin: 5px 0; color: #666;">Documento Interno - No válido como boleta o factura</p>
    <p style="font-weight: bold; margin: 5px 0;">Folio: #<%= @reservation.id %></p>
    <p style="margin: 5px 0;">Fecha de emisión: <%= Time.current.strftime("%d/%m/%Y") %></p>
  </div>
  <div style="display: flex; justify-content: space-between; border-bottom: 2px solid #eee; padding-bottom: 20px; margin-bottom: 30px;">
    <div>
      <h3 style="color: #666; margin-bottom: 5px; text-transform: uppercase; font-size: 12px;">Datos del Cliente</h3>
      <p style="font-weight: bold; font-size: 18px; margin: 0;"><%= @reservation.client_name %></p>
      <% if @reservation.client %>
        <p style="margin: 5px 0;"><%= @reservation.client.rut %></p>
        <p style="margin: 5px 0;"><%= @reservation.client.email %></p>
      <% end %>
    </div>
    <div style="text-align: right;">
      <h3 style="color: #666; margin-bottom: 5px; text-transform: uppercase; font-size: 12px;">Datos de la Propiedad</h3>
      <p style="font-weight: bold; font-size: 18px; margin: 0;"><%= @reservation.property.name %></p>
      <p style="margin: 5px 0;"><%= @reservation.property.address %></p>
    </div>
  </div>
  <div style="background-color: #f8fafc; padding: 20px; border-radius: 8px; margin-bottom: 30px;">
    <h3 style="margin-top: 0; border-bottom: 1px solid #e2e8f0; padding-bottom: 10px;">Detalles de la Reserva</h3>
    <table style="width: 100%; border-collapse: collapse;">
      <tr>
        <td style="padding: 10px 0; border-bottom: 1px solid #e2e8f0;"><strong>Fecha de Entrada:</strong></td>
        <td style="padding: 10px 0; text-align: right; border-bottom: 1px solid #e2e8f0;"><%= @reservation.start_time.strftime("%d/%m/%Y %H:%M") %></td>
      </tr>
      <tr>
        <td style="padding: 10px 0; border-bottom: 1px solid #e2e8f0;"><strong>Fecha de Salida:</strong></td>
        <td style="padding: 10px 0; text-align: right; border-bottom: 1px solid #e2e8f0;"><%= @reservation.end_time.strftime("%d/%m/%Y %H:%M") %></td>
      </tr>
      <tr>
        <td style="padding: 10px 0; border-bottom: 1px solid #e2e8f0;"><strong>Estado de la Reserva:</strong></td>
        <td style="padding: 10px 0; text-align: right; border-bottom: 1px solid #e2e8f0; font-weight: bold;"><%= I18n.t("enums.reservation.status.#{@reservation.status}") %></td>
      </tr>
      <tr>
        <td style="padding: 10px 0; border-bottom: 1px solid #e2e8f0;"><strong>Estado Financiero:</strong></td>
        <td style="padding: 10px 0; text-align: right; border-bottom: 1px solid #e2e8f0; font-weight: bold;"><%= @reservation.payment_state %></td>
      </tr>
    </table>
  </div>
  <h3 style="margin-top: 40px; border-bottom: 2px solid #eee; padding-bottom: 10px;">Historial de Pagos</h3>
  <table style="width: 100%; border-collapse: collapse; margin-bottom: 40px;">
    <thead>
      <tr style="background-color: #f1f5f9;">
        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #cbd5e1;">Fecha</th>
        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #cbd5e1;">Concepto</th>
        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #cbd5e1;">Método</th>
        <th style="padding: 12px; text-align: right; border-bottom: 1px solid #cbd5e1;">Monto</th>
      </tr>
    </thead>
    <tbody>
      <% @reservation.payments.order(payment_date: :asc).each do |payment| %>
        <tr>
          <td style="padding: 12px; border-bottom: 1px solid #e2e8f0;"><%= payment.payment_date.strftime("%d/%m/%Y") %></td>
          <td style="padding: 12px; border-bottom: 1px solid #e2e8f0;"><%= payment.transaction_type.titleize %></td>
          <td style="padding: 12px; border-bottom: 1px solid #e2e8f0;"><%= payment_method_label(payment) %></td>
          <td style="padding: 12px; text-align: right; border-bottom: 1px solid #e2e8f0; font-weight: bold; color: <%= payment.abono? ? '#10b981' : '#ef4444' %>">
            <%= payment.abono? ? '+' : '-' %> $<%= number_to_currency(payment.amount, unit: "", separator: ",", delimiter: ".") %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div style="display: flex; justify-content: flex-end;">
    <div style="width: 300px; background-color: #f8fafc; padding: 20px; border-radius: 8px;">
      <table style="width: 100%;">
        <tr>
          <td style="padding: 5px 0;"><strong>Valor Total:</strong></td>
          <td style="padding: 5px 0; text-align: right;">$<%= number_to_currency(@reservation.total_price, unit: "", separator: ",", delimiter: ".") %></td>
        </tr>
        <tr>
          <td style="padding: 5px 0;"><strong>Total Pagado:</strong></td>
          <td style="padding: 5px 0; text-align: right;">$<%= number_to_currency(@reservation.total_paid, unit: "", separator: ",", delimiter: ".") %></td>
        </tr>
        <tr style="border-top: 2px solid #cbd5e1;">
          <td style="padding: 15px 0 5px 0;"><strong style="font-size: 18px;">Saldo Pendiente:</strong></td>
          <td style="padding: 15px 0 5px 0; text-align: right;"><strong style="font-size: 18px; color: <%= @reservation.pending_balance <= 0 ? '#10b981' : '#f59e0b' %>">$<%= number_to_currency(@reservation.pending_balance, unit: "", separator: ",", delimiter: ".") %></strong></td>
        </tr>
      </table>
    </div>
  </div>
</div>
