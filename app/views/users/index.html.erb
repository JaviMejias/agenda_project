<% content_for :title, "Gestión de Usuarios" %>
<div class="mx-auto px-4 sm:px-6 lg:px-8 py-6" data-controller="search">
  <%= render "shared/index_header", 
      title: "Gestión de Usuarios", 
      icon: "fa-solid fa-users-gear", 
      count: @pagy.count, 
      count_frame_id: "users_count", 
      search_url: users_path, 
      search_placeholder: "Buscar usuario...", 
      search_frame_id: "users_frame" do %>
    
    <%= link_to new_user_path, class: "w-full sm:w-auto group flex items-center justify-center gap-3 px-6 py-3.5 bg-white dark:bg-indigo-600 text-indigo-600 dark:text-white rounded-2xl border border-indigo-100 dark:border-transparent hover:bg-indigo-50 dark:hover:bg-indigo-500 transition-all shadow-md shadow-indigo-100/50 dark:shadow-none hover:-translate-y-1 active:scale-95" do %>
      <i class="fa-solid fa-plus-circle text-indigo-500 dark:text-indigo-200 group-hover:rotate-90 transition-transform duration-500"></i>
      <span class="text-[10px] font-black uppercase tracking-widest">Nuevo Usuario</span>
    <% end %>
  <% end %>
  <turbo-frame id="users_frame" class="relative block">
    <%= render "shared/loading_state", text: "Actualizando equipo..." %>
    <% if @users.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @users.each do |user| %>
          <div class="group bg-white dark:bg-slate-900 rounded-[2rem] border border-gray-100 dark:border-slate-800 shadow-sm hover:shadow-xl hover:shadow-indigo-500/5 transition-all duration-500 overflow-hidden flex flex-col border-b-4 <%= user.admin? ? 'border-b-indigo-500' : 'border-b-gray-200 dark:border-b-slate-700' %>">
            <div class="p-6 sm:p-8 flex-grow">
              <div class="flex justify-between items-start mb-6">
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-tr <%= user.admin? ? 'from-indigo-600 to-purple-600' : 'from-gray-100 to-gray-200 dark:from-slate-700 dark:to-slate-800' %> flex items-center justify-center text-white font-black text-2xl shadow-lg ring-4 ring-white dark:ring-slate-800 transition-transform group-hover:scale-110 duration-500">
                  <%= (user.first_name.presence || user.email)[0].upcase %>
                </div>
                <% if user.admin? %>
                  <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-widest bg-indigo-50 dark:bg-indigo-950/30 text-indigo-600 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900 shadow-sm">
                    <i class="fa-solid fa-shield-halved mr-1.5 text-[8px]"></i> Admin
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-widest bg-gray-50 dark:bg-slate-800 text-gray-500 dark:text-slate-400 border border-gray-100 dark:border-slate-700">
                    <i class="fa-solid fa-user mr-1.5 text-[8px]"></i> Normal
                  </span>
                <% end %>
              </div>
              <div class="space-y-1 mb-6">
                <h3 class="text-xl font-black text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors truncate">
                  <%= user.full_name.presence || "Usuario Sin Nombre" %>
                </h3>
                <p class="text-sm font-bold text-gray-400 dark:text-slate-500 flex items-center gap-2">
                  <i class="fa-regular fa-envelope text-[10px]"></i>
                  <%= user.email %>
                </p>
              </div>
              <div class="flex items-center gap-6 pt-6 border-t border-gray-50 dark:border-slate-800">
                <div>
                  <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-1">Desde</p>
                  <p class="text-xs font-bold text-gray-700 dark:text-slate-300"><%= user.created_at.strftime("%b %Y") %></p>
                </div>
                <% if user.reservations.any? %>
                  <div>
                    <p class="text-[9px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest mb-1">Reservas</p>
                    <p class="text-xs font-bold text-gray-700 dark:text-slate-300"><%= user.reservations.count %></p>
                  </div>
                <% end %>
              </div>
            </div>
            <div class="px-6 py-4 bg-gray-50/50 dark:bg-slate-800/50 border-t border-gray-100 dark:border-slate-800 flex items-center justify-end gap-3">
              <%= link_to edit_user_path(user), data: { turbo_frame: "_top" }, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:border-indigo-200 dark:hover:border-indigo-900 hover:bg-indigo-50 dark:hover:bg-indigo-950/30 transition-all shadow-sm" do %>
                <i class="fa-solid fa-user-pen"></i>
                Editar
              <% end %>
              <% if user != current_user %>
                <%= button_to user_path(user), method: :delete, data: { turbo_confirm: "¿Estás seguro de eliminar a #{user.full_name}?" }, class: "w-10 h-10 flex items-center justify-center bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl text-gray-400 dark:text-slate-500 hover:text-red-600 hover:border-red-200 dark:hover:border-red-900 hover:bg-red-50 dark:hover:bg-red-950/20 transition-all shadow-sm" do %>
                  <i class="fa-solid fa-trash-can text-xs"></i>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", 
          icon: "fa-solid fa-user-slash", 
          title: "No encontramos a nadie", 
          subtitle: "Asegúrate de que el nombre o email estén bien escritos e inténtalo de nuevo." %>
    <% end %>
    <%= render "shared/pagination" %>
  </turbo-frame>
</div>
