<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "Agenda Pro" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
    <link rel="manifest" href="<%= pwa_manifest_path %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">
    <meta name="turbo-cache-control" content="no-cache">

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <%= vite_client_tag %>
    <%= vite_stylesheet_tag "application.css", "data-turbo-track": "reload" %>
    <%= vite_javascript_tag "theme", "data-turbo-track": "reload" %>
    <%= vite_javascript_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body class="min-h-screen bg-slate-50 dark:bg-slate-950 text-gray-900 dark:text-slate-100 selection:bg-indigo-500 selection:text-white transition-colors duration-500">
    
    <!-- Navbar Público -->
    <nav data-controller="mobile-menu" class="fixed top-0 inset-x-0 z-50 transition-colors duration-300">
      <%# Background Blur %>
      <div class="absolute inset-0 bg-white/80 dark:bg-slate-950/80 backdrop-blur-md border-b border-gray-100/80 dark:border-slate-800 shadow-sm -z-10"></div>
      
      <div class="mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 justify-between items-center">
          <div class="flex items-center gap-8">
            <%= link_to (user_signed_in? && current_user.client? ? public_property_index_path : root_path), class: "flex items-center gap-3 group" do %>
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white shadow-md shadow-indigo-500/20 group-hover:scale-105 transition-transform">
                <i class="fa-solid fa-calendar-check text-xl animate-pulse"></i>
              </div>
              <span class="text-xl font-black bg-clip-text text-transparent bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-slate-300">Agenda Pro</span>
            <% end %>
            
            <div class="hidden sm:flex sm:items-center sm:space-x-2">
              <%= link_to public_property_index_path, class: "group relative inline-flex items-center rounded-xl px-4 py-2 text-sm font-bold transition-all duration-300 #{current_page?(public_property_index_path) || current_page?(root_path) ? 'text-indigo-600 bg-indigo-50/50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
                <i class="fa-solid fa-house-chimney mr-2.5 transition-colors <%= current_page?(public_property_index_path) || current_page?(root_path) ? 'text-indigo-500' : 'text-gray-400 group-hover:text-indigo-500' %>"></i>
                <span>Explorar Espacios</span>
              <% end %>

              <% if user_signed_in? %>
                <% if current_user.client? %>
                  <%= link_to my_reservations_path, class: "group relative inline-flex items-center rounded-xl px-4 py-2 text-sm font-bold transition-all duration-300 #{current_page?(my_reservations_path) ? 'text-indigo-600 bg-indigo-50/50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
                    <i class="fa-solid fa-calendar-days mr-2.5 transition-colors <%= current_page?(my_reservations_path) ? 'text-indigo-500' : 'text-gray-400 group-hover:text-indigo-500' %>"></i>
                    <span>Mis Reservas</span>
                  <% end %>
                <% else %>
                  <%= link_to dashboard_path, class: "group relative inline-flex items-center rounded-xl px-4 py-2 text-sm font-bold transition-all duration-300 #{current_page?(dashboard_path) ? 'text-indigo-600 bg-indigo-50/50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
                    <i class="fa-solid fa-gauge-high mr-2.5 transition-colors <%= current_page?(dashboard_path) ? 'text-indigo-500' : 'text-gray-400 group-hover:text-indigo-500' %>"></i>
                    <span>Mi Panel</span>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            
            <!-- Selector de Temas (Desktop) -->
            <div data-controller="theme" class="hidden sm:flex items-center bg-gray-100 dark:bg-slate-800/50 p-1 rounded-xl border border-gray-200/50 dark:border-slate-700/50">
              <button data-action="click->theme#setTheme" data-theme-value="light" title="Modo Claro"
                      class="w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-200 hover:text-indigo-600 dark:hover:text-indigo-400 text-gray-500 dark:text-slate-400">
                <i class="fa-solid fa-sun text-xs"></i>
              </button>
              <button data-action="click->theme#setTheme" data-theme-value="system" title="Seguir Sistema"
                      class="w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-200 hover:text-indigo-600 dark:hover:text-indigo-400 text-gray-500 dark:text-slate-400">
                <i class="fa-solid fa-desktop text-xs"></i>
              </button>
              <button data-action="click->theme#setTheme" data-theme-value="dark" title="Modo Oscuro"
                      class="w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-200 hover:text-indigo-600 dark:hover:text-indigo-400 text-gray-500 dark:text-slate-400">
                <i class="fa-solid fa-moon text-xs"></i>
              </button>
            </div>

            <% if user_signed_in? %>
              <div class="hidden md:flex items-center gap-3 pr-4 border-r border-gray-100 dark:border-slate-800">
                <div class="flex flex-col items-end">
                  <span class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest leading-none">Usuario</span>
                  <span class="text-xs font-bold text-gray-700 dark:text-slate-200 truncate max-w-[150px]"><%= current_user.email.split('@').first %></span>
                </div>
                <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-600 text-white font-black text-sm shadow-lg shadow-indigo-100/30 dark:shadow-none ring-2 ring-white dark:ring-slate-800">
                  <%= current_user.email[0].upcase %>
                </div>
              </div>
              
              <div class="hidden sm:block">
                <%= link_to destroy_user_session_path, data: { turbo: false }, class: "group inline-flex items-center justify-center rounded-xl text-xs font-black uppercase tracking-widest text-gray-400 hover:text-red-600 hover:bg-red-50 dark:hover:bg-red-950/20 px-4 py-2.5 transition-all duration-300 border border-transparent hover:border-red-100 dark:hover:border-red-900 cursor-pointer" do %>
                  <i class="fa-solid fa-power-off mr-2 group-hover:rotate-90 transition-transform"></i> Salir
                <% end %>
              </div>
            <% else %>
              <%= link_to new_user_session_path, class: "hidden sm:inline-flex items-center justify-center rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-700 dark:text-slate-300 px-5 py-2.5 text-sm font-bold shadow-sm hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors" do %>
                <i class="fa-solid fa-right-to-bracket mr-2"></i> Iniciar Sesión
              <% end %>
              <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 dark:bg-indigo-500 text-white px-5 py-2.5 text-sm font-bold shadow-sm hover:bg-indigo-700 dark:hover:bg-indigo-600 transition-colors" do %>
                <i class="fa-solid fa-user-plus mr-2"></i> Crear Cuenta
              <% end %>
            <% end %>

            <!-- Hamburguesa Móvil -->
            <button data-action="click->mobile-menu#toggle" class="sm:hidden inline-flex items-center justify-center rounded-xl p-2.5 text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-indigo-400 focus:outline-none transition-all border border-gray-100 dark:border-slate-800 cursor-pointer">
              <span data-mobile-menu-target="iconOpen">
                <i class="fa-solid fa-bars-staggered text-xl"></i>
              </span>
              <span data-mobile-menu-target="iconClose" class="hidden">
                <i class="fa-solid fa-xmark text-xl"></i>
              </span>
            </button>
          </div>
        </div>
      </div>
      
      <!-- Menú Móvil -->
      <div data-mobile-menu-target="menu" class="sm:hidden hidden border-t border-gray-100/50 dark:border-slate-800 bg-white/95 dark:bg-slate-950/95 backdrop-blur-xl transition-all duration-300">
        <div class="space-y-1.5 px-4 py-6">
          
          <div class="px-5 mb-2">
            <span class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest">Navegación</span>
          </div>
          <%= link_to public_property_index_path, class: "flex items-center rounded-2xl px-5 py-4 text-base font-black transition-all #{current_page?(public_property_index_path) || current_page?(root_path) ? 'text-indigo-600 bg-indigo-50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-slate-200 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
            <i class="fa-solid fa-house-chimney mr-4 w-6 text-center <%= current_page?(public_property_index_path) || current_page?(root_path) ? 'text-indigo-500' : 'text-gray-400' %>"></i> Explorar Espacios
          <% end %>

          <% if user_signed_in? %>
            <% if current_user.client? %>
              <%= link_to my_reservations_path, class: "flex items-center rounded-2xl px-5 py-4 text-base font-black transition-all #{current_page?(my_reservations_path) ? 'text-indigo-600 bg-indigo-50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-slate-200 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
                <i class="fa-solid fa-calendar-days mr-4 w-6 text-center <%= current_page?(my_reservations_path) ? 'text-indigo-500' : 'text-gray-400' %>"></i> Mis Reservas
              <% end %>
            <% else %>
              <%= link_to dashboard_path, class: "flex items-center rounded-2xl px-5 py-4 text-base font-black transition-all #{current_page?(dashboard_path) ? 'text-indigo-600 bg-indigo-50 dark:text-indigo-400 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-slate-200 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-50 dark:hover:bg-slate-800'}" do %>
                <i class="fa-solid fa-gauge-high mr-4 w-6 text-center <%= current_page?(dashboard_path) ? 'text-indigo-500' : 'text-gray-400' %>"></i> Mi Panel
              <% end %>
            <% end %>
          <% end %>
          
          <div class="px-5 mt-6 mb-2">
            <span class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest">Apariencia</span>
          </div>
          <div data-controller="theme" class="flex items-center justify-between bg-gray-50 dark:bg-slate-800/80 mx-5 p-1.5 rounded-2xl border border-gray-100 dark:border-slate-700">
            <button data-action="click->theme#setTheme" data-theme-value="light" class="flex-1 flex flex-col items-center gap-1.5 py-3 rounded-xl transition-all hover:bg-white dark:hover:bg-slate-750 text-gray-500 dark:text-slate-400">
              <i class="fa-solid fa-sun text-sm"></i>
              <span class="text-[9px] font-black uppercase tracking-tighter">Claro</span>
            </button>
            <button data-action="click->theme#setTheme" data-theme-value="system" class="flex-1 flex flex-col items-center gap-1.5 py-3 rounded-xl transition-all hover:bg-white dark:hover:bg-slate-750 text-gray-500 dark:text-slate-400">
              <i class="fa-solid fa-desktop text-sm"></i>
              <span class="text-[9px] font-black uppercase tracking-tighter">Sistema</span>
            </button>
            <button data-action="click->theme#setTheme" data-theme-value="dark" class="flex-1 flex flex-col items-center gap-1.5 py-3 rounded-xl transition-all hover:bg-white dark:hover:bg-slate-750 text-gray-500 dark:text-slate-400">
              <i class="fa-solid fa-moon text-sm"></i>
              <span class="text-[9px] font-black uppercase tracking-tighter">Oscuro</span>
            </button>
          </div>
          
          <div class="pt-6 mt-6 border-t border-gray-100 dark:border-slate-800">
            <% if user_signed_in? %>
              <div class="flex items-center justify-between px-2">
                <div class="flex items-center gap-3">
                  <div class="flex items-center justify-center w-10 h-10 rounded-2xl bg-gradient-to-tr from-indigo-500 to-purple-600 text-white font-black shadow-md">
                    <%= current_user.email[0].upcase %>
                  </div>
                  <div class="flex flex-col">
                    <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest leading-none mb-1">Mi Cuenta</span>
                    <span class="text-sm font-bold text-gray-700 dark:text-slate-300 truncate max-w-[180px]"><%= current_user.email %></span>
                  </div>
                </div>
                <%= link_to destroy_user_session_path, data: { turbo: false }, class: "flex items-center justify-center w-10 h-10 rounded-2xl bg-red-50 dark:bg-red-950/20 text-red-500 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/30 transition-all border border-transparent hover:border-red-100 dark:hover:border-red-900 cursor-pointer" do %>
                  <i class="fa-solid fa-power-off"></i>
                <% end %>
              </div>
            <% else %>
              <div class="grid grid-cols-2 gap-4 px-2">
                <%= link_to new_user_session_path, class: "flex items-center justify-center rounded-2xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-gray-700 dark:text-slate-300 py-4 text-base font-black shadow-sm hover:bg-gray-50 dark:hover:bg-slate-750 transition-colors" do %>
                  <i class="fa-solid fa-right-to-bracket mr-2"></i> Iniciar Sesión
                <% end %>
                <%= link_to new_user_registration_path, class: "flex items-center justify-center rounded-2xl bg-indigo-600 dark:bg-indigo-500 text-white py-4 text-base font-black shadow-sm hover:bg-indigo-700 dark:hover:bg-indigo-600 transition-colors" do %>
                  <i class="fa-solid fa-user-plus mr-2"></i> Crear Cuenta
                <% end %>
              </div>
            <% end %>
          </div>

        </div>
      </div>
    </nav>

    <main class="pt-16 pb-20 sm:pb-8 flex flex-col min-h-screen">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>

  </body>
</html>
