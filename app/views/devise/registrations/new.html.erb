<div class="w-full max-w-md mx-4 bg-white rounded-3xl shadow-2xl overflow-hidden animate-fade-in-up">
  <div class="px-6 py-8 sm:px-10 sm:py-12">
    
    <div class="text-center mb-8">
      <div class="mx-auto h-16 w-16 bg-gradient-to-tr from-indigo-100 to-purple-100 rounded-full flex items-center justify-center mb-4 shadow-inner">
        <i class="fa-solid fa-user-plus text-3xl text-indigo-600"></i>
      </div>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Crea tu cuenta</h2>
      <p class="mt-2 text-sm text-gray-500">Únete para empezar a gestionar tus propiedades</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      
      <div>
        <%= f.label :email, "Correo electrónico", class: "block text-sm font-bold text-gray-700 mb-1" %>
        <div class="relative rounded-xl shadow-sm">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <i class="fa-regular fa-envelope text-gray-400"></i>
          </div>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "tu@correo.com",
            class: "block w-full pl-11 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm bg-gray-50 focus:bg-white text-gray-900 transition-colors" %>
        </div>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-bold text-gray-700 mb-1" do %>
          Contraseña
          <% if @minimum_password_length %>
            <span class="text-xs font-normal text-gray-400 ml-1">(mín. <%= @minimum_password_length %> caracteres)</span>
          <% end %>
        <% end %>
        <div class="relative rounded-xl shadow-sm">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <i class="fa-solid fa-lock text-gray-400"></i>
          </div>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "Crea tu contraseña",
            class: "block w-full pl-11 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm bg-gray-50 focus:bg-white text-gray-900 transition-colors" %>
        </div>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirma tu contraseña", class: "block text-sm font-bold text-gray-700 mb-1" %>
        <div class="relative rounded-xl shadow-sm">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <i class="fa-solid fa-check-circle text-gray-400"></i>
          </div>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Repite tu contraseña",
            class: "block w-full pl-11 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm bg-gray-50 focus:bg-white text-gray-900 transition-colors" %>
        </div>
      </div>

      <div class="pt-2">
        <%= f.submit "Crear Cuenta", class: "w-full flex justify-center py-3.5 px-4 border border-transparent rounded-xl shadow-md text-sm font-bold text-white bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer transform hover:-translate-y-0.5 transition-all duration-200" %>
      </div>
    <% end %>

  </div>
  
  <div class="px-6 py-6 bg-gray-50 border-t border-gray-100 sm:px-10 text-center">
    <p class="text-sm text-gray-600">
      ¿Ya tienes una cuenta? 
      <%= link_to "Inicia sesión", new_session_path(resource_name), class: "font-bold text-indigo-600 hover:text-indigo-500 transition-colors" %>
    </p>
  </div>
</div>
