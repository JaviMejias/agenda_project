<%
  form_structure = [
    { name: :first_name, label: "Nombre", placeholder: "Juan", type: :text_field, icon: "fa-regular fa-user", required: true },
    { name: :last_name, label: "Apellido", placeholder: "Pérez", type: :text_field, icon: "fa-regular fa-user", required: true },
    { name: :rut, label: "RUT", placeholder: "12.345.678-9", type: :text_field, icon: "fa-solid fa-id-card", required: true, data: { action: "input->rut#format" } },
    { name: :phone, label: "Teléfono", placeholder: "+56 9 1234 5678", type: :telephone_field, icon: "fa-solid fa-phone", required: true },
    { name: :email, label: "Correo electrónico", type: :email_field, icon: "fa-regular fa-envelope", autocomplete: "email", required: true },
    { name: :password, label: "Nueva contraseña", placeholder: "Nueva contraseña", type: :password_field, icon: "fa-solid fa-lock", autocomplete: "new-password", required: false, change_label: true },
    { name: :password_confirmation, label: "Confirmar nueva contraseña", placeholder: "Repite nueva contraseña", type: :password_field, icon: "fa-solid fa-check-circle", autocomplete: "new-password", required: false },
    { name: :current_password, label: "Contraseña Actual", placeholder: "Contraseña actual", type: :password_field, icon: "fa-solid fa-shield-halved", autocomplete: "current-password", required: true, current_password_label: true, border_t: true }
  ]
%>
<% content_for :title, "Mi Perfil" %>
<div class="mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in">
  <div class="mb-8">
    <%= link_to :back, class: "group inline-flex items-center text-sm font-bold text-gray-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" do %>
      <div class="w-10 h-10 rounded-full bg-white dark:bg-slate-800 shadow-md border border-gray-100 dark:border-slate-700 flex items-center justify-center mr-3 group-hover:bg-indigo-50 dark:group-hover:bg-indigo-900/50 group-hover:border-indigo-200 transition-all group-hover:-translate-x-1">
        <i class="fa-solid fa-arrow-left text-xs"></i>
      </div>
      Volver
    <% end %>
  </div>
  <div class="max-w-lg mx-auto bg-white dark:bg-slate-900 shadow-2xl overflow-hidden rounded-[2.5rem] border border-gray-100 dark:border-slate-800 animate-fade-in-up">
    <div class="relative p-6 sm:p-10 bg-gradient-to-br from-white to-indigo-50 dark:from-slate-900 dark:to-slate-950 border-b border-indigo-100 dark:border-slate-800 overflow-hidden">
      <div class="absolute -top-24 -right-24 w-80 h-80 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="relative z-10 flex items-center gap-4">
        <div class="w-14 h-14 rounded-2xl bg-white dark:bg-slate-800 border border-indigo-100/50 dark:border-slate-700 shadow-sm flex items-center justify-center text-indigo-600 dark:text-indigo-400 text-2xl">
          <i class="fa-solid fa-user-gear"></i>
        </div>
        <div>
          <h3 class="text-2xl font-black text-gray-900 dark:text-white tracking-tight leading-tight">Configuración del Perfil</h3>
          <p class="text-indigo-600 dark:text-indigo-400 text-[10px] font-bold uppercase tracking-widest opacity-80">Edita tus credenciales de acceso</p>
        </div>
      </div>
    </div>
    <div class="px-6 py-8 sm:px-10">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6", autocomplete: "off", data: { controller: "rut" } }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <% form_structure.each do |field| %>
          <div class="space-y-2 <%= 'pt-4 border-t border-gray-100 dark:border-slate-800' if field[:border_t] %>">
            <%= f.label field[:name], class: "block text-xs font-black text-gray-400 dark:text-slate-500 uppercase tracking-widest ml-1" do %>
              <%= field[:label] %>
              <% if field[:change_label] %>
                <span class="lowercase text-[10px] font-bold text-gray-400 dark:text-slate-500">(dejar en blanco si no deseas cambiarla)</span>
              <% elsif field[:current_password_label] %>
                <span class="lowercase text-[10px] font-bold text-indigo-500 dark:text-indigo-400">(requerida para confirmar cambios)</span>
              <% end %>
            <% end %>
            <div class="relative group">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-400 dark:text-slate-600 group-focus-within:text-indigo-600 transition-colors">
                <i class="<%= field[:icon] %>"></i>
              </div>
              <%= f.public_send(field[:type], field[:name],
                  autofocus: field[:autofocus],
                  autocomplete: field[:autocomplete],
                  placeholder: field[:placeholder],
                  required: field[:required],
                  data: field[:data],
                  class: "block w-full pl-11 pr-4 py-4 border border-gray-200/80 dark:border-slate-800 rounded-2xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent sm:text-sm bg-gray-50/50 dark:bg-slate-800/20 focus:bg-white dark:focus:bg-slate-800 text-gray-900 dark:text-white transition-all shadow-sm"
              ) %>
            </div>
          </div>
        <% end %>
        <div class="pt-6 border-t border-gray-100 dark:border-slate-800 flex flex-col sm:flex-row items-center justify-start gap-8">
          <%= button_tag type: "submit", class: "w-full sm:w-auto sm:min-w-[200px] flex justify-center items-center py-3.5 px-6 border border-transparent rounded-xl shadow-lg text-base font-bold text-white bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer transform hover:-translate-y-1 transition-all duration-300" do %>
            <i class="fa-solid fa-floppy-disk mr-2"></i> Actualizar Perfil
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
